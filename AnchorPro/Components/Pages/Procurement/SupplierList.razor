@page "/procurement/suppliers"
@using AnchorPro.Data.Entities
@using AnchorPro.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Purchasing")]
@inject IProcurementService ProcurementService
@inject AuthenticationStateProvider AuthStateProvider
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Suppliers | Anchor Pro</PageTitle>

<ApplePageHeader Title="Supplier Registry" Subtitle="Manage vendors, vendors contacts and procurement relationships">
    <ActionButtons>
        <button class="btn btn-premium btn-sm" @onclick="OpenCreateModal">
            <i class="bi bi-plus-lg me-1"></i> ADD SUPPLIER
        </button>
    </ActionButtons>
</ApplePageHeader>

<div class="card-premium p-0 overflow-hidden mt-3">
    <div class="table-responsive">
        <table class="table-premium">
            <thead>
                <tr>
                    <th class="ps-4">SUPPLIER CODE</th>
                    <th>NAME</th>
                    <th>CONTACT PERSON</th>
                    <th>EMAIL</th>
                    <th>PHONE</th>
                    <th class="text-end pe-4">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @if (suppliers == null)
                {
                    <tr><td colspan="6" class="py-5 text-center"><div class="spinner-border spinner-border-sm text-primary"></div></td></tr>
                }
                else if (!suppliers.Any())
                {
                    <tr><td colspan="6" class="py-5 text-center text-slate-400 fw-600">No suppliers registered.</td></tr>
                }
                else
                {
                    @foreach (var s in suppliers)
                    {
                        <tr>
                            <td class="ps-4 fw-800 text-slate-400">@(s.SupplierCode ?? "N/A")</td>
                            <td class="fw-800 text-slate-900">@s.Name</td>
                            <td class="small text-slate-600">@s.ContactPerson</td>
                            <td class="small text-slate-600">@s.Email</td>
                            <td class="small text-slate-600">@s.Phone</td>
                            <td class="text-end pe-4">
                                <button class="btn-action" @onclick="() => OpenEditModal(s)">EDIT</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@* Create/Edit Modal *@
@if (showModal)
{
    <div class="modal fade show d-block" style="background-color:rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius:16px;">
                <div class="modal-header py-4 px-4 border-0">
                    <h5 class="modal-title fw-800 text-slate-900">@(editSupplier.Id == 0 ? "Add New Supplier" : "Edit Supplier")</h5>
                    <button type="button" class="btn-close" @onclick="() => showModal = false"></button>
                </div>
                <div class="modal-body px-4 pb-4">
                    <div class="row g-3 mb-3">
                        <div class="col-12">
                            <label class="form-label x-small fw-800 text-slate-400 text-uppercase">Company Name</label>
                            <input type="text" @bind="editSupplier.Name" class="form-control form-control-premium" />
                        </div>
                        <div class="col-6">
                            <label class="form-label x-small fw-800 text-slate-400 text-uppercase">Supplier Code</label>
                            <input type="text" @bind="editSupplier.SupplierCode" class="form-control form-control-premium" />
                        </div>
                        <div class="col-6">
                            <label class="form-label x-small fw-800 text-slate-400 text-uppercase">Contact Person</label>
                            <input type="text" @bind="editSupplier.ContactPerson" class="form-control form-control-premium" />
                        </div>
                        <div class="col-6">
                            <label class="form-label x-small fw-800 text-slate-400 text-uppercase">Email</label>
                            <input type="email" @bind="editSupplier.Email" class="form-control form-control-premium" />
                        </div>
                        <div class="col-6">
                            <label class="form-label x-small fw-800 text-slate-400 text-uppercase">Phone</label>
                            <input type="text" @bind="editSupplier.Phone" class="form-control form-control-premium" />
                        </div>
                        <div class="col-12">
                            <label class="form-label x-small fw-800 text-slate-400 text-uppercase">Address</label>
                            <input type="text" @bind="editSupplier.Address" class="form-control form-control-premium" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-light fw-800 px-4" style="border-radius:10px;" @onclick="() => showModal = false">CANCEL</button>
                    <button type="button" class="btn btn-premium fw-800 px-4" style="border-radius:10px;" @onclick="SaveSupplier">
                        <i class="bi bi-check-lg me-1"></i> SAVE SUPPLIER
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Supplier>? suppliers;
    private Supplier editSupplier = new();
    private bool showModal = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadSuppliers();
    }

    private async Task LoadSuppliers()
    {
        suppliers = await ProcurementService.GetAllSuppliersAsync();
    }

    private void OpenCreateModal()
    {
        editSupplier = new Supplier();
        showModal = true;
    }

    private void OpenEditModal(Supplier s)
    {
        editSupplier = new Supplier 
        { 
            Id = s.Id, 
            Name = s.Name, 
            SupplierCode = s.SupplierCode,
            ContactPerson = s.ContactPerson,
            Email = s.Email,
            Phone = s.Phone,
            Address = s.Address,
            Notes = s.Notes
        };
        showModal = true;
    }

    private async Task SaveSupplier()
    {
        if (string.IsNullOrWhiteSpace(editSupplier.Name)) return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.Identity?.Name ?? "system";

        if (editSupplier.Id == 0)
            await ProcurementService.CreateSupplierAsync(editSupplier, userId);
        else
            await ProcurementService.UpdateSupplierAsync(editSupplier, userId);

        showModal = false;
        await LoadSuppliers();
    }
}
