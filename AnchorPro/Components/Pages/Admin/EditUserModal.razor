@using AnchorPro.Data
@using Microsoft.AspNetCore.Identity
@using AnchorPro.Services.Interfaces
@inject UserManager<ApplicationUser> UserManager

@if (IsVisible && User != null)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
                <div class="modal-header border-bottom-0 pt-4 px-4">
                    <h5 class="modal-title fw-800 text-slate-900">Edit Team Member</h5>
                    <button type="button" class="btn-close" @onclick="Close"></button>
                </div>
                <div class="modal-body px-4 pb-4">
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger py-2 small fw-600">@ErrorMessage</div>
                    }

                    <div class="mb-3">
                        <label class="form-label x-small fw-800 text-slate-500 text-uppercase">First Name</label>
                        <input class="form-control border-0 bg-light fw-600" style="height: 48px; border-radius: 10px;" @bind="FirstName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Last Name</label>
                        <input class="form-control border-0 bg-light fw-600" style="height: 48px; border-radius: 10px;" @bind="LastName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Email (Username)</label>
                        <input type="email" class="form-control border-0 bg-light fw-600" style="height: 48px; border-radius: 10px;" @bind="Email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Employee / Man Number</label>
                        <input class="form-control border-0 bg-light fw-600" style="height: 48px; border-radius: 10px;" @bind="EmployeeNumber" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Role</label>
                        <select class="form-select border-0 bg-light fw-600" style="height: 48px; border-radius: 10px;" @bind="Role">
                            <option value="Technician">Technician</option>
                            <option value="Planner">Planner</option>
                            <option value="Supervisor">Supervisor</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-top-0 px-4 pb-4">
                    <button type="button" class="btn btn-light fw-800 px-4" style="border-radius: 10px;" @onclick="Close">CANCEL</button>
                    <button type="button" class="btn btn-primary fw-800 px-4" style="border-radius: 10px;" @onclick="UpdateUser">SAVE CHANGES</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public ApplicationUser? User { get; set; }
    [Parameter] public string InitialRole { get; set; } = "Technician";
    [Parameter] public EventCallback OnUserUpdated { get; set; }

    private string FirstName { get; set; } = "";
    private string LastName { get; set; } = "";
    private string Email { get; set; } = "";
    private string EmployeeNumber { get; set; } = "";
    private string Role { get; set; } = "Technician";
    private string? ErrorMessage;

    protected override void OnParametersSet()
    {
        if (User != null && IsVisible)
        {
            FirstName = User.FirstName ?? "";
            LastName = User.LastName ?? "";
            Email = User.Email ?? "";
            EmployeeNumber = User.EmployeeNumber ?? "";
            Role = !string.IsNullOrEmpty(InitialRole) && InitialRole != "Loading..." ? InitialRole : "Technician";
        }
    }

    private async Task Close()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(false);
        ErrorMessage = null;
    }

    private async Task UpdateUser()
    {
        ErrorMessage = null;
        if (User == null) return;

        User.FirstName = FirstName;
        User.LastName = LastName;
        User.EmployeeNumber = EmployeeNumber;
        User.Email = Email;
        User.UserName = Email;

        var result = await UserManager.UpdateAsync(User);
        if (result.Succeeded)
        {
            // Update Role
            var currentRoles = await UserManager.GetRolesAsync(User);
            if (!currentRoles.Contains(Role))
            {
                await UserManager.RemoveFromRolesAsync(User, currentRoles);
                await UserManager.AddToRoleAsync(User, Role);
            }

            await OnUserUpdated.InvokeAsync();
            await Close();
        }
        else
        {
            ErrorMessage = string.Join(", ", result.Errors.Select(e => e.Description));
        }
    }
}
