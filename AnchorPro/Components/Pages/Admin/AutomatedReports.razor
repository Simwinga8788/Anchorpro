@page "/admin/automated-reports"
@using AnchorPro.Data.Entities
@using AnchorPro.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject IReportingService ReportingService
@inject NavigationManager NavigationManager
@inject IOrgService OrgService
@* No Snackbar service available *@
@* Start Standard UI *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Automated Reporting</PageTitle>

<ApplePageHeader Title="Automated Reporting" Subtitle="ANALYTICS & INSIGHTS">
    <ActionButtons>
        <button class="btn btn-premium" @onclick="CreateNew">
            <i class="bi bi-plus-lg me-2"></i>SCHEDULE REPORT
        </button>
    </ActionButtons>
</ApplePageHeader>

    @if (error != null)
    {
        <div class="alert alert-danger shadow-sm border-0">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @error
        </div>
    }
    else if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-slate-500 fw-800 uppercase x-small">Syncing reporting engine...</p>
        </div>
    }
    else
    {
        <div class="card-premium p-0 overflow-hidden">
            <div class="card-header bg-white py-4 px-4 border-bottom">
                 <h5 class="mb-0 fw-800 text-slate-900 fs-6">Active Schedules</h5>
                 <div class="x-small text-slate-400 fw-800 mt-1">ENGINE STATUS: OPERATIONAL</div>
            </div>
            
            <div class="table-responsive-premium shadow-none border-0 rounded-0">
                <table class="table-premium mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Report Name</th>
                            <th>Type</th>
                            <th>Schedule</th>
                            <th>Recipients</th>
                            <th>Last Run</th>
                            <th>Next Run</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in reports)
                        {
                            <tr>
                                <td class="ps-4 py-3 fw-800 text-slate-900">
                                    @item.Name
                                    @if(item.DepartmentId.HasValue)
                                    {
                                        <div class="x-small text-primary fw-800 uppercase mt-1">@item.Department?.Name</div>
                                    }
                                </td>
                                <td><span class="badge-premium slate">@item.Type.ToString().ToUpper()</span></td>
                                <td class="small fw-600 text-slate-600">@item.CronSchedule</td>
                                <td class="small text-slate-500 fw-600">@item.Recipients</td>
                                <td class="small text-slate-500 fw-600">
                                    @(item.LastRun.HasValue ? item.LastRun.Value.ToLocalTime().ToString("MMM dd, HH:mm") : "NEVER")
                                </td>
                                <td class="small text-primary fw-800">
                                    @(item.NextRun.HasValue ? item.NextRun.Value.ToLocalTime().ToString("MMM dd, HH:mm") : "-")
                                </td>
                                 <td class="text-end pe-4">
                                      <div class="d-flex justify-content-end gap-2">
                                          <button class="btn-action" @onclick="() => Edit(item)" title="Edit">
                                             EDIT
                                         </button>
                                          <button class="btn-action btn-action-primary" @onclick="() => RunNow(item)" title="Run Now">
                                             RUN NOW
                                         </button>
                                         <button class="btn-action btn-action-danger" @onclick="() => Delete(item.Id)" title="Delete">
                                             REMOVE
                                         </button>
                                      </div>
                                 </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Mobile View -->
            <div class="d-md-none p-3">
                @foreach (var item in reports)
                {
                    <div class="card p-3 mb-3 border-0 shadow-sm position-relative overflow-hidden" style="background: white; border-radius: 12px;">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                             <div class="fw-800 text-slate-900">@item.Name</div>
                             <span class="badge-premium slate">@item.Type.ToString().ToUpper()</span>
                        </div>
                        <div class="text-slate-500 x-small fw-800 uppercase mb-2">SCH: @item.CronSchedule</div>
                        <div class="text-slate-400 x-small fw-800 mb-3">REC: @item.Recipients</div>
                        
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <div class="text-slate-400 x-small fw-800 uppercase">LAST RUN</div>
                                <div class="x-small fw-800 text-slate-600">@(item.LastRun.HasValue ? item.LastRun.Value.ToLocalTime().ToString("MM/dd HH:mm") : "-")</div>
                            </div>
                             <div class="col-6">
                                <div class="text-slate-400 x-small fw-800 uppercase">NEXT RUN</div>
                                <div class="x-small fw-800 text-primary">@(item.NextRun.HasValue ? item.NextRun.Value.ToLocalTime().ToString("MM/dd HH:mm") : "-")</div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 pt-3 border-top">
                             <button class="btn btn-premium btn-sm flex-grow-1" @onclick="() => RunNow(item)">RUN NOW</button>
                             <button class="btn btn-premium-ghost btn-sm" @onclick="() => Edit(item)"><i class="bi bi-pencil-fill"></i></button>
                             <button class="btn btn-premium-ghost btn-danger border-0 bg-danger-subtle text-danger btn-sm" @onclick="() => Delete(item.Id)"><i class="bi bi-trash3-fill"></i></button>
                        </div>
                    </div>
                }
            </div>

            @if (!reports.Any() && !isLoading)
            {
                <div class="text-center py-5 text-slate-400">
                    <i class="bi bi-calendar-x display-4 mb-3 opacity-25"></i>
                    <p class="fw-800 uppercase x-small">No automated reports scheduled</p>
                </div>
            }
        </div>
    }


@if (showModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingReport.Id == 0 ? "New Schedule" : "Edit Schedule")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Report Name</label>
                        <input type="text" class="form-control" @bind="editingReport.Name" placeholder="e.g. Monthly Executive Summary" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Department (Optional)</label>
                        <select class="form-select" @bind="editingReport.DepartmentId">
                            <option value="">Full Organization</option>
                            @foreach (var d in departments)
                            {
                                <option value="@d.Id">@d.Name</option>
                            }
                        </select>
                        <div class="form-text text-primary fw-800 x-small uppercase mt-1">Leave empty for cross-departmental scope</div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Report Type</label>
                        <select class="form-select" @bind="editingReport.Type">
                            @foreach (var type in Enum.GetValues<ReportType>())
                            {
                                <option value="@type">@type</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                         <label class="form-label">Frequency</label>
                         <select class="form-select" @bind="editingReport.CronSchedule">
                             <option value="Daily">Daily (Every 24h)</option>
                             <option value="Weekly">Weekly (Every 7 days)</option>
                             <option value="Monthly">Monthly (Every 30 days)</option>
                         </select>
                         <div class="form-text">Reports are emailed automatically based on this schedule.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Recipients (Comma Separated)</label>
                        <input type="text" class="form-control" @bind="editingReport.Recipients" placeholder="manager@example.com, finance@example.com" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-premium-ghost" @onclick="CloseModal">Cancel</button>
                    <button type="button" class="btn btn-premium" @onclick="Save">Save Schedule</button>
                </div>
            </div>
        </div>
    </div>
}

    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1100">
        @if (!string.IsNullOrEmpty(toastMessage))
        {
            <div class="toast show align-items-center text-white bg-primary border-0" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        @toastMessage
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => toastMessage = null" aria-label="Close"></button>
                </div>
            </div>
        }
    </div>

@code {
    private bool isLoading = true;
    private List<ReportDefinition> reports = new();
    private bool showModal = false;
    private ReportDefinition editingReport = new();
    
    private string? toastMessage;
    private string toastClass = "alert-success";
    private List<Department> departments = new();

    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            departments = await OrgService.GetAllDepartmentsAsync();
            await LoadReports();
        }
        catch(Exception ex) 
        {
            error = ex.Message;
            Console.WriteLine($"Error loading reports: {ex}");
        }
    }

    private async Task LoadReports()
    {
        isLoading = true;
        reports = await ReportingService.GetScheduledReportsAsync();
        isLoading = false;
    }

    private void CreateNew()
    {
        editingReport = new ReportDefinition { CronSchedule = "Monthly", Type = ReportType.MonthlyMaintenanceSummary };
        showModal = true;
    }

    private void Edit(ReportDefinition report)
    {
        editingReport = new ReportDefinition
        {
            Id = report.Id,
            Name = report.Name,
            Type = report.Type,
            CronSchedule = report.CronSchedule,
            Recipients = report.Recipients,
            TenantId = report.TenantId,
            DepartmentId = report.DepartmentId,
            NextRun = report.NextRun
        };
        showModal = true;
    }

    private async Task Save()
    {
        await ReportingService.SaveReportDefinitionAsync(editingReport);
        showModal = false;
        await LoadReports();
    }

    private async Task Delete(int id)
    {
        if (await DisplayConfirm("Are you sure you want to delete this schedule?"))
        {
            await ReportingService.DeleteReportDefinitionAsync(id);
            await LoadReports();
        }
    }

    private void CloseModal() => showModal = false;

    // Mock JS confirm since we don't have JS interop service injected
    private async Task RunNow(ReportDefinition report)
    {
        if (await DisplayConfirm($"Run '{report.Name}' immediately?"))
        {
            isLoading = true;
            try 
            {
                await ReportingService.RunReportAsync(report.Id);
                toastMessage = $"Report '{report.Name}' sent successfully!";
                toastClass = "alert-success";
            }
            catch (Exception ex)
            {
                toastMessage = $"Failed to send report: {ex.Message}";
                toastClass = "alert-danger";
            }
            finally
            {
                isLoading = false;
                await Task.Delay(5000); // Wait 5s
                toastMessage = null; 
                await InvokeAsync(StateHasChanged);
            }
        }
    }

     // Mock JS confirm since we don't have JS interop service injected
    private async Task<bool> DisplayConfirm(string msg) 
    {
        return true; // For now, auto confirm or implement JS
    }
}
