@page "/planning"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using AnchorPro.Data
@using AnchorPro.Data.Entities
@using AnchorPro.Data.Enums
@using AnchorPro.Services.Interfaces
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Authorization
@inject IJobCardService JobCardService
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager
@attribute [Authorize(Roles = "Admin,Planner,Supervisor")]

<PageTitle>Planning Board</PageTitle>

<ApplePageHeader Title="Planning & Scheduling" Subtitle="OPERATIONAL ORCHESTRATION">
    <ActionButtons>
        <AuthorizeView Roles="Admin">
            <button class="btn btn-premium-ghost">
                <i class="bi bi-gear-fill me-2"></i>BOARD CONFIGURATION
            </button>
        </AuthorizeView>
    </ActionButtons>
</ApplePageHeader>

    <div class="row g-4 align-items-start">
        <!-- COLUMN 1: To-Do / Backlog -->
        <div class="col-lg-4">
            <div class="d-flex justify-content-between align-items-end mb-3 px-1">
                <h6 class="metric-label-premium">Backlog Protocol (@unscheduledJobs.Count)</h6>
                <div class="x-small fw-800 text-slate-400">UNSCHEDULED</div>
            </div>
            
            <div class="vstack gap-3">
                @foreach(var job in unscheduledJobs)
                {
                    <div class="card p-3 mb-0 border-0 shadow-sm position-relative overflow-hidden" 
                         style="cursor: pointer; transition: transform 0.2s; border-radius: 12px; background: white;"
                         @onclick="() => SelectJob(job)">
                        <div class="position-absolute top-0 bottom-0 start-0" 
                               style="width: 4px; background-color: @GetPriorityColor(job.Priority);"></div>
                        
                        <div class="ps-2">
                            <div class="fw-800 text-slate-900 mb-1">@job.JobType?.Name</div>
                            <div class="text-slate-500 x-small fw-800 mb-3">ASSET: @job.Equipment?.Name</div>
                            
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge-premium slate">READY FOR DISPATCH</span>
                                <span class="x-small fw-800" style="color: @GetPriorityColor(job.Priority)">@job.Priority.ToString().ToUpper()</span>
                            </div>
                        </div>
                    </div>
                }
                @if(!unscheduledJobs.Any()) { 
                    <div class="text-center py-5 border border-dashed rounded-4 bg-white opacity-50">
                        <i class="bi bi-check2-circle display-6 text-slate-300"></i>
                        <div class="text-slate-400 x-small fw-800 uppercase mt-2">Backlog Clear</div>
                    </div> 
                }
            </div>
        </div>

        <!-- COLUMN 2: Scheduled / In Progress -->
        <div class="col-lg-4">
            <div class="d-flex justify-content-between align-items-end mb-3 px-1">
                <h6 class="metric-label-premium">Active Operations (@scheduledJobs.Count)</h6>
                <div class="x-small fw-800 text-primary">LIVE STATUS</div>
            </div>
            
            <div class="vstack gap-3">
                @foreach(var job in scheduledJobs)
                {
                    <div class="card p-3 mb-0 border-0 shadow-sm position-relative overflow-hidden" @onclick='() => NavigationManager.NavigateTo($"/job-cards/{job.Id}")' style="cursor: pointer; border-radius: 12px; background: white;">
                        <div class="position-absolute top-0 bottom-0 start-0" 
                             style="width: 4px; background-color: var(--ap-primary);"></div>
                        
                        <div class="ps-2">
                            <div class="fw-800 text-slate-900 mb-1">@job.JobType?.Name</div>
                            <div class="text-slate-500 x-small fw-800 mb-3">
                                @(job.AssignedTechnician?.FirstName?.ToUpper() ?? "ASSIGNED TECH")
                                @if(!string.IsNullOrEmpty(job.AssignedTechnician?.EmployeeNumber)) { <span class="ms-1 opacity-50">#@job.AssignedTechnician.EmployeeNumber</span> }
                            </div>
                            
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-slate-400 x-small text-uppercase fw-800">
                                    <i class="bi bi-clock-history me-1"></i>
                                    @job.ScheduledStartDate?.ToString("MMM dd, HH:mm")
                                </span>
                                <span class="badge-premium @(job.Status == JobStatus.InProgress ? "warning" : "info")">@job.Status.ToString().ToUpper()</span>
                            </div>
                        </div>
                    </div>
                }
                @if(!scheduledJobs.Any()) { 
                    <div class="text-center py-5 border border-dashed rounded-4 bg-white opacity-50">
                        <i class="bi bi-activity display-6 text-slate-300"></i>
                        <div class="text-slate-400 x-small fw-800 uppercase mt-2">No active jobs scheduled</div>
                    </div> 
                }
            </div>
        </div>

        <!-- COLUMN 3: Technician Workload -->
        <div class="col-lg-4">
            <h6 class="metric-label-premium mb-3 px-1">Resource Allocation</h6>
            
            <div class="card-premium p-4">
                @foreach(var tech in technicians)
                {
                    var load = GetTechnicianLoad(tech.Id);
                    var isOverloaded = load > 80;
                    
                    <div class="mb-4 last-child-mb-0">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="fw-800 text-slate-900 small">@tech.FirstName?.ToUpper() @tech.LastName?.ToUpper() <span class="text-slate-300 ms-1">#@tech.EmployeeNumber</span></span>
                            <span class="text-slate-400 x-small fw-800">@load% UTILIZATION</span>
                        </div>
                        
                        <div class="progress" style="height: 6px; background-color: var(--ap-slate-100); border-radius: 10px; overflow: hidden;">
                            <div class="progress-bar" 
                                 style="width: @load%; background-color: @(isOverloaded ? "var(--ap-danger)" : "var(--ap-primary)")">
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>


<style>
    .x-small { font-size: 0.70rem; letter-spacing: 0.05em; }
</style>

@code {
    private List<JobCard> unscheduledJobs = new();
    private List<JobCard> scheduledJobs = new();
    private List<ApplicationUser> technicians = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var allJobs = await JobCardService.GetAllJobCardsAsync();
        unscheduledJobs = allJobs.Where(j => j.Status == JobStatus.Unscheduled).ToList();
        scheduledJobs = allJobs.Where(j => j.Status == JobStatus.Scheduled || j.Status == JobStatus.InProgress).ToList();

        // Enforce fresh query and filter out Platform Owner
        var allUsers = UserManager.Users
            .Where(u => u.Email != "simwinga8788@gmail.com" && u.FirstName != "Platform Owner")
            .ToList();
            
        technicians = new List<ApplicationUser>();
        foreach (var user in allUsers)
        {
            if (await UserManager.IsInRoleAsync(user, "Technician"))
                technicians.Add(user);
        }
    }

    private bool showModal = false;
    private JobCard? selectedJob;
    private DateTime plannedStart = DateTime.Now.Date.AddHours(8); // Default to 8 AM today
    private int plannedDurationHours = 4; // Default 4 hours duration

    private async Task SelectJob(JobCard job)
    {
        selectedJob = await JobCardService.GetJobCardByIdAsync(job.Id);
        plannedStart = DateTime.Now.Date.AddDays(1).AddHours(8); // Default next day 8 AM
        
        // Calculate duration based on tasks
        if(selectedJob?.JobTasks?.Any() == true)
        {
            var totalMinutes = selectedJob.JobTasks.Sum(t => t.EstimatedDurationMinutes);
            plannedDurationHours = (int)Math.Ceiling(totalMinutes / 60.0);
            if(plannedDurationHours < 1) plannedDurationHours = 1;
        }

        showModal = true;
        assignmentError = null;
    }

    private void CloseModal()
    {
        showModal = false;
        selectedJob = null;
    }

    private async Task AssignToTech(ApplicationUser tech)
    {
        if(selectedJob != null)
        {
             var start = plannedStart;
             var end = plannedStart.AddHours(plannedDurationHours);

            // PROMPT: Check for conflicts first
            var conflict = await JobCardService.CheckScheduleConflictsAsync(selectedJob.Id, tech.Id, start, end); 

            if (conflict.IsConflicted)
            {
                // Simple JS alert alternative or UI state logic
                // For now, we'll just set a UI message.
                assignmentError = conflict.Message;
                return;
            }

            try
            {
                await JobCardService.AssignTechnicianAsync(selectedJob.Id, tech.Id, start, end);
                // Status is automatically updated to Scheduled inside AssignTechnicianAsync
                await LoadData();
                CloseModal();
            }
            catch (Exception ex)
            {
                assignmentError = $"Unable to assign: {ex.Message}";
                Console.WriteLine($"Assignment Error: {ex}");
            }
        }
    }

    private string? assignmentError;

    private int GetTechnicianLoad(string techId)
    {
        int count = scheduledJobs.Count(j => j.AssignedTechnicianId == techId);
        return Math.Min(100, count * 20); // 5 jobs = 100%
    }
    
    private string GetPriorityColor(JobPriority p) => p switch {
        JobPriority.Critical => "var(--ap-danger)",
        JobPriority.High => "var(--ap-warning)",
        _ => "var(--ap-primary)"
    };
}

@if (showModal && selectedJob != null)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg" style="max-height: 90vh; overflow-y: auto;">
                <div class="modal-header bg-light">
                    <div>
                        <div class="d-flex align-items-center gap-2">
                            <h5 class="modal-title fw-bold mb-0">#@selectedJob.JobNumber</h5>
                            <span class="badge" style="background-color: @GetPriorityColor(selectedJob.Priority)">@selectedJob.Priority</span>
                        </div>
                        <div class="text-secondary small mt-1">@selectedJob.JobType?.Name &bull; @selectedJob.Equipment?.Name</div>
                    </div>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body p-4">
                    @if (!string.IsNullOrEmpty(assignmentError))
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-4">
                            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                            <div>
                                <strong>Scheduling Conflict Detected</strong>
                                <div class="small">@assignmentError</div>
                            </div>
                            <button type="button" class="btn-close ms-auto" @onclick="() => assignmentError = null"></button>
                        </div>
                    }

                    <div class="row">
                        <!-- Job Details Column -->
                        <div class="col-lg-7 border-end">
                            <h6 class="fw-bold text-secondary text-uppercase x-small mb-3">Job Details</h6>
                            <p class="mb-4 text-dark">@selectedJob.Description</p>
                            
                            <h6 class="fw-bold text-secondary text-uppercase x-small mb-3">Tasks Required</h6>
                            @if(selectedJob.JobTasks != null && selectedJob.JobTasks.Any())
                            {
                                <div class="vstack gap-2">
                                    @foreach(var task in selectedJob.JobTasks.OrderBy(t => t.Sequence))
                                    {
                                        <div class="p-3 bg-light rounded-3 border-start border-4 border-secondary">
                                            <div class="fw-bold text-dark">@task.Name</div>
                                            @if(!string.IsNullOrEmpty(task.Instructions))
                                            {
                                                <div class="small text-muted mt-1">@task.Instructions</div>
                                            }
                                            <div class="d-flex align-items-center mt-2 x-small text-secondary">
                                                <i class="bi bi-clock me-1"></i> @task.EstimatedDurationMinutes min
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-secondary small">No specific tasks defined.</div>
                            }
                        </div>

                            <!-- Assignment Column -->
                        <div class="col-lg-5 ps-lg-4">
                            <h6 class="fw-bold text-secondary text-uppercase x-small mb-3 mt-4 mt-lg-0">Schedule Job</h6>
                            
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Start Date & Time</label>
                                <input type="datetime-local" class="form-control" @bind="plannedStart" />
                            </div>
                            
                            <div class="mb-4">
                                <label class="form-label small fw-bold">Expected Duration</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" @bind="plannedDurationHours" min="1" />
                                    <span class="input-group-text">Hours</span>
                                </div>
                            </div>

                            <h6 class="fw-bold text-secondary text-uppercase x-small mb-3">Assign Technician</h6>
                            <p class="small text-muted mb-3">Select a team member to assign this job to.</p>
                            
                            <div class="vstack gap-2">
                                @foreach(var tech in technicians)
                                {
                                    var load = GetTechnicianLoad(tech.Id);
                                    var isLowLoad = load < 50;
                                    
                                    <button class="btn btn-outline-light text-dark text-start border p-3 shadow-sm d-flex align-items-center w-100 tech-assign-btn"
                                            @onclick="() => AssignToTech(tech)">
                                        <div class="bg-white rounded-circle p-2 me-3 shadow-sm text-primary">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="fw-700 text-slate-900">@tech.FirstName @tech.LastName</div>
                                            <div class="x-small text-slate-400 fw-800 text-uppercase mb-1">MAN #: @(tech.EmployeeNumber ?? "N/A")</div>
                                            <div class="d-flex align-items-center mt-1">
                                                <div class="progress flex-grow-1" style="height: 4px; background-color: #eee;">
                                                    <div class="progress-bar" style="width: @load%; background-color: @(isLowLoad ? "#10B981" : "#F59E0B")"></div>
                                                </div>
                                                <span class="x-small ms-2 text-muted">@load%</span>
                                            </div>
                                        </div>
                                        <i class="bi bi-chevron-right text-muted ms-2"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .tech-assign-btn { transition: all 0.2s; }
    .tech-assign-btn:hover { border-color: var(--color-accent-primary) !important; background-color: #f8ffff; }
</style>
