@page "/billing/invoices"
@using AnchorPro.Data.Entities
@using AnchorPro.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Finance")]
@inject IFinancialService FinanceService
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Financial Ledger | Anchor Pro</PageTitle>

<ApplePageHeader Title="Financial Ledger" Subtitle="Track invoices, payments and collection performance">
    <ActionButtons>
        <button class="btn btn-premium-ghost btn-sm me-2" @onclick="LoadInvoices">
            <i class="bi bi-arrow-clockwise me-1"></i> REFRESH
        </button>
        <button class="btn btn-premium btn-sm" @onclick="ExportLedger">
            <i class="bi bi-download me-1"></i> EXPORT CSV
        </button>
    </ActionButtons>
</ApplePageHeader>

@if (snapshot != null)
{
    <div class="row g-3 mt-2 mb-4">
        <div class="col-6 col-md-3">
            <div class="card-premium py-3" style="border-left: 3px solid #10b981;">
                <div class="metric-label-premium">REVENUE (MTD)</div>
                <div class="h3 fw-800 text-success mb-0">ZMW @snapshot.TotalRevenueMTD.ToString("N0")</div>
                <div class="x-small text-slate-400 fw-800 mt-1">INVOICED TOTAL</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card-premium py-3" style="border-left: 3px solid #2563eb;">
                <div class="metric-label-premium">COLLECTED (MTD)</div>
                <div class="h3 fw-800 text-primary mb-0">ZMW @snapshot.TotalCollectedMTD.ToString("N0")</div>
                <div class="x-small text-slate-400 fw-800 mt-1">REAL CASH FLOW</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card-premium py-3" style="border-left: 3px solid #f59e0b;">
                <div class="metric-label-premium">OUTSTANDING</div>
                <div class="h3 fw-800 text-warning mb-0">ZMW @snapshot.TotalOutstanding.ToString("N0")</div>
                <div class="x-small text-danger fw-800 mt-1">@snapshot.UnpaidInvoiceCount OPEN INVOICES</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card-premium py-3" style="border-left: 3px solid #6d28d9;">
                <div class="metric-label-premium">OVERDUE</div>
                <div class="h3 fw-800 text-slate-800 mb-0">ZMW @snapshot.OverdueAmount.ToString("N0")</div>
                <div class="x-small text-danger fw-800 mt-1">CRITICAL AR</div>
            </div>
        </div>
    </div>
}

<div class="card-premium p-0 overflow-hidden">
    <div class="px-4 py-3 border-bottom d-flex justify-content-between align-items-center bg-slate-50">
        <h6 class="fw-800 text-slate-900 mb-0">INVOICE REGISTRY</h6>
        <div class="d-flex gap-2">
             <input type="text" class="form-control form-control-sm border-0 bg-white" style="width:200px;" placeholder="Search invoices..." @bind="searchTerm" @bind:event="oninput" />
             <select class="form-select form-select-sm border-0 bg-white" style="width:150px;" @bind="statusFilter">
                 <option value="">All Statuses</option>
                 <option value="Paid">Paid</option>
                 <option value="Partial">Partial</option>
                 <option value="Unpaid">Unpaid</option>
                 <option value="Overdue">Overdue</option>
             </select>
        </div>
    </div>
    
    <div class="table-responsive">
        <table class="table-premium">
            <thead>
                <tr>
                    <th class="ps-4">INVOICE #</th>
                    <th>DATE</th>
                    <th>CUSTOMER</th>
                    <th class="text-end">SUBTOTAL</th>
                    <th class="text-end">TAX (16%)</th>
                    <th class="text-end">TOTAL</th>
                    <th class="text-end">PAID</th>
                    <th class="text-end">BALANCE</th>
                    <th class="text-center">STATUS</th>
                    <th class="text-end pe-4">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @if (invoices == null)
                {
                    <tr><td colspan="10" class="py-5 text-center"><div class="spinner-border spinner-border-sm text-primary"></div></td></tr>
                }
                else if (!FilteredInvoices.Any())
                {
                    <tr><td colspan="10" class="py-5 text-center text-slate-400 fw-600">No invoices found matching current filters.</td></tr>
                }
                else
                {
                    @foreach (var inv in FilteredInvoices)
                    {
                        <tr>
                            <td class="ps-4 fw-800 text-primary">@inv.InvoiceNumber</td>
                            <td class="small text-slate-600">@inv.InvoiceDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td class="small fw-700">@(inv.Customer?.Name ?? "N/A")</td>
                            <td class="text-end small">@inv.Subtotal.ToString("N2")</td>
                            <td class="text-end small">@inv.TaxAmount.ToString("N2")</td>
                            <td class="text-end fw-800">@inv.Total.ToString("N2")</td>
                            <td class="text-end text-success small fw-700">@inv.AmountPaid.ToString("N2")</td>
                            <td class="text-end text-danger fw-800">@inv.Balance.ToString("N2")</td>
                            <td class="text-center">
                                <span class="badge-premium @GetStatusClass(inv)">@inv.PaymentStatus.ToString().ToUpper()</span>
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn-action me-1" title="Record Payment" @onclick="() => OpenPaymentModal(inv)">
                                    <i class="bi bi-wallet2"></i>
                                </button>
                                <button class="btn-action" title="View Details" @onclick="() => OpenInvoiceDetail(inv)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@* Record Payment Modal *@
@if (selectedInvoice != null && showPaymentModal)
{
    <div class="modal fade show d-block" style="background-color:rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius:16px;">
                <div class="modal-header py-4 px-4 border-0">
                    <div>
                        <h5 class="modal-title fw-800 text-slate-900">Record Payment</h5>
                        <div class="x-small fw-800 text-slate-400 mt-1">INV: @selectedInvoice.InvoiceNumber | BAL: ZMW @selectedInvoice.Balance.ToString("N2")</div>
                    </div>
                    <button type="button" class="btn-close" @onclick="() => showPaymentModal = false"></button>
                </div>
                <div class="modal-body px-4 pb-4">
                    <div class="mb-3">
                        <label class="form-label x-small fw-800 text-slate-400 text-uppercase">Payment Amount (ZMW)</label>
                        <input type="number" @bind="paymentAmount" class="form-control form-control-premium" />
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label x-small fw-800 text-slate-400 text-uppercase">Method</label>
                            <select @bind="paymentMethod" class="form-select form-control-premium">
                                @foreach (var method in Enum.GetValues<PaymentMethod>())
                                {
                                    <option value="@method">@method</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label x-small fw-800 text-slate-400 text-uppercase">Reference #</label>
                            <input type="text" @bind="paymentRef" class="form-control form-control-premium" placeholder="Ref/CHQ#" />
                        </div>
                    </div>
                    <div class="mt-3">
                        <label class="form-label x-small fw-800 text-slate-400 text-uppercase">Notes</label>
                        <input type="text" @bind="paymentNotes" class="form-control form-control-premium" />
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-light fw-800 px-4" style="border-radius:10px;" @onclick="() => showPaymentModal = false">CANCEL</button>
                    <button type="button" class="btn btn-premium fw-800 px-4" style="border-radius:10px;" @onclick="ProcessPayment">
                        <i class="bi bi-check-circle me-1"></i> RECORD PAYMENT
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Invoice Detail View Modal *@
@if (selectedInvoice != null && !showPaymentModal)
{
    @* Existing Detail modal logic but updated for Invoice entity *@
    <div class="modal fade show d-block" style="background-color:rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius:16px;">
                <div class="modal-header py-4 px-4 border-0 bg-slate-50">
                    <div>
                        <div class="x-small fw-800 text-primary text-uppercase mb-1">INVOICE PREVIEW</div>
                        <h4 class="modal-title fw-800 text-slate-900 mb-0">@selectedInvoice.InvoiceNumber</h4>
                    </div>
                    <div class="ms-auto">
                        <span class="badge-premium @GetStatusClass(selectedInvoice) px-3 py-2">@selectedInvoice.PaymentStatus.ToString().ToUpper()</span>
                        <button type="button" class="btn-close ms-3" @onclick="() => selectedInvoice = null"></button>
                    </div>
                </div>
                <div class="modal-body px-4 py-4">
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <div class="x-small fw-800 text-slate-400 text-uppercase mb-2">BILLED TO</div>
                            @if (selectedInvoice.Customer != null)
                            {
                                <div class="fw-800 text-slate-900">@selectedInvoice.Customer.Name</div>
                                <div class="small text-slate-500">@selectedInvoice.Customer.Address</div>
                                <div class="small text-slate-500">@selectedInvoice.Customer.Phone</div>
                            }
                        </div>
                        <div class="col-md-6 text-md-end">
                            <div class="x-small fw-800 text-slate-400 text-uppercase mb-2">INVOICE DETAILS</div>
                            <div class="small"><strong>Date:</strong> @selectedInvoice.InvoiceDate.ToLocalTime().ToString("dd MMM yyyy")</div>
                            <div class="small text-danger"><strong>Due Date:</strong> @(selectedInvoice.DueDate?.ToLocalTime().ToString("dd MMM yyyy") ?? "Immediate")</div>
                            @if (selectedInvoice.JobCard != null)
                            {
                                <div class="small"><strong>Linked Job:</strong> @selectedInvoice.JobCard.JobNumber</div>
                            }
                        </div>
                    </div>

                    <div class="rounded-3 overflow-hidden mb-4" style="border:1px solid #e5e7eb;">
                        <table class="table table-sm mb-0">
                            <thead class="bg-slate-50">
                                <tr>
                                    <th class="ps-3 py-2 x-small fw-800 text-slate-500">DESCRIPTION</th>
                                    <th class="pe-3 py-2 x-small fw-800 text-slate-500 text-end">AMOUNT (ZMW)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="ps-3 py-2 small fw-700">Operational Charges / Maintenance Services</td>
                                    <td class="pe-3 py-2 small fw-700 text-end">@selectedInvoice.Subtotal.ToString("N2")</td>
                                </tr>
                                <tr>
                                    <td class="ps-3 py-2 x-small text-slate-500">Value Added Tax (16%)</td>
                                    <td class="pe-3 py-2 x-small text-slate-500 text-end">@selectedInvoice.TaxAmount.ToString("N2")</td>
                                </tr>
                                <tr class="bg-slate-50">
                                    <td class="ps-3 py-3 fw-800 text-slate-900">GRAND TOTAL</td>
                                    <td class="pe-3 py-3 fw-800 text-slate-900 text-end h5 mb-0">@selectedInvoice.Total.ToString("N2")</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    @* Payment Ledger Section *@
                    <h6 class="fw-800 text-slate-900 mb-3 fs-6">PAYMENT LEDGER</h6>
                    @if (selectedInvoice.Payments != null && selectedInvoice.Payments.Any())
                    {
                        <div class="row g-2">
                            @foreach (var p in selectedInvoice.Payments)
                            {
                                <div class="col-12 p-3 rounded-3 border bg-light d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="small fw-800 text-slate-900">@p.Method.ToString().ToUpper() Payment - @p.ReferenceNumber</div>
                                        <div class="x-small text-slate-500">Recorded on @p.PaymentDate.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
                                    </div>
                                    <div class="text-end">
                                        <div class="fw-800 text-success">- ZMW @p.Amount.ToString("N2")</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="p-4 text-center border rounded-3 text-slate-400 x-small fw-800">NO PAYMENTS RECORDED YET</div>
                    }
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button class="btn btn-light fw-800 px-4" style="border-radius:10px;" @onclick="() => selectedInvoice = null">CLOSE</button>
                    @if (selectedInvoice.Balance > 0)
                    {
                        <button class="btn btn-premium fw-800 px-4" style="border-radius:10px;" @onclick="() => OpenPaymentModal(selectedInvoice)">
                            <i class="bi bi-wallet2 me-1"></i> RECORD PAYMENT
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Invoice>? invoices;
    private FinancialSnapshot? snapshot;
    private string searchTerm = "";
    private string statusFilter = "";

    // Payment Form
    private Invoice? selectedInvoice;
    private bool showPaymentModal = false;
    private decimal paymentAmount;
    private PaymentMethod paymentMethod;
    private string paymentRef = "";
    private string paymentNotes = "";

    private List<Invoice> FilteredInvoices => invoices?
        .Where(i => string.IsNullOrEmpty(searchTerm) || i.InvoiceNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || (i.Customer?.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(i => string.IsNullOrEmpty(statusFilter) || i.PaymentStatus.ToString() == statusFilter)
        .ToList() ?? new();

    protected override async Task OnInitializedAsync()
    {
        await LoadInvoices();
    }

    private async Task LoadInvoices()
    {
        invoices = await FinanceService.GetAllInvoicesAsync();
        snapshot = await FinanceService.GetFinancialSnapshotAsync();
    }

    private void OpenInvoiceDetail(Invoice inv)
    {
        selectedInvoice = inv;
        showPaymentModal = false;
    }

    private async Task OpenPaymentModal(int invId) {
         var inv = await FinanceService.GetInvoiceByIdAsync(invId);
         if (inv != null) OpenPaymentModal(inv);
    }

    private void OpenPaymentModal(Invoice inv)
    {
        selectedInvoice = inv;
        paymentAmount = inv.Balance;
        paymentMethod = PaymentMethod.BankTransfer;
        paymentRef = "";
        paymentNotes = "";
        showPaymentModal = true;
    }

    private async Task ProcessPayment()
    {
        if (selectedInvoice == null || paymentAmount <= 0) return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.Identity?.Name ?? "system";

        var payment = new InvoicePayment
        {
            InvoiceId = selectedInvoice.Id,
            Amount = paymentAmount,
            Method = paymentMethod,
            ReferenceNumber = paymentRef,
            Notes = paymentNotes,
            PaymentDate = DateTime.UtcNow
        };

        await FinanceService.RecordPaymentAsync(payment, userId);
        showPaymentModal = false;
        selectedInvoice = null;
        await LoadInvoices();
    }

    private string GetStatusClass(Invoice inv) => inv.PaymentStatus switch {
        InvoicePaymentStatus.Paid => "success",
        InvoicePaymentStatus.Partial => "primary",
        InvoicePaymentStatus.Overdue => "danger",
        _ => "warning"
    };

    private async Task ExportLedger()
    {
        // Simple CSV Export logic
    }
}
