@page "/crm"
@using AnchorPro.Data.Entities
@using AnchorPro.Data.Enums
@using AnchorPro.Services.Interfaces
@inject ICustomerService CustomerService
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Customers & CRM | Anchor Pro</PageTitle>

<ApplePageHeader Title="Customers & CRM" Subtitle="Client registry, service history & relationship management">
    <ActionButtons>
        <input type="text" class="form-control form-control-sm border-0 bg-light fw-600 me-2"
               style="width: 220px; border-radius: 8px;" placeholder="🔍  Search clients..."
               @bind="searchTerm" @bind:event="oninput" />
        <button class="btn btn-primary btn-sm" @onclick="() => OpenEditor()">
            <i class="bi bi-person-plus me-1"></i> Add Customer
        </button>
    </ActionButtons>
</ApplePageHeader>

@* Summary Bar *@
@if (customers != null)
{
    <div class="row g-3 mt-2 mb-4">
        <div class="col-6 col-md-3">
            <div class="card-premium text-center py-3">
                <div class="metric-label-premium">TOTAL CLIENTS</div>
                <div class="h3 fw-800 text-slate-900 mb-0">@customers.Count</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card-premium text-center py-3">
                <div class="metric-label-premium">ACTIVE JOBS</div>
                <div class="h3 fw-800 text-primary mb-0">@customers.Sum(c => c.JobCards.Count(j => j.Status != JobStatus.Completed && j.Status != JobStatus.Cancelled))</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card-premium text-center py-3">
                <div class="metric-label-premium">TOTAL JOBS</div>
                <div class="h3 fw-800 text-slate-900 mb-0">@customers.Sum(c => c.JobCards.Count)</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card-premium text-center py-3">
                <div class="metric-label-premium">TOTAL REVENUE</div>
                <div class="h3 fw-800 text-success mb-0">ZMW @customers.Sum(c => c.JobCards.Where(j => j.Status == JobStatus.Completed).Sum(j => j.InvoiceAmount)).ToString("N0")</div>
            </div>
        </div>
    </div>
}

<div class="row g-4">
    @* Customer List *@
    <div class="@(selectedCustomer != null ? "col-lg-7" : "col-12")">
        <div class="card-premium p-0 overflow-hidden">
            <div class="px-4 py-3 border-bottom d-flex justify-content-between align-items-center" style="background: #fafafa;">
                <h6 class="fw-800 text-slate-900 mb-0">CLIENT REGISTRY</h6>
                <span class="x-small fw-800 text-slate-400">@(FilteredCustomers?.Count ?? 0) RECORDS</span>
            </div>
            <div class="table-responsive">
                <table class="table-premium">
                    <thead>
                        <tr>
                            <th class="ps-4">CLIENT</th>
                            <th>CONTACT PERSON</th>
                            <th>PHONE</th>
                            <th>JOBS</th>
                            <th>REVENUE</th>
                            <th class="text-end pe-4">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (customers == null)
                        {
                            <tr><td colspan="6" class="py-5 text-center">
                                <div class="spinner-border text-primary spinner-border-sm"></div>
                                <span class="ms-2 x-small fw-800 text-slate-400">LOADING CLIENT REGISTRY...</span>
                            </td></tr>
                        }
                        else if (!FilteredCustomers!.Any())
                        {
                            <tr><td colspan="6" class="py-5 text-center">
                                <i class="bi bi-person-badge fs-2 opacity-25 d-block mb-2"></i>
                                <span class="small fw-600 text-slate-400">No clients match your search.</span>
                            </td></tr>
                        }
                        else
                        {
                            @foreach (var customer in FilteredCustomers!)
                            {
                                var rev = customer.JobCards.Where(j => j.Status == JobStatus.Completed).Sum(j => j.InvoiceAmount);
                                var isSelected = selectedCustomer?.Id == customer.Id;
                                <tr class="@(isSelected ? "table-active" : "")" style="cursor:pointer;" @onclick="() => SelectCustomer(customer)">
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center fw-800 text-white x-small"
                                                 style="width:32px;height:32px;background:linear-gradient(135deg,#2563eb,#7c3aed);flex-shrink:0;">
                                                @customer.Name.Substring(0, 1).ToUpper()
                                            </div>
                                            <div>
                                                <div class="fw-800 text-slate-900 small">@customer.Name</div>
                                                <div class="x-small text-slate-400">@customer.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="small text-slate-600">@(customer.ContactPerson ?? "—")</td>
                                    <td class="small text-slate-500">@(customer.Phone ?? "—")</td>
                                    <td>
                                        <span class="badge bg-primary-subtle text-primary fw-800 x-small">@customer.JobCards.Count JOBS</span>
                                    </td>
                                    <td class="fw-800 small text-slate-900">ZMW @rev.ToString("N0")</td>
                                    <td class="text-end pe-3" @onclick:stopPropagation="true">
                                        <button class="btn-action me-1" @onclick="() => OpenEditor(customer)">EDIT</button>
                                        <button class="btn-action btn-action-danger" @onclick="() => DeleteCustomer(customer)">REMOVE</button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* Customer Detail Panel *@
    @if (selectedCustomer != null && detailCustomer != null)
    {
        <div class="col-lg-5">
            <div class="card-premium p-0 overflow-hidden h-100">
                <div class="px-4 py-3 border-bottom d-flex justify-content-between align-items-center" style="background:linear-gradient(135deg,#f8faff,#eef2ff);">
                    <div>
                        <h6 class="fw-800 text-slate-900 mb-0">@detailCustomer.Name</h6>
                        <div class="x-small text-slate-400 fw-600">CLIENT PROFILE</div>
                    </div>
                    <button class="btn-close btn-close-sm" @onclick="() => selectedCustomer = null"></button>
                </div>

                @* Stats row *@
                <div class="row g-0 border-bottom">
                    <div class="col-4 text-center py-3 border-end">
                        <div class="h4 fw-800 text-slate-900 mb-0">@detailStats?.TotalJobs</div>
                        <div class="x-small fw-800 text-slate-400">TOTAL JOBS</div>
                    </div>
                    <div class="col-4 text-center py-3 border-end">
                        <div class="h4 fw-800 text-primary mb-0">@detailStats?.OpenJobs</div>
                        <div class="x-small fw-800 text-slate-400">OPEN</div>
                    </div>
                    <div class="col-4 text-center py-3">
                        <div class="h4 fw-800 text-success mb-0">ZMW @detailStats?.TotalRevenue.ToString("N0")</div>
                        <div class="x-small fw-800 text-slate-400">REVENUE</div>
                    </div>
                </div>

                @* Contact Info *@
                <div class="p-4 border-bottom">
                    <div class="x-small fw-800 text-slate-400 text-uppercase mb-3">CONTACT DETAILS</div>
                    <div class="d-flex flex-column gap-2">
                        @if (!string.IsNullOrEmpty(detailCustomer.ContactPerson))
                        {
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-person text-primary" style="width:18px;"></i>
                                <span class="small fw-600">@detailCustomer.ContactPerson</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(detailCustomer.Email))
                        {
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-envelope text-primary" style="width:18px;"></i>
                                <a href="mailto:@detailCustomer.Email" class="small fw-600 text-primary text-decoration-none">@detailCustomer.Email</a>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(detailCustomer.Phone))
                        {
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-telephone text-primary" style="width:18px;"></i>
                                <a href="tel:@detailCustomer.Phone" class="small fw-600 text-primary text-decoration-none">@detailCustomer.Phone</a>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(detailCustomer.Address))
                        {
                            <div class="d-flex align-items-start gap-2">
                                <i class="bi bi-geo-alt text-primary mt-1" style="width:18px;"></i>
                                <span class="small text-slate-500">@detailCustomer.Address</span>
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(detailCustomer.Notes))
                    {
                        <div class="mt-3 p-3 rounded-3" style="background:#f8faff;">
                            <div class="x-small fw-800 text-slate-400 mb-1">NOTES</div>
                            <p class="small text-slate-600 mb-0">@detailCustomer.Notes</p>
                        </div>
                    }
                </div>

                @* Job History *@
                <div class="px-4 pt-3 pb-2">
                    <div class="x-small fw-800 text-slate-400 text-uppercase mb-2">JOB HISTORY</div>
                </div>
                <div style="max-height:300px;overflow-y:auto;">
                    @if (!detailCustomer.JobCards.Any())
                    {
                        <div class="px-4 pb-4 text-center">
                            <i class="bi bi-clipboard-x fs-3 text-slate-200 d-block mb-2"></i>
                            <span class="small text-slate-400 fw-600">No jobs linked to this client yet.</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var job in detailCustomer.JobCards.OrderByDescending(j => j.CreatedAt))
                        {
                            <div class="px-4 py-2 d-flex justify-content-between align-items-center border-bottom">
                                <div>
                                    <div class="small fw-800 text-slate-900">@job.JobNumber</div>
                                    <div class="x-small text-slate-400">@job.Equipment?.Name — @job.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</div>
                                </div>
                                <div class="text-end">
                                    <span class="badge x-small fw-800 @GetStatusBadge(job.Status)">@job.Status.ToString().ToUpper()</span>
                                    @if (job.InvoiceAmount > 0)
                                    {
                                        <div class="x-small fw-800 text-success mt-1">ZMW @job.InvoiceAmount.ToString("N0")</div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
                @if (detailStats?.LastServiceDate.HasValue == true)
                {
                    <div class="px-4 py-3 x-small text-slate-400 fw-600 border-top">
                        LAST SERVICE: @detailStats.LastServiceDate.Value.ToLocalTime().ToString("MMM dd, yyyy")
                    </div>
                }
            </div>
        </div>
    }
</div>

@* Add/Edit Customer Modal *@
@if (showEditor)
{
    <div class="modal fade show d-block" style="background-color:rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius:16px;">
                <div class="modal-header border-bottom-0 pt-4 px-4">
                    <h5 class="modal-title fw-800 text-slate-900">
                        @(currentCustomer.Id == 0 ? "Add New Client" : "Edit Client")
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => showEditor = false"></button>
                </div>
                <div class="modal-body px-4 pb-2">
                    @if (!string.IsNullOrEmpty(editorError))
                    {
                        <div class="alert alert-danger py-2 small fw-600">@editorError</div>
                    }
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Company / Client Name *</label>
                            <input class="form-control border-0 bg-light fw-600" style="height:48px;border-radius:10px;"
                                   @bind="currentCustomer.Name" placeholder="Enter company or client name" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Contact Person</label>
                            <input class="form-control border-0 bg-light fw-600" style="height:48px;border-radius:10px;"
                                   @bind="currentCustomer.ContactPerson" placeholder="Primary contact name" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Phone Number</label>
                            <input class="form-control border-0 bg-light fw-600" style="height:48px;border-radius:10px;"
                                   @bind="currentCustomer.Phone" placeholder="+260..." />
                        </div>
                        <div class="col-12">
                            <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Email Address</label>
                            <input type="email" class="form-control border-0 bg-light fw-600" style="height:48px;border-radius:10px;"
                                   @bind="currentCustomer.Email" placeholder="client@example.com" />
                        </div>
                        <div class="col-12">
                            <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Physical Address</label>
                            <textarea class="form-control border-0 bg-light fw-600" style="border-radius:10px;min-height:70px;"
                                      @bind="currentCustomer.Address" placeholder="Full address..."></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Internal Notes</label>
                            <textarea class="form-control border-0 bg-light fw-600" style="border-radius:10px;min-height:70px;"
                                      @bind="currentCustomer.Notes" placeholder="Notes visible only to your team..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 px-4 pb-4 pt-3">
                    <button type="button" class="btn btn-light fw-800 px-4" style="border-radius:10px;" @onclick="() => showEditor = false">CANCEL</button>
                    <button type="button" class="btn btn-primary fw-800 px-4" style="border-radius:10px;" @onclick="SaveCustomer" disabled="@isSaving">
                        @if (isSaving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        @(currentCustomer.Id == 0 ? "ADD CLIENT" : "SAVE CHANGES")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Customer>? customers;
    private Customer currentCustomer = new();
    private Customer? selectedCustomer;
    private Customer? detailCustomer;
    private CustomerStats? detailStats;
    private bool showEditor = false;
    private bool isSaving = false;
    private string? editorError;
    private string searchTerm = "";

    private List<Customer>? FilteredCustomers => string.IsNullOrWhiteSpace(searchTerm)
        ? customers
        : customers?.Where(c =>
            c.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            (c.ContactPerson != null && c.ContactPerson.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
            (c.Email != null && c.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
            (c.Phone != null && c.Phone.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
          ).ToList();

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        customers = await CustomerService.GetAllCustomersAsync();
        // Refresh detail panel if open
        if (selectedCustomer != null)
            await SelectCustomer(selectedCustomer);
    }

    private async Task SelectCustomer(Customer customer)
    {
        selectedCustomer = customer;
        detailCustomer = await CustomerService.GetCustomerWithJobsAsync(customer.Id);
        detailStats = await CustomerService.GetCustomerStatsAsync(customer.Id);
    }

    private void OpenEditor(Customer? customer = null)
    {
        editorError = null;
        currentCustomer = customer != null ? new Customer
        {
            Id = customer.Id,
            Name = customer.Name,
            ContactPerson = customer.ContactPerson,
            Email = customer.Email,
            Phone = customer.Phone,
            Address = customer.Address,
            Notes = customer.Notes,
            TenantId = customer.TenantId
        } : new Customer();
        showEditor = true;
    }

    private async Task SaveCustomer()
    {
        editorError = null;
        if (string.IsNullOrWhiteSpace(currentCustomer.Name))
        {
            editorError = "Client name is required.";
            return;
        }

        isSaving = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.Identity?.Name ?? "System";

            if (currentCustomer.Id == 0)
                await CustomerService.CreateCustomerAsync(currentCustomer, userId);
            else
                await CustomerService.UpdateCustomerAsync(currentCustomer, userId);

            showEditor = false;
            await LoadData();
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteCustomer(Customer customer)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            $"Remove '{customer.Name}' from the registry? This will not delete their linked jobs.");
        if (confirmed)
        {
            if (selectedCustomer?.Id == customer.Id) selectedCustomer = null;
            await CustomerService.DeleteCustomerAsync(customer.Id);
            await LoadData();
        }
    }

    private string GetStatusBadge(JobStatus status) => status switch
    {
        JobStatus.Completed => "bg-success-subtle text-success",
        JobStatus.InProgress => "bg-primary-subtle text-primary",
        JobStatus.Scheduled => "bg-info-subtle text-info",
        JobStatus.Cancelled => "bg-danger-subtle text-danger",
        JobStatus.OnHold => "bg-warning-subtle text-warning",
        _ => "bg-secondary-subtle text-secondary"
    };
}
