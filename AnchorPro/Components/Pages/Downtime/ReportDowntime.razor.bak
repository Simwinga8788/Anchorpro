@page "/downtime/report"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using AnchorPro.Data.Entities
@using AnchorPro.Data.Enums
@using AnchorPro.Services.Interfaces
@using System.Security.Claims
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@* @attribute [Authorize] *@
@inject IEquipmentService EquipmentService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDowntimeService DowntimeService
@inject IReferenceDataService ReferenceDataService
@inject IJobTaskService JobTaskService
@inject IJobCardService JobCardService

<PageTitle>Report Downtime</PageTitle>

<ApplePageHeader Title="Report Downtime" Subtitle="Log equipment delays and breakdowns">
    <ActionButtons>
        <a href="downtime/history" class="btn btn-secondary">
            <i class="bi bi-clock-history"></i>
            <span>View History</span>
        </a>
    </ActionButtons>
</ApplePageHeader>

<div class="row justify-content-center">
    <div class="col-lg-8">
        @if (activeEntry != null)
        {
            <div class="card p-5 mb-4 text-center border-0 shadow-sm" style="background-color: #FEF2F2;">
                <div class="mb-3">
                    <div class="spinner-grow text-danger" role="status" style="width: 1rem; height: 1rem;"></div>
                    <span class="ms-2 fw-bold text-danger">LIVE DOWNTIME</span>
                </div>
                <h1 class="fw-bold mb-2 display-4">@((DateTime.UtcNow - activeEntry.StartTime).ToString(@"hh\:mm"))</h1>
                <div class="text-secondary mb-4">
                    Started at @activeEntry.StartTime.ToLocalTime().ToString("h:mm tt")
                </div>
                
                <div class="d-flex justify-content-center">
                    <button class="btn btn-danger btn-lg px-5 py-3 shadow fw-bold" @onclick="StopActiveDowntime">
                        <i class="bi bi-stop-circle-fill me-2"></i>END DOWNTIME
                    </button>
                </div>
                
                <p class="mt-4 mb-0 text-muted">
                    @activeEntry.Notes
                </p>
            </div>
        }
        else
        {
        <div class="card">
            <EditForm Model="downtimeReport" OnValidSubmit="SubmitReport">
                <DataAnnotationsValidator />
                
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger mb-4">@errorMessage</div>
                }
                
                @if (submitted)
                {
                    <div class="alert alert-success mb-4">
                        <i class="bi bi-check-circle me-2"></i>
                        Downtime report submitted successfully!
                    </div>
                }

                <div class="row g-4">
                    <!-- Downtime Category -->
                    <div class="col-md-6">
                        <label class="form-label">Category *</label>
                        <InputSelect @bind-Value="downtimeReport.CategoryId" class="form-select">
                            <option value="0">-- Select Category --</option>
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </InputSelect>
                    </div>

                    <!-- Status -->
                    <div class="col-md-6">
                        <label class="form-label">Status *</label>
                        <InputSelect @bind-Value="downtimeReport.Status" class="form-select">
                            <option value="Ongoing">Ongoing - Still Active</option>
                            <option value="Resolved">Resolved - Already Fixed</option>
                        </InputSelect>
                        <div class="form-text">Select "Resolved" if the issue is already fixed</div>
                    </div>

                    <!-- Equipment Selection - Now Optional -->
                    <div class="col-12">
                        <label class="form-label">Equipment (if applicable)</label>
                        <InputSelect @bind-Value="downtimeReport.EquipmentId" class="form-select">
                            <option value="0">-- No Equipment / Not Applicable --</option>
                            @foreach (var eq in equipmentList)
                            {
                                <option value="@eq.Id">@eq.Name (@eq.SerialNumber)</option>
                            }
                        </InputSelect>
                        <div class="form-text">Leave as "Not Applicable" for delays not related to equipment</div>
                    </div>

                    <!-- Severity -->
                    <div class="col-md-6">
                        <label class="form-label">Severity *</label>
                        <InputSelect @bind-Value="downtimeReport.Severity" class="form-select">
                            <option value="">-- Select Severity --</option>
                            <option value="Critical">Critical - Production Stopped</option>
                            <option value="High">High - Major Impact</option>
                            <option value="Medium">Medium - Moderate Impact</option>
                            <option value="Low">Low - Minor Impact</option>
                        </InputSelect>
                        <ValidationMessage For="() => downtimeReport.Severity" class="text-danger" />
                    </div>

                    <!-- Start Time -->
                    <div class="col-md-6">
                        <label class="form-label">Start Time *</label>
                        <InputDate @bind-Value="downtimeReport.StartTime" Type="InputDateType.DateTimeLocal" class="form-control" />
                        <ValidationMessage For="() => downtimeReport.StartTime" class="text-danger" />
                        @if (downtimeReport.Status == "Ongoing" && downtimeReport.StartTime < DateTime.Now)
                        {
                            var elapsed = DateTime.Now - downtimeReport.StartTime;
                            <div class="form-text text-warning">
                                <i class="bi bi-hourglass-split me-1"></i>
                                <strong>Elapsed: @elapsed.TotalHours.ToString("F1") hours (@elapsed.TotalMinutes.ToString("F0") min)</strong>
                            </div>
                        }
                    </div>

                    <!-- End Time - Required if Resolved -->
                    <div class="col-md-6">
                        <label class="form-label">
                            End Time @(downtimeReport.Status == "Resolved" ? "*" : "(optional)")
                        </label>
                        <div class="d-flex gap-2">
                            <InputDate @bind-Value="downtimeReport.EndTime" Type="InputDateType.DateTimeLocal" class="form-control" />
                            @if (downtimeReport.Status == "Ongoing")
                            {
                                <button type="button" class="btn btn-success" @onclick="EndDelayNow" title="End delay and set time to now">
                                    <i class="bi bi-stop-circle"></i>
                                    <span class="d-none d-lg-inline ms-2">End Now</span>
                                </button>
                            }
                        </div>
                        @if (downtimeReport.Status == "Resolved" && !downtimeReport.EndTime.HasValue)
                        {
                            <div class="text-danger small mt-1">End time is required for resolved issues</div>
                        }
                        @if (downtimeReport.EndTime.HasValue && downtimeReport.EndTime > downtimeReport.StartTime)
                        {
                            var duration = downtimeReport.EndTime.Value - downtimeReport.StartTime;
                            <div class="form-text">
                                <i class="bi bi-clock me-1"></i>
                                Duration: @duration.TotalHours.ToString("F1") hours (@duration.TotalMinutes.ToString("F0") minutes)
                            </div>
                        }
                    </div>

                    <!-- Description -->
                    <div class="col-12">
                        <label class="form-label">Description *</label>
                        <InputTextArea @bind-Value="downtimeReport.Description" class="form-control" rows="4" 
                                       placeholder="Describe the issue, symptoms, and any immediate actions taken..." />
                        <ValidationMessage For="() => downtimeReport.Description" class="text-danger" />
                    </div>

                    <!-- Root Cause (Optional) -->
                    <div class="col-12">
                        <label class="form-label">Root Cause (if known)</label>
                        <InputTextArea @bind-Value="downtimeReport.RootCause" class="form-control" rows="2" 
                                       placeholder="What caused this downtime?" />
                    </div>

                    <!-- Resolution Notes - Only for Resolved Issues -->
                    @if (downtimeReport.Status == "Resolved")
                    {
                        <div class="col-12">
                            <label class="form-label">Resolution Notes *</label>
                            <InputTextArea @bind-Value="downtimeReport.ResolutionNotes" class="form-control" rows="3" 
                                           placeholder="How was this issue resolved? What actions were taken?" />
                            <ValidationMessage For="() => downtimeReport.ResolutionNotes" class="text-danger" />
                        </div>
                    }

                    <!-- Estimated Cost and Production Loss Removed for simplified Technician view -->
                </div>

                <div class="d-flex justify-content-end gap-3 mt-4 pt-4 border-top">
                    <a href="/" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <span>Submit Report</span>
                    </button>
                </div>
            </EditForm>
        </div>
        }
    </div>
</div>

@code {
    private DowntimeReportModel downtimeReport = new() { StartTime = DateTime.Now, Status = "Ongoing" };
    private List<Equipment> equipmentList = new();
    private string? errorMessage;
    private bool submitted = false;
    private bool isSubmitting = false;
    private string currentUserId = "system";

    private DowntimeEntry? activeEntry;
    private List<DowntimeCategory> categories = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.Identity?.Name ?? "system";
        
        equipmentList = await EquipmentService.GetAllEquipmentAsync();
        activeEntry = await DowntimeService.GetActiveDowntimeAsync(currentUserId);
    }

    private async Task StopActiveDowntime()
    {
        if (activeEntry != null)
        {
            activeEntry.EndTime = DateTime.Now;
            activeEntry.DurationMinutes = (int)(activeEntry.EndTime.Value - activeEntry.StartTime).TotalMinutes;
            await DowntimeService.UpdateDowntimeEntryAsync(activeEntry, currentUserId);
            activeEntry = null; // Reset UI
            downtimeReport = new DowntimeReportModel { StartTime = DateTime.Now, Status = "Ongoing" };
        }
    }

    private void EndDelayNow()
    {
        downtimeReport.EndTime = DateTime.Now;
        downtimeReport.Status = "Resolved";
        StateHasChanged();
    }

    private async Task SubmitReport()
    {
        // Basic validation
        if (downtimeReport.CategoryId == 0 || 
            string.IsNullOrEmpty(downtimeReport.Severity) || 
            string.IsNullOrEmpty(downtimeReport.Description))
        {
            errorMessage = "Please fill in all required fields.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            // Try to find a task related to this equipment or user's active job
            var allJobs = await JobCardService.GetAllJobCardsAsync();
            var activeJob = allJobs.FirstOrDefault(j => j.AssignedTechnicianId == currentUserId && j.Status == JobStatus.InProgress);
            int taskId = 0;
            if (activeJob != null)
            {
                var tasksForJob = await JobTaskService.GetTasksForJobCardAsync(activeJob.Id);
                taskId = tasksForJob.FirstOrDefault(t => !t.IsCompleted)?.Id ?? tasksForJob.FirstOrDefault()?.Id ?? 0;
            }

            var entry = new DowntimeEntry
            {
                JobTaskId = taskId > 0 ? taskId : (await JobTaskService.GetAllTasksAsync()).FirstOrDefault()?.Id ?? 1,
                DowntimeCategoryId = downtimeReport.CategoryId,
                StartTime = downtimeReport.StartTime,
                EndTime = downtimeReport.Status == "Resolved" ? downtimeReport.EndTime : null,
                Notes = $"{downtimeReport.Description} (Severity: {downtimeReport.Severity})",
                CreatedBy = currentUserId,
                CreatedAt = DateTime.UtcNow
            };
            
            await DowntimeService.CreateDowntimeEntryAsync(entry, currentUserId);
            
            if (entry.EndTime == null)
            {
                activeEntry = entry; // Switch to Active View
            }
            else
            {
                submitted = true;
                downtimeReport = new DowntimeReportModel { StartTime = DateTime.Now, Status = "Ongoing" };
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error submitting report: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class DowntimeReportModel
    {
        public int EquipmentId { get; set; } // Optional - 0 means not applicable
        public int CategoryId { get; set; }
        [System.ComponentModel.DataAnnotations.Required] public string Status { get; set; } = "Ongoing";
        [System.ComponentModel.DataAnnotations.Required] public string Severity { get; set; } = "";
        [System.ComponentModel.DataAnnotations.Required] public DateTime StartTime { get; set; }
        public DateTime? EndTime { get; set; }
        [System.ComponentModel.DataAnnotations.Required, System.ComponentModel.DataAnnotations.MinLength(10)] public string Description { get; set; } = "";
        public string? RootCause { get; set; }
        public string? ResolutionNotes { get; set; } // Required if Status = Resolved
        public decimal? EstimatedCost { get; set; }
        public int? ProductionLoss { get; set; }
    }
}
