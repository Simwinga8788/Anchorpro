@page "/job-cards"
@rendermode InteractiveServer
@using AnchorPro.Data.Entities
@using AnchorPro.Data.Enums
@using AnchorPro.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@inject IJobCardService JobCardService
@inject NavigationManager NavigationManager
@inject IExportService ExportService
@inject IJSRuntime JS
@inject ILabelService LabelService

<PageTitle>Job Cards</PageTitle>

<ApplePageHeader Title="Job Cards" Subtitle="Manage work orders and maintenance tasks">
    <ActionButtons>
        <AuthorizeView Roles="Admin,Supervisor,Planner">
            <button class="btn btn-premium-ghost me-2" @onclick="ExportCsv">
                <i class="bi bi-download"></i> EXPORT CSV
            </button>
            <button class="btn btn-premium" @onclick="CreateNew">
                <i class="bi bi-plus-lg me-2"></i>NEW JOB CARD
            </button>
        </AuthorizeView>
        <AuthorizeView Roles="Technician">
            <button class="btn btn-premium-ghost me-2" @onclick="ExportCsv">
                <i class="bi bi-download"></i> EXPORT CSV
            </button>
        </AuthorizeView>
    </ActionButtons>
</ApplePageHeader>

<!-- Filters -->
<div class="card-premium mb-4 p-3 p-md-4">
    <div class="row g-3 align-items-end">
        <div class="col-6 col-md-3">
            <label class="metric-label-premium">STATUS</label>
            <select class="form-select border-0 bg-white shadow-sm fw-800 rounded-3" style="height: 42px;" @bind="selectedStatus" @bind:after="ApplyFilters">
                <option value="">All Statuses</option>
                @foreach (JobStatus status in Enum.GetValues(typeof(JobStatus)))
                {
                    <option value="@status">@status</option>
                }
            </select>
        </div>
        <div class="col-6 col-md-3">
            <label class="metric-label-premium">PRIORITY</label>
            <select class="form-select border-0 bg-white shadow-sm fw-800 rounded-3" style="height: 42px;" @bind="selectedPriority" @bind:after="ApplyFilters">
                <option value="">All Priorities</option>
                @foreach (JobPriority priority in Enum.GetValues(typeof(JobPriority)))
                {
                    <option value="@priority">@LabelService.GetPriorityLabel(priority)</option>
                }
            </select>
        </div>
        <div class="col-12 col-md-4">
            <label class="metric-label-premium">SEARCH OPERATIONS</label>
            <input type="text" class="form-control border-0 bg-white shadow-sm fw-800 rounded-3" style="height: 42px;" placeholder="Search Job # or asset..." 
                   @bind="searchText" @bind:after="ApplyFilters" />
        </div>
        <div class="col-12 col-md-2">
            <button class="btn btn-premium-ghost w-100 border-0 shadow-sm" @onclick="ClearFilters" style="height: 42px; padding: 0;">
                RESET
            </button>
        </div>
    </div>
</div>

<!-- Job Cards List -->
<div class="card-premium p-0 overflow-hidden">
    @if (isLoading)
    {
        <div class="d-flex justify-content-center p-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (!filteredJobCards.Any())
    {
        <div class="text-center p-5 text-muted">
            <i class="bi bi-inbox display-4 mb-3 d-block opacity-25"></i>
            <p class="mb-3 fw-800">No job cards found</p>
            @if (!string.IsNullOrEmpty(searchText) || !string.IsNullOrEmpty(selectedStatus))
            {
                <button class="btn btn-premium-ghost" @onclick="ClearFilters">
                    Clear filters
                </button>
            }
            else
            {
                <button class="btn btn-premium" @onclick="CreateNew">
                    Create Job
                </button>
            }
        </div>
    }
    else
    {
        <div class="table-responsive-premium">
            <table class="table-premium mb-0">
                <thead>
                    <tr>
                        <th style="width: 15%">Reference</th>
                        <th style="width: 25%">Asset</th>
                        <th style="width: 15%">Type</th>
                        <th style="width: 10%">Priority</th>
                        <th style="width: 10%">Status</th>
                        <th style="width: 15%">Cost</th>
                        <th class="text-end" style="width: 10%">Operations</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in filteredJobCards)
                    {
                        <tr class="job-row-hover" @onclick='() => NavigationManager.NavigateTo($"/job-cards/{job.Id}")' style="cursor: pointer;">
                            <td class="fw-800 text-primary">#@job.JobNumber</td>
                            <td>
                                <div class="fw-800 text-slate-900">@job.Equipment?.Name</div>
                                <div class="x-small text-slate-400 fw-800">SN: @job.Equipment?.SerialNumber</div>
                            </td>
                            <td>
                                <span class="badge-premium slate">@job.JobType?.Name</span>
                            </td>
                             <td>
                                <span class="badge-premium @GetPriorityClass(job.Priority)">@job.Priority.ToString().ToUpper()</span>
                            </td>
                            <td>
                                <span class="badge-premium @GetStatusBadgeClass(job.Status)">@job.Status.ToString().ToUpper()</span>
                            </td>
                            <td>
                                <div class="fw-800 text-slate-900">K @(job.TotalCost > 0 ? job.TotalCost.ToString("N2") : "0.00")</div>
                                <div class="x-small text-slate-400 fw-800">ZMW</div>
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <button class="btn-action" @onclick='() => EditJob(job.Id)' @onclick:stopPropagation title="Edit">
                                        EDIT
                                    </button>
                                    <AuthorizeView Roles="Admin">
                                        <button class="btn-action btn-action-danger" @onclick="() => DeleteJob(job.Id)" @onclick:stopPropagation title="Delete">
                                            REMOVE
                                        </button>
                                    </AuthorizeView>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-lg-none mt-3">
            @foreach (var job in filteredJobCards)
            {
                <div class="card-premium p-4 mb-3 position-relative overflow-hidden" @onclick='() => NavigationManager.NavigateTo($"/job-cards/{job.Id}")' style="cursor: pointer; background: white;">
                    <div class="position-absolute top-0 bottom-0 start-0" style="width: 5px; background-color: var(--ap-primary);"></div>
                    
                    <div class="ps-2">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="fw-800 text-primary">#@job.JobNumber</span>
                            <span class="badge-premium @GetPriorityClass(job.Priority)">@job.Priority.ToString().ToUpper()</span>
                        </div>
                        <div class="fw-800 text-slate-900 mb-1" style="font-size: 1.1rem;">@job.JobType?.Name</div>
                        <div class="text-slate-400 x-small fw-800 mb-4">ASSET: @job.Equipment?.Name</div>
                        
                        <div class="d-flex justify-content-between align-items-center pt-3 border-top" style="border-top-style: dashed !important;">
                            <span class="badge-premium @GetStatusBadgeClass(job.Status)">@job.Status.ToString().ToUpper()</span>
                            <div class="fw-800 text-slate-900">K @(job.TotalCost > 0 ? job.TotalCost.ToString("N2") : "0.00")</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Stats Footer -->
<div class="row g-2 g-md-3 mt-2">
    <div class="col-6 col-md-3">
        <div class="card-premium p-3 text-center mb-0">
            <div class="metric-label-premium">TOTAL OPER.</div>
            <div class="h4 mb-0 fw-800 text-slate-900">@filteredJobCards.Count</div>
        </div>
    </div>
     <div class="col-6 col-md-3">
        <div class="card-premium p-3 text-center mb-0">
            <div class="metric-label-premium">BACKLOG</div>
            <div class="h4 mb-0 fw-800 text-slate-900">@filteredJobCards.Count(j => j.Status == JobStatus.Unscheduled)</div>
        </div>
    </div>
     <div class="col-6 col-md-3">
        <div class="card-premium p-3 text-center mb-0">
            <div class="metric-label-premium">ACTIVE</div>
            <div class="h4 mb-0 fw-800 text-slate-900">@filteredJobCards.Count(j => j.Status == JobStatus.InProgress)</div>
        </div>
    </div>
     <div class="col-6 col-md-3">
        <div class="card-premium p-3 text-center mb-0">
            <div class="metric-label-premium text-success">RESOLVED</div>
            <div class="h4 mb-0 fw-800 text-success">@filteredJobCards.Count(j => j.Status == JobStatus.Completed)</div>
        </div>
    </div>
</div>

<style>
    .x-small { font-size: 0.75rem; }
    .table thead th { border: none; font-weight: 600; color: #9CA3AF; }
    .table td { border: none; }
    .table tr:hover { background-color: #F9FAFB; }
</style>

@code {
    private List<JobCard> allJobCards = new();
    private List<JobCard> filteredJobCards = new();
    private bool isLoading = true;

    private string searchText = "";
    private string selectedStatus = "";
    private string selectedPriority = "";

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine("JobCardList: Init started");
        try
        {
            await LabelService.LoadLabelsAsync();
            Console.WriteLine("JobCardList: Labels loaded");
            await LoadData();
            Console.WriteLine("JobCardList: Init complete");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"JobCardList Init Error: {ex}");
        }
    }
    /*
        await LabelService.LoadLabelsAsync();
        await LoadData();
    */

    private async Task LoadData()
    {
        Console.WriteLine("JobCardList: Loading Data...");
        try 
        {
            isLoading = true;
            allJobCards = await JobCardService.GetAllJobCardsAsync();
            Console.WriteLine($"JobCardList: Loaded {allJobCards.Count} cards");
            ApplyFilters();
            isLoading = false;
        }
        catch (Exception ex)
        {
             Console.WriteLine($"JobCardList LoadData Error: {ex}");
             isLoading = false;
        }
    }
    /*
        isLoading = true;
        allJobCards = await JobCardService.GetAllJobCardsAsync();
        ApplyFilters();
        isLoading = false;
    */

    private void ApplyFilters()
    {
        var query = allJobCards.AsQueryable();

        if (!string.IsNullOrEmpty(selectedStatus) && Enum.TryParse<JobStatus>(selectedStatus, out var status))
        {
            query = query.Where(j => j.Status == status);
        }

        if (!string.IsNullOrEmpty(selectedPriority) && Enum.TryParse<JobPriority>(selectedPriority, out var priority))
        {
            query = query.Where(j => j.Priority == priority);
        }

        if (!string.IsNullOrEmpty(searchText))
        {
            query = query.Where(j => 
                j.JobNumber.Contains(searchText, StringComparison.OrdinalIgnoreCase) || 
                (j.Description != null && j.Description.Contains(searchText, StringComparison.OrdinalIgnoreCase)));
        }

        filteredJobCards = query.OrderByDescending(j => j.CreatedAt).ToList();
    }

    private void ClearFilters()
    {
        searchText = "";
        selectedStatus = "";
        selectedPriority = "";
        ApplyFilters();
    }

    private void CreateNew()
    {
        NavigationManager.NavigateTo("/job-cards/create");
    }

    private string GetPriorityClass(JobPriority p) => p switch {
        JobPriority.Critical => "danger",
        JobPriority.High => "warning",
        JobPriority.Normal => "info",
        _ => "slate"
    };

    private string GetStatusBadgeClass(JobStatus s) => s switch {
        JobStatus.Completed => "success",
        JobStatus.InProgress => "warning",
        JobStatus.Scheduled => "info",
        JobStatus.Cancelled => "danger",
        _ => "slate"
    };

    private void EditJob(int jobId)
    {
        NavigationManager.NavigateTo($"/job-cards/edit/{jobId}");
    }

    private async Task DeleteJob(int jobId)
    {
        await JobCardService.DeleteJobCardAsync(jobId);
        await LoadData();
    }

    private async Task ExportCsv()
    {
        var csvBytes = ExportService.GenerateJobHistoryCsv(filteredJobCards);
        var fileName = $"JobHistory_{DateTime.Now:yyyyMMdd_HHmm}.csv";
        var base64 = Convert.ToBase64String(csvBytes);
        
        await JS.InvokeVoidAsync("downloadFile", fileName, "text/csv", base64);
    }
}
