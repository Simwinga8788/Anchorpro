@page "/job-cards/{Id:int}"
@rendermode InteractiveServer
@using AnchorPro.Data.Entities
@using AnchorPro.Data.Enums
@using AnchorPro.Services.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@inject IJobCardService JobCardService
@inject IJobTaskService JobTaskService
@inject IProcurementService ProcurementService
@inject IInventoryService InventoryService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Job Details | #@(jobCard?.JobNumber ?? "...")</PageTitle>

@if (isLoading)
{
    <div class="d-flex flex-column align-items-center justify-content-center p-5">
        <div class="spinner-border text-primary mb-3" role="status"></div>
        <div class="text-slate-500 fw-800 uppercase x-small">Pulling digital twin...</div>
    </div>
}
else if (jobCard == null)
{
    <div class="container py-5 text-center">
        <i class="bi bi-exclamation-octagon display-1 text-danger mb-4"></i>
        <h2 class="fw-800">Job Not Found</h2>
        <p class="text-slate-500 mb-4">The maintenance record you're looking for doesn't exist or has been moved.</p>
        <button class="btn btn-primary px-4 fw-800" @onclick="BackToList">BACK TO OPERATIONS</button>
    </div>
}
else
{
    <div class="container-fluid py-3 py-md-4 px-3 px-lg-5">
    <ApplePageHeader Title="@jobCard.JobType?.Name" Subtitle="@($"#{jobCard.JobNumber} • REPLICA STATUS")">
        <ActionButtons>
            <div class="d-flex gap-2">
                <button class="btn btn-premium-ghost px-4" @onclick="BackToList">BACK</button>
                <AuthorizeView Roles="Admin,Supervisor,Planner">
                    <button class="btn btn-premium px-4" @onclick="EditJob">EDIT</button>
                </AuthorizeView>
            </div>
        </ActionButtons>
    </ApplePageHeader>


        <div class="row g-4">
            <!-- Left Side: Core Info & Tasks -->
            <div class="col-lg-8">
                <!-- Asset Link Card -->
                <div class="card-premium p-3 p-md-4 mb-4" style="background: linear-gradient(to right, #F8FAFC, #FFFFFF);">
                    <div class="row g-3 align-items-center">
                        <div class="col-auto">
                            <div class="icon-box bg-white shadow-sm text-primary" style="width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px;">
                                <i class="bi bi-cpu"></i>
                            </div>
                        </div>
                        <div class="col">
                            <h6 class="metric-label-premium mb-1">Assigned Asset</h6>
                            <div class="fw-800 text-slate-900 mb-0 cursor-pointer d-flex align-items-center" @onclick='() => NavigationManager.NavigateTo($"/equipment/details/{jobCard.EquipmentId}")' style="font-size: 1.1rem;">
                                @jobCard.Equipment?.Name <i class="bi bi-arrow-right-short ms-1 text-primary"></i>
                            </div>
                            <div class="text-slate-400 x-small fw-700">@jobCard.Equipment?.SerialNumber</div>
                        </div>
                        <div class="col-12 col-md-5 mt-3 mt-md-0 border-top border-md-0 pt-3 pt-md-0">
                            <h6 class="metric-label-premium mb-1">Work Description</h6>
                            <p class="text-slate-700 mb-0 small fw-700 line-clamp-2">@jobCard.Description</p>
                        </div>
                    </div>
                </div>

                <!-- Execution Checklist -->
                <div class="card-premium mb-4 p-0 overflow-hidden">
                    <div class="card-header bg-white border-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-center">
                         <h5 class="fw-800 text-slate-900 mb-0 fs-6">System Checklist</h5>
                         <div class="badge-premium slate">@tasks.Count(t => t.IsCompleted)/@tasks.Count COMPLETE</div>
                    </div>
                    <div class="card-body px-0">
                        @if (!tasks.Any())
                        {
                            <div class="px-4 py-3 text-slate-400 italic small">No digital instructions attached to this record.</div>
                        }
                        else
                        {
                            <div class="checklist-items">
                                @foreach (var task in tasks)
                                {
                                    <div class="checklist-item d-flex align-items-start gap-3 px-4 py-3 @(task.IsCompleted ? "bg-slate-50" : "")">
                                        <div class="form-check pt-1">
                                            <input class="form-check-input" type="checkbox" checked="@task.IsCompleted" disabled="@(jobCard.Status != JobStatus.InProgress)" 
                                                   @onchange="() => CompleteTask(task.Id)" style="width: 20px; height: 20px; cursor: pointer; border-radius: 6px;" />
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="fw-800 text-slate-900 @(task.IsCompleted ? "text-decoration-line-through text-slate-400" : "")">@task.Name</div>
                                            @if (!string.IsNullOrEmpty(task.Instructions))
                                            {
                                                <div class="small text-slate-500 mt-1 fw-600">@task.Instructions</div>
                                            }
                                            <div class="d-flex gap-3 mt-2">
                                                <div class="text-slate-400 x-small fw-800"><i class="bi bi-clock me-1"></i>EST. @task.EstimatedDurationMinutes MIN</div>
                                                @if (task.IsCompleted && task.CompletedAt.HasValue)
                                                {
                                                    <div class="text-success x-small fw-800"><i class="bi bi-check-lg me-1"></i>SYNCED @task.CompletedAt.Value.ToLocalTime().ToString("HH:mm")</div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
                <!-- Spare Parts Used -->
                <div class="card-premium mb-4 p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-800 text-slate-900 mb-0 fs-6">Internal Parts & Materials</h5>
                        <AuthorizeView Roles="Admin,Supervisor,Planner">
                            <button class="btn btn-premium-ghost btn-sm px-3 fw-800" @onclick="OpenPartsModal">
                                <i class="bi bi-plus-lg me-1"></i> ADD PART
                            </button>
                        </AuthorizeView>
                    </div>
                    
                    @if (jobCard.JobCardParts == null || !jobCard.JobCardParts.Any())
                    {
                        <div class="text-center py-4 text-slate-400 italic small bg-slate-50 rounded-3 border-dashed">
                             No inventory items attributed to this job yet.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="small">ITEM</th>
                                        <th class="text-center small">QTY</th>
                                        <th class="text-end small">UNIT</th>
                                        <th class="text-end small">TOTAL</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var part in jobCard.JobCardParts)
                                    {
                                        <tr>
                                            <td class="small fw-700">@part.InventoryItem?.Name</td>
                                            <td class="text-center small fw-800">@part.QuantityUsed</td>
                                            <td class="text-end text-slate-500 x-small">K @part.UnitCostSnapshot.ToString("N2")</td>
                                            <td class="text-end small fw-800">K @((part.QuantityUsed * part.UnitCostSnapshot).ToString("N2"))</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <!-- External / Subcontracted POs — Cost Trinity View -->
                <div class="card-premium mb-4 p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-800 text-slate-900 mb-0 fs-6">External POs (Direct Purchase & Subcontracting)</h5>
                        <div class="text-slate-400 x-small fw-800 uppercase text-primary">ERP PROCUREMENT</div>
                    </div>
                    
                    @if (linkedPOs == null || !linkedPOs.Any())
                    {
                        <div class="text-center py-4 text-slate-400 italic small bg-slate-50 rounded-3 border-dashed">
                             No external purchase orders linked to this work order.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="small">PO #</th>
                                        <th class="small">SUPPLIER</th>
                                        <th class="small">TYPE</th>
                                        <th class="small">STATUS</th>
                                        <th class="text-end small">AMOUNT</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var po in linkedPOs)
                                    {
                                        <tr>
                                            <td class="small fw-800 text-primary">@po.PoNumber</td>
                                            <td class="small fw-700">@po.Supplier?.Name</td>
                                            <td>
                                                <span class="badge-premium @(po.PoType == PurchaseOrderType.Subcontracting ? "warning" : "primary") x-small">
                                                    @(po.PoType == PurchaseOrderType.DirectPurchase ? "Direct Purchase" : "Subcontracting")
                                                </span>
                                            </td>
                                            <td><span class="badge @(po.Status == PurchaseOrderStatus.Received ? "bg-success" : "bg-info") small">@po.Status.ToString().ToUpper()</span></td>
                                            <td class="text-end small fw-800">K @po.TotalAmount.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- Right Side: Status & Timeline -->
            <div class="col-lg-4">
                <!-- Status Control Pad -->
                <div class="card border-0 shadow-sm p-4 mb-4 @GetStatusContainerClass(jobCard.Status)">
                    <h6 class="text-white-50 fw-800 small text-uppercase mb-4" style="letter-spacing: 0.1em;">Operational Status</h6>
                    
                    <div class="d-flex align-items-center gap-3 mb-4">
                         <div class="status-indicator-ring">
                             <div class="status-indicator-core"></div>
                         </div>
                         <div class="h3 fw-800 text-white mb-0">@jobCard.Status.ToString().ToUpper()</div>
                    </div>

                    <div class="vstack gap-2">
                         @if (jobCard.Status == JobStatus.Unscheduled || jobCard.Status == JobStatus.Scheduled)
                         {
                             <button class="btn btn-light w-100 py-3 fw-800 text-primary shadow-sm" @onclick='() => ChangeStatus(JobStatus.InProgress)'>
                                 <i class="bi bi-play-fill me-2"></i> START WORK ORDER
                             </button>
                         }
                         @if (jobCard.Status == JobStatus.InProgress)
                         {
                             <button class="btn btn-success w-100 py-3 fw-800 border-0 shadow-sm" style="background: #10B981;" @onclick='() => ChangeStatus(JobStatus.Completed)'>
                                 <i class="bi bi-check-circle-fill me-2"></i> SYNC AS COMPLETED
                             </button>
                         }
                         @if (jobCard.Status != JobStatus.Cancelled && jobCard.Status != JobStatus.Completed)
                         {
                             <button class="btn btn-outline-light w-100 py-2 border-dashed fw-800 small opacity-75 mt-2" @onclick='() => ChangeStatus(JobStatus.Cancelled)'>
                                 CANCEL RECORD
                             </button>
                         }
                    </div>
                    @if (jobCard.Status == JobStatus.InProgress || jobCard.Status == JobStatus.Scheduled)
                    {
                        <div class="mt-4 border-top pt-4">
                            <button class="btn btn-premium w-100 py-3 fw-800" @onclick="GoToExecution">
                                <i class="bi bi-tools me-2"></i> EXECUTION CONSOLE
                            </button>
                            <div class="text-white-50 x-small text-center mt-2 fw-800">COMPLETE TASKS & ADD PARTS</div>
                        </div>
                    }
                </div>

                <!-- Financial Snapshot — Cost Trinity -->
                <div class="card-premium p-4 mb-4">
                    <h6 class="metric-label-premium mb-1">Financial Intelligence</h6>
                    <div class="text-slate-400 x-small fw-700 mb-4">COST TRINITY BREAKDOWN</div>

                    @{
                        var totalForBars = Math.Max(jobCard.TotalCost, 0.01m);
                        decimal laborPct  = Math.Round((jobCard.LaborCost / totalForBars) * 100, 0);
                        decimal partsPct  = Math.Round((jobCard.PartsCost / totalForBars) * 100, 0);
                        decimal directPct = Math.Round((jobCard.DirectPurchaseCost / totalForBars) * 100, 0);
                        decimal subPct    = Math.Round((jobCard.SubcontractingCost / totalForBars) * 100, 0);
                    }

                    <!-- Stacked Cost Bar -->
                    <div class="d-flex rounded-pill overflow-hidden mb-4" style="height: 10px;">
                        <div style="width: @laborPct%;  background: #64748B;" title="Labor"></div>
                        <div style="width: @partsPct%;  background: #22C55E;" title="Stock Parts"></div>
                        <div style="width: @directPct%; background: #3B82F6;" title="Direct Purchase"></div>
                        <div style="width: @subPct%;    background: #F59E0B;" title="Subcontracting"></div>
                    </div>

                    <!-- Bucket Rows -->
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="d-flex align-items-center gap-2">
                            <div class="rounded-circle" style="width:10px;height:10px;background:#64748B;flex-shrink:0;"></div>
                            <span class="text-slate-500 fw-700 small">Internal Labor</span>
                        </div>
                        <span class="fw-800 text-slate-900">K @jobCard.LaborCost.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="d-flex align-items-center gap-2">
                            <div class="rounded-circle" style="width:10px;height:10px;background:#22C55E;flex-shrink:0;"></div>
                            <span class="text-slate-500 fw-700 small">Stock Parts</span>
                        </div>
                        <span class="fw-800 text-slate-900">K @jobCard.PartsCost.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="d-flex align-items-center gap-2">
                            <div class="rounded-circle" style="width:10px;height:10px;background:#3B82F6;flex-shrink:0;"></div>
                            <span class="text-slate-500 fw-700 small">Direct Purchase <span class="x-small text-slate-400 fw-600">(Non-stock job parts)</span></span>
                        </div>
                        <span class="fw-800 text-primary">K @jobCard.DirectPurchaseCost.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="d-flex align-items-center gap-2">
                            <div class="rounded-circle" style="width:10px;height:10px;background:#F59E0B;flex-shrink:0;"></div>
                            <span class="text-slate-500 fw-700 small">Subcontracting <span class="x-small text-slate-400 fw-600">(External labor/service)</span></span>
                        </div>
                        <span class="fw-800 text-warning">K @jobCard.SubcontractingCost.ToString("N2")</span>
                    </div>

                    <div class="pt-3 border-top d-flex justify-content-between align-items-center">
                         <span class="text-slate-900 fw-800 x-small uppercase">TOTAL COST</span>
                         <span class="h4 fw-800 text-primary mb-0">K @jobCard.TotalCost.ToString("N2")</span>
                    </div>

                    @if (jobCard.Status == JobStatus.Completed)
                    {
                        <div class="mt-4 p-3 rounded-3 bg-slate-50 border border-dashed">
                             <div class="d-flex justify-content-between mb-2">
                                 <span class="text-slate-500 fw-800 x-small">REVENUE (INVOICE)</span>
                                 <span class="fw-800 text-slate-900">K @jobCard.InvoiceAmount.ToString("N2")</span>
                             </div>
                             <div class="d-flex justify-content-between">
                                 <span class="text-slate-500 fw-800 x-small">PROFIT / MARGIN</span>
                                 <span class="fw-800 @(jobCard.Profit >= 0 ? "text-success" : "text-danger")">
                                    K @jobCard.Profit.ToString("N2") &nbsp;(@jobCard.ProfitMarginPercent.ToString("N1")%)
                                 </span>
                             </div>
                        </div>
                    }
                </div>

                <!-- Timeline -->
                <div class="card-premium p-4">
                    <h6 class="metric-label-premium mb-4">Timeline Control</h6>
                    <div class="timeline-v">
                        <div class="timeline-v-item">
                            <div class="time text-slate-400 fw-800 uppercase x-small">SCHEDULED</div>
                            <div class="val text-slate-900 fw-800">@(jobCard.ScheduledStartDate?.ToString("MMM dd, HH:mm") ?? "UNSCHEDULED")</div>
                        </div>
                        <div class="timeline-v-item">
                            <div class="time text-slate-400 fw-800 uppercase x-small">ACTUAL START</div>
                            <div class="val text-slate-900 fw-800">@(jobCard.ActualStartDate?.ToString("MMM dd, HH:mm") ?? "--:--")</div>
                        </div>
                        <div class="timeline-v-item border-0 pb-0">
                            <div class="time text-slate-400 fw-800 uppercase x-small">ACTUAL FINISH</div>
                            <div class="val text-slate-900 fw-800">@(jobCard.ActualEndDate?.ToString("MMM dd, HH:mm") ?? "IN PROGRESS")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .fw-800 { font-weight: 800; }
    .fw-700 { font-weight: 700; }
    .fw-600 { font-weight: 600; }
    .text-slate-400 { color: #94A3B8; }
    .text-slate-500 { color: #64748B; }
    .text-slate-700 { color: #334155; }
    .text-slate-900 { color: #0F172A; }
    .bg-slate-50 { background-color: #F8FAFC; }
    .bg-slate-100 { background-color: #F1F5F9; }
    .x-small { font-size: 0.65rem; letter-spacing: 0.05em; }
    
    .status-indicator-ring { width: 44px; height: 44px; border: 4px solid rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
    .status-indicator-core { width: 14px; height: 14px; background: white; border-radius: 50%; box-shadow: 0 0 15px white; animation: blink 2s infinite; }
    
    @@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

    .card-status-scheduled { background: linear-gradient(135deg, #0F172A 0%, #1E40AF 100%); }
    .card-status-inprogress { background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%); }
    .card-status-completed { background: linear-gradient(135deg, #059669 0%, #047857 100%); }
    .card-status-cancelled { background: linear-gradient(135deg, #94A3B8 0%, #475569 100%); }

    .timeline-v-item { border-left: 2px solid #F1F5F9; padding-left: 20px; position: relative; padding-bottom: 24px; }
    .timeline-v-item::before { content: ""; position: absolute; left: -7px; top: 0; width: 12px; height: 12px; background: white; border: 2px solid var(--ap-primary); border-radius: 50%; }
    .timeline-v-item .time { font-size: 10px; margin-bottom: 2px; }
    
    .checklist-item { border-bottom: 1px solid #F1F5F9; transition: all 0.2s; }
    .checklist-item:hover { background: #F8FAFC; }
</style>

@code {
    [Parameter] public int Id { get; set; }
    private JobCard? jobCard;
    private List<JobTask> tasks = new();
    private List<PurchaseOrder> linkedPOs = new();
    private bool isLoading = true;
    private List<InventoryItem> allParts = new();
    private int selectedPartId;
    private int selectedPartQty = 1;
    private bool showPartsModal = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadJobCard();
    }

    private async Task LoadJobCard()
    {
        isLoading = true;
        try {
            jobCard = await JobCardService.GetJobCardByIdAsync(Id);
            if (jobCard != null) 
            {
                tasks = await JobTaskService.GetTasksForJobCardAsync(Id);
                linkedPOs = await ProcurementService.GetPurchaseOrdersByJobCardIdAsync(Id);
            }
        }
        finally { isLoading = false; }
    }

    private async Task ChangeStatus(JobStatus newStatus)
    {
        if (jobCard == null) return;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.Identity?.Name ?? "System";
        await JobCardService.UpdateJobStatusAsync(jobCard.Id, newStatus, userId);
        await LoadJobCard();
    }

    private async Task CompleteTask(int taskId)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.Identity?.Name ?? "System";
        await JobTaskService.CompleteTaskAsync(taskId, userId);
        await LoadJobCard();
    }

    private void EditJob() => NavigationManager.NavigateTo($"/job-cards/edit/{Id}");
    private void GoToExecution() => NavigationManager.NavigateTo($"/my-tasks/{Id}");
    private void BackToList() => NavigationManager.NavigateTo("/job-cards");

    private string GetPriorityBadgeClass(JobPriority p) => p switch {
        JobPriority.Critical => "bg-danger",
        JobPriority.High => "bg-warning text-dark",
        JobPriority.Normal => "bg-primary",
        _ => "bg-slate-100 text-slate-600"
    };

    private string GetStatusContainerClass(JobStatus s) => s switch {
        JobStatus.Scheduled => "card-status-scheduled",
        JobStatus.InProgress => "card-status-inprogress",
        JobStatus.Completed => "card-status-completed",
        _ => "card-status-cancelled"
    };

    private async Task OpenPartsModal()
    {
        allParts = await InventoryService.GetAllItemsAsync();
        selectedPartQty = 1;
        showPartsModal = true;
    }

    private async Task AddPart()
    {
        if (selectedPartId > 0 && selectedPartQty > 0)
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.Identity?.Name ?? "System";
            await JobCardService.AddPartToJobAsync(Id, selectedPartId, selectedPartQty, userId);
            showPartsModal = false;
            await LoadJobCard();
        }
    }
}

@if (showPartsModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header">
                    <h5 class="modal-title fw-800">Add Spare Part to #@jobCard?.JobNumber</h5>
                    <button type="button" class="btn-close" @onclick="() => showPartsModal = false"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label x-small fw-800 uppercase text-slate-500">Inventory Item</label>
                        <select class="form-select border-2" @bind="selectedPartId" style="border-radius: 10px;">
                            <option value="0">-- Select Part --</option>
                            @foreach(var part in allParts)
                            {
                                <option value="@part.Id">@part.Name (Stock: @part.QuantityOnHand)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label x-small fw-800 uppercase text-slate-500">Quantity to Issue</label>
                        <input type="number" class="form-control border-2" @bind="selectedPartQty" min="1" max="100" style="border-radius: 10px;" />
                    </div>
                    <div class="alert alert-info x-small fw-600 mb-0">
                        <i class="bi bi-info-circle-fill me-1"></i>
                        Adding a part will immediately impact the Internal Parts cost of this work order and deduct stock from inventory.
                    </div>
                </div>
                <div class="modal-footer border-0 p-4">
                    <button class="btn btn-premium-ghost px-4 fw-800" @onclick="() => showPartsModal = false">CANCEL</button>
                    <button class="btn btn-premium px-5 fw-800" @onclick="AddPart" disabled="@(selectedPartId == 0 || selectedPartQty <= 0)">ISSUE PART</button>
                </div>
            </div>
        </div>
    </div>
}
