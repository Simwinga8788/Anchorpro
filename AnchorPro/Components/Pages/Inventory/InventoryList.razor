@page "/inventory"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using AnchorPro.Data
@using AnchorPro.Data.Entities
@using AnchorPro.Services.Interfaces
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Authorization
@inject IInventoryService InventoryService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize]

<PageTitle>Inventory</PageTitle>

<ApplePageHeader Title="Inventory & Parts" Subtitle="LOGISTICS & SUPPLY">
    <ActionButtons>
        <AuthorizeView Roles="Admin,Planner,Supervisor">
            <button class="btn btn-premium" @onclick="CreateNew">
                <i class="bi bi-plus-lg me-2"></i>ADD NEW PART
            </button>
        </AuthorizeView>
    </ActionButtons>
</ApplePageHeader>

    <div class="card-premium p-0 overflow-hidden">
        @if (items == null)
        {
            <div class="p-5 text-center">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 text-slate-500 fw-800 uppercase x-small">Querying central warehouse...</p>
            </div>
        }
        else if (!items.Any())
        {
            <div class="p-5 text-center text-slate-400">
                <i class="bi bi-box-seam display-4 mb-3 opacity-25"></i>
                <p class="fw-800 x-small uppercase">No inventory items identified</p>
            </div>
        }
        else
        {
            <div class="d-none d-lg-block">
                <table class="table-premium mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Part Identifier</th>
                            <th>Designation</th>
                            <th>Stock Level</th>
                            <th>Deployment Bin</th>
                            <th>Valuation</th>
                            <th class="text-end pe-4">Operations</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in items)
                        {
                            <tr>
                                <td class="ps-4 py-4 fw-800 text-primary small">@item.PartNumber</td>
                                <td>
                                    <div class="fw-800 text-slate-900">@item.Name</div>
                                    @if(!string.IsNullOrEmpty(item.Description))
                                    {
                                        <div class="x-small text-slate-400 fw-700">@item.Description</div>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        @{
                                            var isLow = item.QuantityOnHand <= item.ReorderLevel;
                                        }
                                        <span class="badge-premium @(isLow ? "danger" : "success") px-3 py-2">
                                            @item.QuantityOnHand
                                        </span>
                                        @if(isLow)
                                        {
                                            <i class="bi bi-exclamation-triangle-fill text-danger x-small" title="REORDER REQUIRED"></i>
                                        }
                                    </div>
                                </td>
                                <td class="text-slate-500 small fw-800">@item.LocationBin</td>
                                <td class="fw-800 text-slate-900 small">@item.UnitCost.ToString("C")</td>
                                <td class="text-end pe-4">
                                    <AuthorizeView Roles="Admin,Planner,Supervisor">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="btn-action" @onclick="() => EditItem(item)">
                                                EDIT
                                            </button>
                                            <button class="btn-action btn-action-primary" @onclick="() => ShowStockModal(item)">
                                                STOCK
                                            </button>
                                        </div>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Mobile View (Inventory Cards) -->
            <div class="d-lg-none p-3">
                @foreach (var item in items)
                {
                    <div class="card p-3 mb-3 border-0 shadow-sm position-relative overflow-hidden" @onclick="() => EditItem(item)" style="cursor: pointer; background: white; border-radius: 12px;">
                        <div class="position-absolute top-0 bottom-0 start-0" style="width: 4px; background-color: @(item.QuantityOnHand <= item.ReorderLevel ? "var(--ap-danger)" : "var(--ap-primary)")"></div>
                        <div class="ps-2">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <div class="fw-800 text-primary small">@item.PartNumber</div>
                                    <div class="fw-800 text-slate-900">@item.Name</div>
                                </div>
                                <span class="badge-premium @(item.QuantityOnHand <= item.ReorderLevel ? "danger" : "success")">STK: @item.QuantityOnHand</span>
                            </div>
                            <div class="text-slate-400 x-small fw-700 mb-3 uppercase">LOC: @item.LocationBin • @item.UnitCost.ToString("C")</div>
                            <div class="d-flex gap-2 pt-3 border-top">
                                 <button class="btn-action" @onclick:stopPropagation="true" @onclick="() => EditItem(item)">EDIT</button>
                                 <button class="btn-action btn-action-primary" @onclick:stopPropagation="true" @onclick="() => ShowStockModal(item)">STOCK</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>


@if (showEditor)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">@(currentItem.Id == 0 ? "Add New Part" : "Edit Part")</h5>
                    <button type="button" class="btn-close" @onclick="CloseEditor"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="currentItem" OnValidSubmit="SaveItem">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Part Number (SKU)</label>
                            <InputText class="form-control" @bind-Value="currentItem.PartNumber" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Name</label>
                            <InputText class="form-control" @bind-Value="currentItem.Name" />
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold">Unit Cost</label>
                                <InputNumber class="form-control" @bind-Value="currentItem.UnitCost" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold">Reorder Level</label>
                                <InputNumber class="form-control" @bind-Value="currentItem.ReorderLevel" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Location / Bin</label>
                            <InputText class="form-control" @bind-Value="currentItem.LocationBin" />
                        </div>
                         <div class="mb-3">
                            <label class="form-label small fw-bold">Description</label>
                            <InputTextArea class="form-control" @bind-Value="currentItem.Description" />
                        </div>

                        @if(currentItem.Id == 0)
                        {
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Initial Stock</label>
                                <InputNumber class="form-control" @bind-Value="currentItem.QuantityOnHand" />
                                <div class="form-text">Set starting inventory count.</div>
                            </div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="btn btn-premium-ghost" @onclick="CloseEditor">Cancel</button>
                            <button type="submit" class="btn btn-premium">Save Part</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (showStockEditor)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-light">
                    <div>
                        <h5 class="modal-title fw-bold">Adjust Stock</h5>
                        <div class="small text-secondary">@selectedStockItem?.Name (@selectedStockItem?.PartNumber)</div>
                    </div>
                    <button type="button" class="btn-close" @onclick="CloseStockEditor"></button>
                </div>
                <div class="modal-body p-4">
                     <div class="mb-4 text-center">
                         <div class="display-6 fw-bold mb-1">@selectedStockItem?.QuantityOnHand</div>
                         <div class="text-secondary small text-uppercase">Current Stock</div>
                     </div>

                     <div class="mb-3">
                        <label class="form-label small fw-bold">Adjustment Amount (Positive or Negative)</label>
                        <input type="number" class="form-control form-control-lg" @bind="stockAdjustmentAmount" />
                        <div class="form-text">Enter +5 to add stock, -2 to remove stock.</div>
                     </div>

                     <div class="mb-3">
                        <label class="form-label small fw-bold">Reason / Reference</label>
                        <input type="text" class="form-control" @bind="stockAdjustmentReason" placeholder="e.g., Received shipment PO-123" />
                     </div>

                     <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-premium-ghost" @onclick="CloseStockEditor">Cancel</button>
                        <button type="button" class="btn btn-premium" @onclick="SaveStockAdjustment">Confirm Adjustment</button>
                     </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<InventoryItem>? items;
    private bool showEditor = false;
    private bool showStockEditor = false;
    private InventoryItem currentItem = new();
    
    private InventoryItem? selectedStockItem;
    private int stockAdjustmentAmount = 0;
    private string stockAdjustmentReason = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
         items = await InventoryService.GetAllItemsAsync();
    }

    private void CreateNew()
    {
        currentItem = new InventoryItem();
        showEditor = true;
    }

    private void EditItem(InventoryItem item)
    {
        // Clone to avoid direct mutation of list item
        currentItem = new InventoryItem
        {
            Id = item.Id,
            PartNumber = item.PartNumber,
            Name = item.Name,
            Description = item.Description,
            UnitCost = item.UnitCost,
            ReorderLevel = item.ReorderLevel,
            QuantityOnHand = item.QuantityOnHand, 
            LocationBin = item.LocationBin
        };
        showEditor = true;
    }

    private void CloseEditor()
    {
        showEditor = false;
    }

    private async Task SaveItem()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!authState.User.IsInRole("Admin") && !authState.User.IsInRole("Planner") && !authState.User.IsInRole("Supervisor"))
        {
            return; // Unauthorized
        }
        var user = await UserManager.GetUserAsync(authState.User);
        var userId = user?.Id ?? "Unknown";

        if (currentItem.Id == 0)
        {
            await InventoryService.CreateItemAsync(currentItem, userId);
        }
        else
        {
            await InventoryService.UpdateItemAsync(currentItem, userId);
        }

        showEditor = false;
        await LoadData();
    }

    private void ShowStockModal(InventoryItem item)
    {
        selectedStockItem = item;
        stockAdjustmentAmount = 0;
        stockAdjustmentReason = string.Empty;
        showStockEditor = true;
    }

    private void CloseStockEditor()
    {
        showStockEditor = false;
        selectedStockItem = null;
    }

    private async Task SaveStockAdjustment()
    {
         if (selectedStockItem != null && stockAdjustmentAmount != 0)
         {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (!authState.User.IsInRole("Admin") && !authState.User.IsInRole("Planner") && !authState.User.IsInRole("Supervisor"))
            {
                return; // Unauthorized
            }
            var user = await UserManager.GetUserAsync(authState.User);
            var userId = user?.Id ?? "Unknown";

            await InventoryService.AdjustStockAsync(selectedStockItem.Id, stockAdjustmentAmount, userId, stockAdjustmentReason);
            
            showStockEditor = false;
            await LoadData();
         }
    }
}
