@page "/reports"
@using AnchorPro.Data.Models
@using AnchorPro.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@inject IDashboardService DashboardService
@inject IExportService ExportService
@inject IJSRuntime JS
@attribute [Authorize(Roles = "Admin,Planner,Supervisor")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<ApplePageHeader Title="System Analytics" Subtitle="PRODUCTION INTELLIGENCE">
    <ActionButtons>
        <AuthorizeView Roles="Admin">
            <a href="admin/automated-reports" class="btn btn-premium-ghost me-2">
                <i class="bi bi-clock-history me-2"></i>SCHEDULES
            </a>
        </AuthorizeView>
        <button class="btn btn-premium" @onclick="ExportExcel">
            <i class="bi bi-file-earmark-excel-fill me-2"></i>GENERATE EXCEL
        </button>
    </ActionButtons>
</ApplePageHeader>

    @if (metrics == null)
    {
        <div class="d-flex flex-column align-items-center justify-content-center py-5">
            <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem; border-width: 0.3em;" role="status"></div>
            <p class="text-slate-500 fw-800 uppercase x-small">Aggregating historical data...</p>
        </div>
    }
    else
    {
        <!-- KPI Row -->
        <div class="kpi-grid mb-5">
            <div class="card-premium">
                <div class="metric-label-premium">COMPLETION RATE</div>
                <div class="d-flex align-items-center justify-content-between mt-2">
                    <div class="metric-value text-success">@metrics.OnTimeCompletionPercentage%</div>
                    <div class="badge-premium success">ON TIME</div>
                </div>
                <div class="x-small fw-800 text-slate-400 mt-2">TARGET: 85% PERFORMANCE</div>
            </div>

            <div class="card-premium">
                <div class="metric-label-premium">AVG LEAD TIME</div>
                <div class="d-flex align-items-baseline gap-2 mt-2">
                    <div class="metric-value">@metrics.AvgLeadTimeHours<span class="fs-6 ms-1 fw-700 text-slate-400 font-monospace">HRS</span></div>
                </div>
                <div class="x-small fw-800 text-slate-400 mt-2">REQUEST TO RESOLUTION</div>
            </div>

            <div class="card-premium">
                <div class="metric-label-premium">TOTAL COMPLETED</div>
                <div class="d-flex align-items-center justify-content-between mt-2">
                    <div class="metric-value">@metrics.CompletedJobsInPeriod</div>
                    <div class="badge-premium slate">30 DAYS</div>
                </div>
                <div class="x-small fw-800 text-slate-400 mt-2">THROUGHPUT YTD</div>
            </div>

            <div class="card-premium">
                <div class="metric-label-premium">ACTIVE BACKLOG</div>
                <div class="d-flex align-items-center justify-content-between mt-2">
                    <div class="metric-value text-danger">@metrics.OverdueJobsCount</div>
                    <div class="badge-premium danger">OVERDUE</div>
                </div>
                <div class="x-small fw-800 text-slate-400 mt-2">PRIORITY ATTENTION</div>
            </div>
        </div>

        <div class="row g-4 mb-5">
             <div class="col-lg-8">
                  <div class="card-premium h-100 p-0 overflow-hidden">
                      <div class="card-header bg-white border-0 py-4 px-4">
                          <h5 class="mb-0 fw-800 text-slate-900 fs-6">Operational Throughput</h5>
                          <div class="header-subtitle mt-1">Daily Resolution Trend</div>
                      </div>
                      <div class="card-body px-4 pb-4">
                          <div class="overflow-x-auto" style="scrollbar-width: none; -ms-overflow-style: none;">
                              <div class="d-flex align-items-end justify-content-between gap-1 mt-3" style="height: 220px; min-width: 600px;">
                                  @if (metrics.CompletionTrend.Any())
                                  {
                                      var max = metrics.CompletionTrend.Max(x => x.CompletedCount);
                                      if (max == 0) max = 1;

                                      @foreach(var day in metrics.CompletionTrend)
                                      {
                                          var percent = (day.CompletedCount * 100.0 / max);
                                          <div class="chart-bar-wrapper" title="@day.Date.ToShortDateString(): @day.CompletedCount jobs">
                                              <div class="chart-bar bg-primary" style="height: @(Math.Max(8, percent))%;"></div>
                                          </div>
                                      }
                                  }
                              </div>
                          </div>
                          <div class="d-flex justify-content-between mt-4 pb-2 border-top pt-3 text-slate-400 x-small fw-800 uppercase" style="letter-spacing: 0.05em;">
                              <span>@DateTime.Now.AddDays(-30).ToString("MMM dd")</span>
                              <span>TREND ANALYSIS (LAST 30 DAYS)</span>
                              <span>@DateTime.Now.ToString("MMM dd")</span>
                          </div>
                      </div>
                  </div>
              </div>
             
             <div class="col-lg-4">
                  <div class="card-premium h-100 p-0 overflow-hidden">
                       <div class="card-header bg-white border-0 py-4 px-4">
                          <h5 class="mb-0 fw-800 text-slate-900 fs-6">Downtime Causes</h5>
                          <div class="header-subtitle mt-1">Impact by Category</div>
                       </div>
                       <div class="card-body px-4 pb-4">
                           @{
                               var maxDowntime = metrics.GlobalDowntime.Any() ? metrics.GlobalDowntime.Max(x => x.TotalDurationHours) : 0;
                           }
                           @foreach(var item in metrics.GlobalDowntime.OrderByDescending(x => x.TotalDurationHours).Take(6))
                           {
                               var barWidth = maxDowntime > 0 ? (item.TotalDurationHours * 100.0 / maxDowntime) : 0;
                               <div class="mb-4">
                                   <div class="d-flex justify-content-between mb-2">
                                       <span class="x-small fw-800 text-slate-700 uppercase">@item.Category</span>
                                       <span class="x-small fw-800 text-primary">@item.TotalDurationHours <span class="text-slate-400">HRS</span></span>
                                   </div>
                                   <div class="progress" style="height: 8px; background: #F1F5F9; border-radius: 4px; overflow: hidden;">
                                       <div class="progress-bar bg-primary" style="width: @(Math.Max(5, barWidth))%;"></div>
                                   </div>
                               </div>
                           }
                           @if (!metrics.GlobalDowntime.Any())
                           {
                               <div class="d-flex flex-column align-items-center justify-content-center py-5 h-100">
                                   <i class="bi bi-shield-check text-slate-200 display-4 mb-3"></i>
                                   <div class="text-slate-400 x-small fw-800 uppercase">System Integrity Nominal</div>
                               </div>
                           }
                       </div>
                  </div>
              </div>
        </div>

        <!-- Asset Performance -->
        <div class="card-premium mb-5 p-0 overflow-hidden">
            <div class="card-header bg-white border-0 py-4 px-4 d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-0 fw-800 text-slate-900 fs-6">Asset Reliability Protocol</h5>
                    <div class="header-subtitle mt-1">ISO 14224 Compliance Monitoring</div>
                </div>
                <div class="badge-premium slate">INTERNAL PROTOCOL</div>
            </div>
            
            <div class="d-none d-md-block">
                <table class="table-premium mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Asset Designation</th>
                            <th>Utilization</th>
                            <th>MTBF <span class="text-slate-400 fw-500">(HRS)</span></th>
                            <th>MTTR <span class="text-slate-400 fw-500">(HRS)</span></th>
                            <th>Failures</th>
                            <th class="pe-4 text-end">Est. Next Alert</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var asset in metrics.EquipmentStats.OrderBy(x => x.MTBF_Hours))
                        {
                            <tr>
                                <td class="ps-4 py-4">
                                    <div class="fw-800 text-slate-900">@asset.EquipmentName</div>
                                    <div class="x-small text-slate-500 fw-700">SERVICE CLASS A</div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="progress flex-grow-1" style="height: 6px; width: 80px; background: #F1F5F9; border-radius: 3px; overflow: hidden;">
                                            <div class="progress-bar bg-info" style="width: @asset.UtilizationPercentage%"></div>
                                        </div>
                                        <span class="x-small fw-800 text-slate-700">@asset.UtilizationPercentage%</span>
                                    </div>
                                </td>
                                <td class="fw-800 text-slate-600">@asset.MTBF_Hours</td>
                                <td class="fw-800 text-slate-600">@asset.MTTR_Hours</td>
                                <td>
                                    @if(asset.BreakdownCount > 0) {
                                        <div class="badge-premium danger">@asset.BreakdownCount</div>
                                    } else {
                                        <span class="text-slate-300">—</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    @if(asset.PredictedNextFailure.HasValue) {
                                        <div class="d-inline-block px-3 py-1 bg-warning-subtle text-warning-emphasis fw-800 rounded-pill x-small">
                                            <i class="bi bi-calendar-event me-1"></i> @asset.PredictedNextFailure.Value.ToString("MMM dd")
                                        </div>
                                    } else {
                                        <div class="d-inline-block px-3 py-1 bg-success-subtle text-success fw-800 rounded-pill x-small">
                                            <i class="bi bi-shield-check me-1"></i> STABLE
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Mobile View -->
            <div class="d-md-none p-3">
                @foreach(var asset in metrics.EquipmentStats.OrderBy(x => x.MTBF_Hours))
                {
                    <div class="card p-3 mb-3 border-0 shadow-sm position-relative overflow-hidden" style="background: white; border-radius: 12px;">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                             <div class="fw-800 text-slate-900">@asset.EquipmentName</div>
                             @if(asset.PredictedNextFailure.HasValue) {
                                 <div class="badge-premium warning">ALERT @asset.PredictedNextFailure.Value.ToString("MM/dd")</div>
                             } else {
                                 <div class="badge-premium success">STABLE</div>
                             }
                        </div>
                        <div class="row g-2 mb-3">
                            <div class="col-4">
                                <div class="text-slate-400 x-small fw-800 uppercase">MTBF</div>
                                <div class="fw-800 text-slate-700">@asset.MTBF_Hours<span class="x-small ms-1">H</span></div>
                            </div>
                            <div class="col-4">
                                <div class="text-slate-400 x-small fw-800 uppercase">MTTR</div>
                                <div class="fw-800 text-slate-700">@asset.MTTR_Hours<span class="x-small ms-1">H</span></div>
                            </div>
                            <div class="col-4">
                                <div class="text-slate-400 x-small fw-800 uppercase">FLR</div>
                                <div class="fw-800 text-slate-700">@asset.BreakdownCount</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3 pt-2 border-top">
                             <div class="x-small fw-800 text-slate-500 uppercase">UTILIZATION</div>
                             <div class="progress flex-grow-1" style="height: 6px; background: #F1F5F9; border-radius: 3px; overflow: hidden;">
                                 <div class="progress-bar bg-info" style="width: @asset.UtilizationPercentage%"></div>
                             </div>
                             <span class="x-small fw-800 text-slate-900">@asset.UtilizationPercentage%</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    }


<style>
    .chart-bar-wrapper {
        flex: 1;
        height: 100%;
        display: flex;
        align-items: end;
        padding: 0 1px;
    }
    .chart-bar {
        width: 100%;
        border-radius: 4px 4px 0 0;
        transition: all 0.3s;
        opacity: 0.8;
    }
    .chart-bar:hover {
        opacity: 1;
        cursor: pointer;
        background: var(--ap-primary-dark) !important;
    }
</style>

@code {
    private PerformanceMetrics? metrics;

    protected override async Task OnInitializedAsync()
    {
        metrics = await DashboardService.GetPerformanceMetricsAsync(30);
    }

    private async Task ExportExcel()
    {
        if (metrics == null) return;
        
        var excelBytes = ExportService.GeneratePerformanceExcel(metrics);
        var fileName = $"PerformanceReport_{DateTime.Now:yyyyMMdd}.xlsx";
        var base64 = Convert.ToBase64String(excelBytes);
        
        await JS.InvokeVoidAsync("downloadFile", fileName, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", base64);
    }
}
