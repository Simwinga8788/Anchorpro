@page "/safety"
@using AnchorPro.Data.Entities
@using AnchorPro.Services.Interfaces
@using AnchorPro.Data.Enums
@inject ISafetyService SafetyService
@inject IJobCardService JobCardService
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Safety & Compliance | Anchor Pro</PageTitle>

<ApplePageHeader Title="Safety & Compliance" Subtitle="Permit to Work (PTW) registry, energy isolation & safety auditing">
    <ActionButtons>
        <select class="form-select form-select-sm border-0 bg-light fw-700 me-2" style="width:160px;border-radius:8px;" @bind="statusFilter">
            <option value="">All Statuses</option>
            <option value="Active">Active</option>
            <option value="Suspended">Suspended</option>
            <option value="Closed">Closed</option>
        </select>
        <button class="btn btn-primary btn-sm" @onclick="OpenCreatePermit">
            <i class="bi bi-shield-plus me-1"></i> ISSUE PERMIT
        </button>
    </ActionButtons>
</ApplePageHeader>

@* KPI Cards *@
<div class="row g-3 mt-2 mb-4">
    <div class="col-6 col-md-2">
        <div class="card-premium text-center py-3" style="border-left: 3px solid #2563eb;">
            <div class="metric-label-premium">ACTIVE</div>
            <div class="h3 fw-800 text-primary mb-0">@(stats?.ActivePermits ?? 0)</div>
            <div class="x-small text-slate-400 fw-800">PERMITS</div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="card-premium text-center py-3" style="border-left: 3px solid #f59e0b;">
            <div class="metric-label-premium">SUSPENDED</div>
            <div class="h3 fw-800 text-warning mb-0">@(stats?.SuspendedPermits ?? 0)</div>
            <div class="x-small text-slate-400 fw-800">PERMITS</div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="card-premium text-center py-3" style="border-left: 3px solid #dc2626;">
            <div class="metric-label-premium">LOTO APPLIED</div>
            <div class="h3 fw-800 text-danger mb-0">@(stats?.LotoApplied ?? 0)</div>
            <div class="x-small text-slate-400 fw-800">ISOLATION</div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="card-premium text-center py-3" style="border-left: 3px solid #059669;">
            <div class="metric-label-premium">PPE VERIFIED</div>
            <div class="h3 fw-800 text-success mb-0">@(stats?.PpeChecks ?? 0)</div>
            <div class="x-small text-slate-400 fw-800">CHECKS</div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="card-premium text-center py-3" style="border-left: 3px solid #6d28d9;">
            <div class="metric-label-premium">CLOSED (MTD)</div>
            <div class="h3 fw-800 text-slate-700 mb-0">@(stats?.ClosedThisMonth ?? 0)</div>
            <div class="x-small text-slate-400 fw-800">THIS MONTH</div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="card-premium text-center py-3" style="border-left: 3px solid #10b981;">
            <div class="metric-label-premium">COMPLIANCE</div>
            <div class="h3 fw-800 @(stats?.CompliancePercent >= 90 ? "text-success" : "text-warning") mb-0">@(stats?.CompliancePercent ?? 100)%</div>
            <div class="x-small text-slate-400 fw-800">SAFETY SCORE</div>
        </div>
    </div>
</div>

@* Permit Registry Table *@
<div class="card-premium p-0 overflow-hidden">
    <div class="px-4 py-3 border-bottom d-flex justify-content-between align-items-center" style="background:#fafafa;">
        <h6 class="fw-800 text-slate-900 mb-0">PERMIT TO WORK REGISTRY</h6>
        <span class="x-small fw-800 text-slate-400">@FilteredPermits?.Count RECORDS</span>
    </div>
    <div class="table-responsive">
        <table class="table-premium">
            <thead>
                <tr>
                    <th class="ps-4">PTW REF</th>
                    <th>JOB / EQUIPMENT</th>
                    <th>SCOPE OF WORK</th>
                    <th>AUTHORIZED BY</th>
                    <th>SAFETY CHECKS</th>
                    <th>ISSUED</th>
                    <th>STATUS</th>
                    <th class="text-end pe-4">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @if (permits == null)
                {
                    <tr><td colspan="8" class="py-5 text-center">
                        <div class="spinner-border text-primary spinner-border-sm"></div>
                        <span class="ms-2 x-small fw-800 text-slate-400">LOADING PERMIT REGISTRY...</span>
                    </td></tr>
                }
                else if (!FilteredPermits!.Any())
                {
                    <tr><td colspan="8" class="py-5 text-center">
                        <i class="bi bi-shield-check fs-2 opacity-25 d-block mb-2"></i>
                        <span class="small fw-600 text-slate-400">No permits match the selected filter.</span>
                    </td></tr>
                }
                else
                {
                    @foreach (var p in FilteredPermits!)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-800 text-primary small">PTW-@p.Id.ToString("D4")</div>
                                <div class="x-small text-slate-400">JOB: @(p.JobCard?.JobNumber ?? "Stand-alone")</div>
                            </td>
                            <td>
                                <div class="small fw-700 text-slate-800">@(p.JobCard?.Equipment?.Name ?? "General Work")</div>
                            </td>
                            <td class="small text-slate-500" style="max-width:160px;">
                                <span class="text-truncate d-block">@(p.WorkScope ?? "—")</span>
                            </td>
                            <td class="small fw-600">@p.AuthorizedBy</td>
                            <td>
                                <div class="d-flex gap-1 flex-wrap">
                                    <span class="badge x-small fw-800 @(p.IsIsolated ? "bg-success-subtle text-success" : "bg-slate-100 text-slate-400")">ISO</span>
                                    <span class="badge x-small fw-800 @(p.IsLotoApplied ? "bg-danger-subtle text-danger" : "bg-slate-100 text-slate-400")">LOTO</span>
                                    <span class="badge x-small fw-800 @(p.IsAreaSecure ? "bg-success-subtle text-success" : "bg-slate-100 text-slate-400")">AREA</span>
                                    <span class="badge x-small fw-800 @(p.IsPpeChecked ? "bg-success-subtle text-success" : "bg-slate-100 text-slate-400")">PPE</span>
                                    <span class="badge x-small fw-800 @(p.ToolboxTalkCompleted ? "bg-info-subtle text-info" : "bg-slate-100 text-slate-400")">TBT</span>
                                </div>
                            </td>
                            <td class="small text-slate-500">@p.AuthorizedAt.ToLocalTime().ToString("MMM dd, HH:mm")</td>
                            <td>
                                @if (p.Status == PermitStatus.Active)
                                { <span class="badge bg-success-subtle text-success x-small fw-800 px-3 py-1 rounded-pill">ACTIVE</span> }
                                else if (p.Status == PermitStatus.Suspended)
                                { <span class="badge bg-warning-subtle text-warning x-small fw-800 px-3 py-1 rounded-pill">SUSPENDED</span> }
                                else
                                { <span class="badge bg-secondary-subtle text-secondary x-small fw-800 px-3 py-1 rounded-pill">CLOSED</span> }
                            </td>
                            <td class="text-end pe-3">
                                <button class="btn-action me-1" @onclick="() => OpenViewPermit(p)">VIEW</button>
                                @if (p.Status == PermitStatus.Active)
                                {
                                    <button class="btn-action btn-action-danger" @onclick="() => OpenClosePermit(p)">CLOSE</button>
                                }
                                @if (p.Status == PermitStatus.Suspended)
                                {
                                    <button class="btn-action" @onclick="() => ReactivatePermit(p)">REACTIVATE</button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@* Issue New Permit Modal *@
@if (showCreateModal)
{
    <div class="modal fade show d-block" style="background-color:rgba(0,0,0,0.55);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-0 shadow-lg" style="border-radius:16px;">
                <div class="modal-header border-bottom py-4 px-4" style="background:linear-gradient(135deg,#dc2626,#b91c1c);">
                    <div>
                        <h5 class="modal-title fw-800 text-white mb-0">
                            <i class="bi bi-shield-exclamation me-2"></i>Issue Permit to Work
                        </h5>
                        <div class="x-small text-white opacity-75 fw-600 mt-1">Complete all safety checks before issuing</div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showCreateModal = false"></button>
                </div>
                <div class="modal-body px-4 py-4">
                    @if (!string.IsNullOrEmpty(permitError))
                    {
                        <div class="alert alert-danger py-2 small fw-600">@permitError</div>
                    }

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Linked Job Card</label>
                            <select class="form-select border-0 bg-light fw-600" style="height:48px;border-radius:10px;"
                                    @bind="newPermit.JobCardId">
                                <option value="0">— Stand-alone permit (no job) —</option>
                                @foreach (var job in activeJobs)
                                {
                                    <option value="@job.Id">@job.JobNumber — @job.Equipment?.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Authorized By *</label>
                            <input class="form-control border-0 bg-light fw-600" style="height:48px;border-radius:10px;"
                                   @bind="newPermit.AuthorizedBy" placeholder="Supervisor / Engineer name" />
                        </div>
                        <div class="col-12">
                            <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Scope of Work *</label>
                            <input class="form-control border-0 bg-light fw-600" style="height:48px;border-radius:10px;"
                                   @bind="newPermit.WorkScope" placeholder="Brief description of work to be performed..." />
                        </div>
                        <div class="col-12">
                            <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Hazards Identified</label>
                            <textarea class="form-control border-0 bg-light fw-600" style="border-radius:10px;min-height:70px;"
                                      @bind="newPermit.HazardsIdentified" placeholder="List identified hazards..."></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Control Measures</label>
                            <textarea class="form-control border-0 bg-light fw-600" style="border-radius:10px;min-height:70px;"
                                      @bind="newPermit.ControlMeasures" placeholder="Mitigation steps for identified hazards..."></textarea>
                        </div>
                    </div>

                    @* Safety Checklist *@
                    <div class="mt-4 p-4 rounded-3" style="background:#fff8f8;border:1.5px solid #fee2e2;">
                        <div class="fw-800 text-danger small text-uppercase mb-3">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>SAFETY VERIFICATION CHECKLIST
                        </div>
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <div class="form-check d-flex align-items-center gap-3 p-3 rounded-3" style="background:white;border:1px solid #fecaca;">
                                    <input class="form-check-input" type="checkbox" id="chkIso" style="width:20px;height:20px;"
                                           @bind="newPermit.IsIsolated" />
                                    <label class="form-check-label fw-700 small" for="chkIso">
                                        Equipment is fully <strong>Isolated</strong> from energy sources
                                    </label>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="form-check d-flex align-items-center gap-3 p-3 rounded-3" style="background:white;border:1px solid #fecaca;">
                                    <input class="form-check-input" type="checkbox" id="chkLoto" style="width:20px;height:20px;"
                                           @bind="newPermit.IsLotoApplied" />
                                    <label class="form-check-label fw-700 small" for="chkLoto">
                                        <strong>LOTO</strong> (Lock Out Tag Out) has been applied
                                    </label>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="form-check d-flex align-items-center gap-3 p-3 rounded-3" style="background:white;border:1px solid #fecaca;">
                                    <input class="form-check-input" type="checkbox" id="chkArea" style="width:20px;height:20px;"
                                           @bind="newPermit.IsAreaSecure" />
                                    <label class="form-check-label fw-700 small" for="chkArea">
                                        Work <strong>area is secured</strong> and barricaded
                                    </label>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="form-check d-flex align-items-center gap-3 p-3 rounded-3" style="background:white;border:1px solid #fecaca;">
                                    <input class="form-check-input" type="checkbox" id="chkPpe" style="width:20px;height:20px;"
                                           @bind="newPermit.IsPpeChecked" />
                                    <label class="form-check-label fw-700 small" for="chkPpe">
                                        <strong>PPE</strong> checked and worn by all workers
                                    </label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-check d-flex align-items-center gap-3 p-3 rounded-3" style="background:white;border:1px solid #fecaca;">
                                    <input class="form-check-input" type="checkbox" id="chkTbt" style="width:20px;height:20px;"
                                           @bind="newPermit.ToolboxTalkCompleted" />
                                    <label class="form-check-label fw-700 small" for="chkTbt">
                                        <strong>Toolbox Talk</strong> conducted with all involved personnel
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 px-4 pb-4">
                    <button type="button" class="btn btn-light fw-800 px-4" style="border-radius:10px;" @onclick="() => showCreateModal = false">CANCEL</button>
                    <button type="button" class="btn btn-danger fw-800 px-4" style="border-radius:10px;" @onclick="IssuePermit" disabled="@isSaving">
                        @if (isSaving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        <i class="bi bi-shield-check me-2"></i>ISSUE PERMIT
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* View Permit Details Modal *@
@if (viewingPermit != null)
{
    <div class="modal fade show d-block" style="background-color:rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius:16px;">
                <div class="modal-header border-bottom py-4 px-4">
                    <div>
                        <h5 class="modal-title fw-800 text-slate-900">PTW-@viewingPermit.Id.ToString("D4")</h5>
                        <div class="x-small text-slate-400 fw-600">@viewingPermit.AuthorizedAt.ToLocalTime().ToString("MMMM dd, yyyy HH:mm")</div>
                    </div>
                    <button type="button" class="btn-close" @onclick="() => viewingPermit = null"></button>
                </div>
                <div class="modal-body px-4">
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <div class="x-small fw-800 text-slate-400">AUTHORIZED BY</div>
                            <div class="fw-800 text-slate-900">@viewingPermit.AuthorizedBy</div>
                        </div>
                        <div class="col-6">
                            <div class="x-small fw-800 text-slate-400">JOB NUMBER</div>
                            <div class="fw-800 text-primary">@(viewingPermit.JobCard?.JobNumber ?? "Stand-alone")</div>
                        </div>
                        @if (!string.IsNullOrEmpty(viewingPermit.WorkScope))
                        {
                            <div class="col-12">
                                <div class="x-small fw-800 text-slate-400">SCOPE OF WORK</div>
                                <div class="small fw-600">@viewingPermit.WorkScope</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(viewingPermit.HazardsIdentified))
                        {
                            <div class="col-12">
                                <div class="x-small fw-800 text-slate-400">HAZARDS IDENTIFIED</div>
                                <div class="small text-slate-600">@viewingPermit.HazardsIdentified</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(viewingPermit.ControlMeasures))
                        {
                            <div class="col-12">
                                <div class="x-small fw-800 text-slate-400">CONTROL MEASURES</div>
                                <div class="small text-slate-600">@viewingPermit.ControlMeasures</div>
                            </div>
                        }
                    </div>

                    <div class="p-3 rounded-3 mb-3" style="background:#f8faff;">
                        <div class="x-small fw-800 text-slate-400 mb-2">SAFETY CHECKS</div>
                        <div class="row g-2">
                            <div class="col-6"><i class="bi @(viewingPermit.IsIsolated ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger") me-2"></i><span class="small fw-600">Equipment Isolated</span></div>
                            <div class="col-6"><i class="bi @(viewingPermit.IsLotoApplied ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger") me-2"></i><span class="small fw-600">LOTO Applied</span></div>
                            <div class="col-6"><i class="bi @(viewingPermit.IsAreaSecure ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger") me-2"></i><span class="small fw-600">Area Secured</span></div>
                            <div class="col-6"><i class="bi @(viewingPermit.IsPpeChecked ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger") me-2"></i><span class="small fw-600">PPE Checked</span></div>
                            <div class="col-6"><i class="bi @(viewingPermit.ToolboxTalkCompleted ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger") me-2"></i><span class="small fw-600">Toolbox Talk Done</span></div>
                        </div>
                    </div>

                    @if (viewingPermit.Status == PermitStatus.Closed && !string.IsNullOrEmpty(viewingPermit.ClosureNotes))
                    {
                        <div class="p-3 rounded-3" style="background:#f0fdf4;">
                            <div class="x-small fw-800 text-success mb-1">CLOSURE NOTES</div>
                            <div class="small">@viewingPermit.ClosureNotes</div>
                            <div class="x-small text-slate-400 mt-1">Closed: @viewingPermit.ClosedAt?.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</div>
                        </div>
                    }
                </div>
                <div class="modal-footer border-top-0 px-4 pb-4">
                    <button class="btn btn-light fw-800 px-4" style="border-radius:10px;" @onclick="() => viewingPermit = null">CLOSE</button>
                </div>
            </div>
        </div>
    </div>
}

@* Close/Suspend Permit Modal *@
@if (closingPermit != null)
{
    <div class="modal fade show d-block" style="background-color:rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius:16px;">
                <div class="modal-header border-bottom-0 pt-4 px-4">
                    <h5 class="modal-title fw-800 text-slate-900">Close Permit PTW-@closingPermit.Id.ToString("D4")</h5>
                    <button type="button" class="btn-close" @onclick="() => closingPermit = null"></button>
                </div>
                <div class="modal-body px-4">
                    <p class="small text-slate-500">This will mark the permit as closed. Provide closure notes confirming work is complete and the site has been returned to a safe state.</p>
                    <div class="mb-3">
                        <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Closure Notes *</label>
                        <textarea class="form-control border-0 bg-light fw-600" style="border-radius:10px;min-height:100px;"
                                  @bind="closureNotes" placeholder="e.g. Work completed, LOTO removed, equipment returned to service..."></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-warning fw-800 flex-fill" style="border-radius:10px;" @onclick="() => ClosePermitWithStatus(PermitStatus.Suspended)">SUSPEND</button>
                        <button class="btn btn-danger fw-800 flex-fill" style="border-radius:10px;" @onclick="() => ClosePermitWithStatus(PermitStatus.Closed)" disabled="@isSaving">
                            @if (isSaving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                            CLOSE PERMIT
                        </button>
                    </div>
                </div>
                <div class="modal-footer border-top-0 px-4 pb-3">
                    <button class="btn btn-light fw-800 px-4" style="border-radius:10px;" @onclick="() => closingPermit = null">CANCEL</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<PermitToWork>? permits;
    private List<JobCard> activeJobs = new();
    private PermitToWork newPermit = new();
    private PermitToWork? viewingPermit;
    private PermitToWork? closingPermit;
    private SafetyDashboardStats? stats;
    private bool showCreateModal = false;
    private bool isSaving = false;
    private string? permitError;
    private string closureNotes = "";
    private string statusFilter = "";

    private List<PermitToWork>? FilteredPermits => string.IsNullOrEmpty(statusFilter)
        ? permits
        : permits?.Where(p => p.Status.ToString() == statusFilter).ToList();

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll()
    {
        permits = await SafetyService.GetAllPermitsAsync();
        stats = await SafetyService.GetDashboardStatsAsync();
        var allJobs = await JobCardService.GetAllJobCardsAsync();
        activeJobs = allJobs
            .Where(j => j.Status == JobStatus.Scheduled || j.Status == JobStatus.InProgress)
            .ToList();
    }

    private void OpenCreatePermit()
    {
        newPermit = new PermitToWork();
        permitError = null;
        showCreateModal = true;
    }

    private void OpenViewPermit(PermitToWork permit) => viewingPermit = permit;

    private void OpenClosePermit(PermitToWork permit)
    {
        closingPermit = permit;
        closureNotes = "";
    }

    private async Task IssuePermit()
    {
        permitError = null;
        if (string.IsNullOrWhiteSpace(newPermit.AuthorizedBy))
        {
            permitError = "Authorized By is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(newPermit.WorkScope))
        {
            permitError = "Scope of Work is required.";
            return;
        }

        isSaving = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.Identity?.Name ?? "System";
            if (newPermit.JobCardId == 0) newPermit.JobCardId = (await JobCardService.GetAllJobCardsAsync()).FirstOrDefault()?.Id ?? 0;
            await SafetyService.CreatePermitAsync(newPermit, userId);
            showCreateModal = false;
            await LoadAll();
        }
        finally { isSaving = false; }
    }

    private async Task ClosePermitWithStatus(PermitStatus status)
    {
        if (string.IsNullOrWhiteSpace(closureNotes) && status == PermitStatus.Closed)
        {
            permitError = "Closure notes are required to close a permit.";
            return;
        }
        isSaving = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.Identity?.Name ?? "System";
            await SafetyService.UpdatePermitStatusAsync(closingPermit!.Id, status, closureNotes, userId);
            closingPermit = null;
            await LoadAll();
        }
        finally { isSaving = false; }
    }

    private async Task ReactivatePermit(PermitToWork permit)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Reactivate permit PTW-{permit.Id:D4}?");
        if (confirmed)
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.Identity?.Name ?? "System";
            await SafetyService.UpdatePermitStatusAsync(permit.Id, PermitStatus.Active, "", userId);
            await LoadAll();
        }
    }
}
