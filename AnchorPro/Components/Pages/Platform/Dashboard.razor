@page "/platform"
@using AnchorPro.Components.Layout
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@using AnchorPro.Data
@using Microsoft.EntityFrameworkCore
@using AnchorPro.Data.Entities
@inject ApplicationDbContext Context
@inject AnchorPro.Services.Interfaces.ISubscriptionLifecycleService LifecycleService
@attribute [Authorize(Policy = "PlatformOwner")]

<PageTitle>Platform Dashboard | Anchor Pro</PageTitle>

<div class="container-fluid p-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
        <div>
            <h6 class="text-uppercase text-secondary fw-bold mb-1" style="font-size:0.75rem; letter-spacing:1px;">Platform Command Center</h6>
            <h2 class="fw-bold text-dark mb-0">Overview</h2>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary btn-sm" @onclick="LoadData">
                <i class="bi bi-arrow-clockwise me-1"></i>Refresh
            </button>
            <a href="platform/tenants" class="btn btn-dark btn-sm">
                <i class="bi bi-plus-lg me-1"></i>Provision Tenant
            </a>
        </div>
    </div>

    <!-- KPI Grid -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="text-secondary text-uppercase fw-bold" style="font-size: 0.7rem;">Total Revenue (MRR)</span>
                        <i class="bi bi-currency-dollar text-secondary"></i>
                    </div>
                    <div class="d-flex align-items-baseline">
                        <h3 class="fw-bold mb-0 text-dark me-2">@mrr.ToString("C0")</h3>
                        <span class="text-success small fw-bold"><i class="bi bi-arrow-up"></i> 5%</span>
                    </div>
                    <div class="progress mt-2" style="height: 3px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 75%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="text-secondary text-uppercase fw-bold" style="font-size: 0.7rem;">Active Tenants</span>
                        <i class="bi bi-buildings text-secondary"></i>
                    </div>
                    <div class="d-flex align-items-baseline">
                        <h3 class="fw-bold mb-0 text-dark me-2">@activeTenants</h3>
                        <span class="text-muted small">of @tenantCount total</span>
                    </div>
                     <div class="progress mt-2" style="height: 3px;">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: @(tenantCount > 0 ? (activeTenants * 100 / tenantCount) : 0)%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="text-secondary text-uppercase fw-bold" style="font-size: 0.7rem;">Trialing</span>
                        <i class="bi bi-clock-history text-secondary"></i>
                    </div>
                    <div class="d-flex align-items-baseline">
                        <h3 class="fw-bold mb-0 text-dark me-2">@trialCount</h3>
                        <span class="text-warning small fw-bold">Potential</span>
                    </div>
                     <div class="progress mt-2" style="height: 3px;">
                        <div class="progress-bar bg-warning" role="progressbar" style="width: 30%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="text-secondary text-uppercase fw-bold" style="font-size: 0.7rem;">System Health</span>
                        <i class="bi bi-activity text-secondary"></i>
                    </div>
                    <div class="d-flex align-items-baseline">
                        <h3 class="fw-bold mb-0 text-dark me-2">99.9%</h3>
                        <span class="text-success small fw-bold">Operational</span>
                    </div>
                     <div class="progress mt-2" style="height: 3px;">
                        <div class="progress-bar bg-info" role="progressbar" style="width: 99%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Grid -->
    <div class="row g-3">
        <!-- Center: Tenant & Activity -->
        <div class="col-lg-8">
            <!-- Pending Actions (Priority) -->
            <div class="card border-0 shadow-sm mb-4 border-start border-4 border-warning">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <h5 class="fw-bold text-dark mb-0"><i class="bi bi-exclamation-circle-fill text-warning me-2"></i>Pending Actions</h5>
                         <span class="badge bg-warning text-dark">@(pendingPaymentCount + expiringCount) items</span>
                    </div>
                    <div class="list-group list-group-flush mt-3">
                        @if (pendingPaymentCount > 0)
                        {
                            <a href="platform/payments" class="list-group-item list-group-item-action border-0 d-flex justify-content-between align-items-center bg-light rounded mb-2">
                                <div>
                                    <div class="fw-bold">Approvals: Proof of Payment</div>
                                    <div class="small text-muted">@pendingPaymentCount transactions pending review</div>
                                </div>
                                <button class="btn btn-sm btn-dark">Review</button>
                            </a>
                        }
                        
                         @if (expiringCount > 0)
                         {
                             <a href="platform/tenants" class="list-group-item list-group-item-action border-0 d-flex justify-content-between align-items-center bg-light rounded mb-2">
                                <div>
                                    <div class="fw-bold">Trial Expirations</div>
                                    <div class="small text-muted">@expiringCount tenants expiring in &lt; 3 days</div>
                                </div>
                                <button class="btn btn-sm btn-outline-dark">View</button>
                            </a>
                         }

                         @if (gracePeriodCount > 0)
                         {
                             <a href="platform/tenants" class="list-group-item list-group-item-action border-0 d-flex justify-content-between align-items-center bg-warning bg-opacity-10 rounded mb-2">
                                <div>
                                    <div class="fw-bold text-warning-emphasis">In Grace Period</div>
                                    <div class="small text-muted">@gracePeriodCount tenants at risk of suspension</div>
                                </div>
                                <button class="btn btn-sm btn-warning">View</button>
                            </a>
                         }

                         @if (pendingPaymentCount == 0 && expiringCount == 0 && gracePeriodCount == 0)
                         {
                             <div class="text-center py-3 text-muted">
                                 <i class="bi bi-check-circle text-success me-2"></i> No pending actions. Good job!
                             </div>
                         }
                    </div>
                </div>
            </div>

            <!-- Tenant Snapshot -->
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0 text-dark">Tenant Activity Snapshot</h6>
                    <a href="platform/tenants" class="text-decoration-none small fw-bold">View All</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover table-sm align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-3 text-secondary small fw-bold border-0">COMPANY</th>
                                <th class="text-secondary small fw-bold border-0">PLAN</th>
                                <th class="text-secondary small fw-bold border-0">STATUS</th>
                                <th class="text-end pe-3 text-secondary small fw-bold border-0">...</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (recentTenants.Any())
                            {
                                @foreach (var t in recentTenants)
                                {
                                    <tr>
                                        <td class="ps-3 fw-bold text-dark">@t.Name</td>
                                        <td>
                                            @if(t.IsTrial) { <span class="badge bg-light text-dark border">Trial</span> }
                                            else { <span class="badge bg-light text-dark border">@t.PlanName</span> }
                                        </td>
                                        <td>
                                            @if(t.IsActive) { <span class="badge bg-success bg-opacity-10 text-success px-2 py-1 rounded-pill" style="font-size: 0.7rem;">Active</span> }
                                            else { <span class="badge bg-danger bg-opacity-10 text-danger px-2 py-1 rounded-pill" style="font-size: 0.7rem;">Suspended</span> }
                                        </td>
                                        <td class="text-end pe-3">
                                            <a href="platform/tenants" class="btn btn-link btn-sm text-secondary p-0"><i class="bi bi-chevron-right"></i></a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted small">No recent activity found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right: System & Quick Links -->
        <div class="col-lg-4">
             <!-- System Health -->
             <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white py-3 border-bottom">
                    <h6 class="fw-bold mb-0 text-dark">System Health</h6>
                </div>
                <div class="list-group list-group-flush">
                     <div class="list-group-item d-flex justify-content-between align-items-center px-3 py-2">
                        <div>
                            <span class="d-block small fw-bold">Email Service (SMTP)</span>
                            <span class="d-block small text-muted">Postmark API</span>
                        </div>
                        <i class="bi bi-check-circle-fill text-success"></i>
                    </div>
                     <div class="list-group-item d-flex justify-content-between align-items-center px-3 py-2">
                        <div>
                            <span class="d-block small fw-bold">Database</span>
                            <span class="d-block small text-muted">Azure SQL</span>
                        </div>
                        <i class="bi bi-check-circle-fill text-success"></i>
                    </div>
                     <div class="list-group-item d-flex justify-content-between align-items-center px-3 py-2">
                          <div>
                             <span class="d-block small fw-bold">File Storage</span>
                             <span class="d-block small text-muted">Blob Storage</span>
                         </div>
                         <span class="badge bg-warning text-dark">85% Full</span>
                     </div>
                </div>
            </div>
            
            <!-- Quick Links -->
            <div class="card border-0 shadow-sm">
                 <div class="card-header bg-white py-3 border-bottom">
                    <h6 class="fw-bold mb-0 text-dark">Quick Navigation</h6>
                </div>
                <div class="list-group list-group-flush">
                     <a href="platform/audit" class="list-group-item list-group-item-action px-3 py-3 border-0 d-flex align-items-center">
                        <i class="bi bi-shield-check text-secondary me-3"></i>
                         <div>
                            <div class="fw-bold text-dark small">Security Audit</div>
                            <div class="text-muted" style="font-size: 0.7rem;">View access logs</div>
                        </div>
                    </a>
                    <a href="platform/settings" class="list-group-item list-group-item-action px-3 py-3 border-0 d-flex align-items-center">
                        <i class="bi bi-sliders text-secondary me-3"></i>
                         <div>
                            <div class="fw-bold text-dark small">Global Config</div>
                            <div class="text-muted" style="font-size: 0.7rem;">SMTP, Storage, Defaults</div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int tenantCount = 0;
    private int activeTenants = 0;
    private int trialCount = 0;
    private int pendingPaymentCount = 0;
    private int expiringCount = 0;
    private int gracePeriodCount = 0;
    private int suspendedCount = 0;
    private decimal mrr = 0;
    private List<TenantDashboardModel> recentTenants = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData() 
    {
        Context.IgnoreTenantFilter = true; // Ensure we see all data
        
        tenantCount = await Context.Tenants.CountAsync();
        activeTenants = await Context.Tenants.CountAsync(t => t.IsActive);
        
        // Fetch Subscriptions including Plans
        var subs = await Context.TenantSubscriptions.Include(s => s.SubscriptionPlan).ToListAsync();
        
        mrr = subs.Where(s => s.Status == "Active" && !s.IsTrial).Sum(s => s.SubscriptionPlan?.MonthlyPrice ?? 0);
        trialCount = subs.Count(s => s.IsTrial);
        
        // Pending Payments
        pendingPaymentCount = await Context.PaymentTransactions.CountAsync(p => p.Status == "Pending");
        
        // Get at-risk subscriptions using lifecycle service
        var atRiskSubscriptions = await LifecycleService.GetSubscriptionsRequiringActionAsync();
        
        // Count different types of at-risk subscriptions
        gracePeriodCount = atRiskSubscriptions.Count(s => s.Status == "GracePeriod");
        suspendedCount = atRiskSubscriptions.Count(s => s.Status == "Suspended");
        
        // Expiring Trials (within 3 days)
        var now = DateTime.UtcNow;
        expiringCount = subs.Count(s => 
            s.IsTrial && 
            s.TrialEndDate.HasValue && 
            s.TrialEndDate.Value > now && 
            s.TrialEndDate.Value <= now.AddDays(3)
        );
        
        var rawTenants = await Context.Tenants.OrderByDescending(t => t.CreatedAt).Take(5).ToListAsync();
        recentTenants = rawTenants.Select(t => {
            var sub = subs.FirstOrDefault(s => s.TenantId == t.Id);
            return new TenantDashboardModel {
                Name = t.Name,
                IsActive = t.IsActive,
                IsTrial = sub?.IsTrial ?? false,
                PlanName = sub?.SubscriptionPlan?.Name ?? "No Plan",
                Status = sub?.Status ?? "None"
            };
        }).ToList();
    }

    public class TenantDashboardModel {
        public string Name { get; set; } = "";
        public bool IsActive { get; set; }
        public bool IsTrial { get; set; }
        public string PlanName { get; set; } = "";
        public string Status { get; set; } = "None";
    }
}
