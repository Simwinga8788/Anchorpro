@page "/platform/audit"
@using AnchorPro.Components.Layout
@layout MainLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@using AnchorPro.Data
@using AnchorPro.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Context
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<div class="container-fluid py-4 px-lg-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-5 gap-3">
        <div>
            <div class="text-primary x-small fw-800 text-uppercase mb-1" style="letter-spacing: 0.1em;">SYSTEM INTEGRITY</div>
            <h1 class="fw-800 text-slate-900 mb-0">Audit Protocol</h1>
        </div>
        <button class="btn btn-outline-dark fw-800 w-100 w-md-auto" @onclick="LoadLogs">
            <i class="bi bi-arrow-clockwise me-2"></i>REFRESH LOG
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-slate-500 fw-600">Retrieving security records...</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm overflow-hidden p-0">
            <div class="card-header bg-white py-4 px-4 border-bottom d-flex justify-content-between align-items-center">
                 <div>
                    <h5 class="mb-0 fw-800 text-slate-900">Global Event Stream</h5>
                    <div class="text-slate-500 x-small fw-800 uppercase">Last 50 Critical Operations</div>
                 </div>
                 <span class="badge bg-slate-900 text-white px-3 py-2 fw-800 x-small d-none d-sm-inline-block">LIVE STREAM</span>
            </div>

            <div class="d-none d-md-block table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-slate-50 border-bottom">
                        <tr class="text-slate-500 x-small fw-800 uppercase" style="letter-spacing: 0.05em;">
                            <th class="ps-4 py-3">Timestamp</th>
                            <th>Actor</th>
                            <th>Module</th>
                            <th>Action</th>
                            <th class="pe-4">Change Detail</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in logs)
                        {
                            <tr>
                                <td class="ps-4 py-3 text-slate-400 small fw-600">@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td class="fw-800 text-slate-900 small">@log.ChangedBy</td>
                                <td><span class="badge bg-slate-100 text-slate-700 border x-small fw-800 uppercase">@log.Module</span></td>
                                <td class="small fw-700 text-slate-700">@log.Action</td>
                                <td class="text-slate-500 small text-truncate pe-4" style="max-width: 300px;" title="@FormatChange(log)">
                                    @FormatChange(log)
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Mobile View -->
            <div class="d-md-none p-3">
                @foreach (var log in logs)
                {
                    <div class="p-3 mb-3 border rounded-3 bg-white shadow-sm">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                             <span class="x-small fw-800 text-slate-400">@log.Timestamp.ToString("MM/dd HH:mm:ss")</span>
                             <span class="badge bg-slate-100 text-slate-700 border x-small fw-800 uppercase">@log.Module</span>
                        </div>
                        <div class="fw-800 text-slate-900 mb-1">@log.Action</div>
                        <div class="text-slate-500 x-small fw-600 mb-2">BY: @log.ChangedBy</div>
                        <div class="p-2 bg-light rounded x-small font-monospace text-slate-600 text-break">
                            @FormatChange(log)
                        </div>
                    </div>
                }
            </div>

            @if (!logs.Any() && !isLoading)
            {
                <div class="text-center py-5 text-slate-400">
                    <i class="bi bi-shield-slash display-4 mb-3 opacity-25"></i>
                    <p class="fw-800 uppercase x-small">No audit records identified</p>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<SystemAuditLog> logs = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        isLoading = true;
        // Platform Logs are Global (TenantId is null or we ignore filters to see all)
        logs = await Context.SystemAuditLogs
            .IgnoreQueryFilters()
            .OrderByDescending(l => l.Timestamp)
            .Take(50)
            .ToListAsync();
        isLoading = false;
    }
    
    private string FormatChange(SystemAuditLog log)
    {
        if (!string.IsNullOrEmpty(log.OldValue) || !string.IsNullOrEmpty(log.NewValue))
        {
            return $"{log.OldValue} -> {log.NewValue}";
        }
        return "-";
    }
}
