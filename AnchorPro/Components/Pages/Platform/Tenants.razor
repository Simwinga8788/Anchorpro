@page "/platform/tenants"
@using AnchorPro.Components.Layout
@layout MainLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "PlatformOwner")]
@using AnchorPro.Data
@using AnchorPro.Data.Entities
@using Microsoft.EntityFrameworkCore
@using AnchorPro.Services.Interfaces
@using System.Threading.Tasks
@inject ApplicationDbContext Context
@inject NavigationManager NavigationManager
@inject ICurrentTenantService TenantService
@inject AnchorPro.Services.Interfaces.ISubscriptionLifecycleService LifecycleService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Tenant Governance | Platform Console</PageTitle>

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h6 class="text-uppercase text-muted fw-bold mb-1" style="font-size:0.75rem; letter-spacing:1px;">Governance</h6>
            <h2 class="fw-bold text-slate-800 mb-0">Tenant Registry</h2>
        </div>
        <button class="btn btn-dark" @onclick="ShowProvisionModal">
            <i class="bi bi-plus-lg me-2"></i>New Tenant
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-muted">Loading registry...</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 border-bottom d-flex gap-2 align-items-center">
                <div class="input-group input-group-sm" style="width: 300px;">
                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control bg-light border-start-0" placeholder="Search companies, domains, or IDs..." />
                </div>
                <div class="vr mx-2"></div>
                <select class="form-select form-select-sm w-auto border-light fw-bold text-secondary">
                    <option value="">All Statuses</option>
                    <option value="Active">Active</option>
                    <option value="Trial">Trial</option>
                    <option value="Suspended">Suspended</option>
                </select>
                <div class="ms-auto d-flex gap-2">
                    <button class="btn btn-outline-secondary btn-sm" title="Export CSV"><i class="bi bi-download"></i></button>
                    <button class="btn btn-outline-secondary btn-sm" title="Refresh" @onclick="LoadTenants"><i class="bi bi-arrow-clockwise"></i></button>
                </div>
            </div>
            
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 text-secondary small fw-bold border-0 text-uppercase">Company</th>
                            <th class="text-secondary small fw-bold border-0 text-uppercase">Plan & Billing</th>
                            <th class="text-secondary small fw-bold border-0 text-uppercase">Status</th>
                            <th class="text-secondary small fw-bold border-0 text-uppercase">Activity</th>
                            <th class="text-end pe-4 text-secondary small fw-bold border-0 text-uppercase">Control</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in tenantList)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded bg-light d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; font-weight:bold; color:#64748b;">
                                            @item.Tenant.Name.Substring(0,1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@item.Tenant.Name</div>
                                            <div class="small text-muted font-monospace" style="font-size:0.75rem;">ID: @item.Tenant.Id</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (item.Subscription != null)
                                    {
                                        <div class="d-flex align-items-center mb-1">
                                            <span class="badge bg-light text-dark border me-2">@item.Subscription.SubscriptionPlan?.Name</span>
                                            @if(item.Subscription.IsTrial) {
                                                <span class="badge bg-warning text-dark" style="font-size:0.65rem">TRIAL</span>
                                            }
                                        </div>
                                        <div class="small text-muted">
                                            @(item.Subscription.NextBillingDate?.ToShortDateString() ?? "No renewal")
                                        </div>
                                    } 
                                    else 
                                    {
                                        <span class="text-muted small fst-italic">No active plan</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var subStatus = item.Subscription?.Status ?? "None";
                                        var isSuspended = !item.Tenant.IsActive || subStatus == "Suspended";
                                        var isGracePeriod = subStatus == "GracePeriod";
                                        var isTrial = subStatus == "Trial";
                                    }
                                    
                                    @if (isSuspended)
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger px-2 py-1 rounded-pill">
                                            <i class="bi bi-dash-circle me-1"></i>Suspended
                                        </span>
                                    }
                                    else if (isGracePeriod)
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning px-2 py-1 rounded-pill">
                                            <i class="bi bi-exclamation-triangle me-1"></i>Grace Period
                                        </span>
                                    }
                                    else if (isTrial)
                                    {
                                        <span class="badge bg-info bg-opacity-10 text-info px-2 py-1 rounded-pill">
                                            <i class="bi bi-clock me-1"></i>Trial
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success px-2 py-1 rounded-pill">
                                            <i class="bi bi-check-circle me-1"></i>Active
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="small text-dark fw-bold">12 Users</span>
                                        <span class="small text-muted">Last login: 2m ago</span>
                                    </div>
                                </td>
                                <td class="text-end pe-4">
                                     <div class="dropdown">
                                        <button class="btn btn-sm btn-light border" type="button" @onclick="() => ToggleMenu(item.Tenant.Id)">
                                            <i class="bi bi-three-dots"></i>
                                        </button>
                                        @if (activeMenuId == item.Tenant.Id)
                                        {
                                            <div class="dropdown-menu show shadow border-0" style="position: absolute; right: 0; z-index: 1050; min-width: 200px;">
                                                <h6 class="dropdown-header text-uppercase small fw-bold">Governance</h6>
                                                
                                                @if (item.Tenant.IsActive)
                                                {
                                                     <button class="dropdown-item text-danger" @onclick="() => ToggleSuspension(item.Tenant, false)">
                                                        <i class="bi bi-pause-circle me-2"></i>Suspend Access
                                                    </button>
                                                }
                                                else
                                                {
                                                     <button class="dropdown-item text-success" @onclick="() => ToggleSuspension(item.Tenant, true)">
                                                        <i class="bi bi-play-circle-fill me-2"></i>Reactivate
                                                    </button>
                                                }
                                                <button class="dropdown-item" @onclick="() => ManageTenant(item.Tenant.Id)">
                                                    <i class="bi bi-pencil me-2"></i>Edit Profile
                                                </button>
                                                
                                                @if (item.Subscription?.IsTrial == true)
                                                {
                                                    <button class="dropdown-item text-primary" @onclick="() => ConvertTrialToPaid(item.Tenant)">
                                                        <i class="bi bi-arrow-up-circle me-2"></i>Convert to Paid
                                                    </button>
                                                }
                                                
                                                <div class="dropdown-divider"></div>
                                                
                                                <button class="dropdown-item text-dark fw-bold" @onclick="() => LoginAsAdmin(item.Tenant.Id)">
                                                    <i class="bi bi-box-arrow-in-right me-2"></i>Login as Admin
                                                </button>

                                                <button class="dropdown-item" @onclick="() => {}">
                                                    <i class="bi bi-clock-history me-2"></i>View Audit Log
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
             <div class="card-footer bg-white py-3 border-top">
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted">Showing @tenantList.Count environments</small>
                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
                            <li class="page-item active"><a class="page-link" href="#">1</a></li>
                            <li class="page-item"><a class="page-link" href="#">Next</a></li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<TenantViewModel> tenantList = new();
    private int? activeMenuId = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadTenants();
    }

    private async Task LoadTenants()
    {
        isLoading = true;
        // Simulate delay for "Loading..."
        await Task.Delay(500);

        var tenants = await Context.Tenants.OrderByDescending(t => t.CreatedAt).ToListAsync();
        var subs = await Context.TenantSubscriptions.Include(s => s.SubscriptionPlan).ToListAsync();
        
        tenantList = tenants.Select(t => new TenantViewModel
        {
            Tenant = t,
            Subscription = subs.FirstOrDefault(s => s.TenantId == t.Id)
        }).ToList();

        isLoading = false;
    }

    private void ToggleMenu(int id)
    {
        if (activeMenuId == id) activeMenuId = null;
        else activeMenuId = id;
    }

    private async Task ToggleSuspension(Tenant tenant, bool activate)
    {
        try
        {
            // Get current user ID for audit trail
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.Identity?.Name;

            // Update tenant status
            var dbTenant = await Context.Tenants.FindAsync(tenant.Id);
            if (dbTenant == null) return;

            dbTenant.IsActive = activate;
            dbTenant.UpdatedAt = DateTime.UtcNow;
            dbTenant.UpdatedBy = userId;

            // Update subscription status using lifecycle service
            var subscription = await Context.TenantSubscriptions
                .FirstOrDefaultAsync(s => s.TenantId == tenant.Id);

            if (subscription != null)
            {
                if (activate)
                {
                    // Reactivate subscription
                    await LifecycleService.ReactivateSubscriptionAsync(
                        subscription.Id, 
                        userId, 
                        "Manually reactivated by platform owner"
                    );
                }
                else
                {
                    // Suspend subscription
                    await LifecycleService.SuspendSubscriptionAsync(
                        subscription.Id, 
                        "ManualSuspension", 
                        userId
                    );
                }
            }

            await Context.SaveChangesAsync();
            await LoadTenants();
            activeMenuId = null;
        }
        catch (Exception ex)
        {
            // Log error (in production, use proper logging)
            Console.WriteLine($"Error toggling suspension: {ex.Message}");
        }
    }



    private async Task ConvertTrialToPaid(Tenant tenant)
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.Identity?.Name;

            var subscription = await Context.TenantSubscriptions.FirstOrDefaultAsync(s => s.TenantId == tenant.Id);
            if (subscription != null && subscription.IsTrial)
            {
                // Find "Professional" plan or default to logic's ID
                var proPlan = await Context.SubscriptionPlans.FirstOrDefaultAsync(p => p.Name == "Professional");
                int newPlanId = proPlan?.Id ?? 2; // Default to 2 if not found

                await LifecycleService.ConvertTrialToPaidAsync(subscription.Id, newPlanId);
                
                // Add note to audit log (conceptually)
                // For now just refresh
                await LoadTenants();
                activeMenuId = null;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error converting trial: {ex.Message}");
        }
    }

    private void LoginAsAdmin(int tenantId)
    {
        NavigationManager.NavigateTo($"/api/admin-access/login-as/{tenantId}", forceLoad: true);
    }

    private void ShowProvisionModal() { }
    private void ManageTenant(int id) { }

    public class TenantViewModel
    {
        public Tenant Tenant { get; set; } = new();
        public TenantSubscription? Subscription { get; set; }
    }
}
