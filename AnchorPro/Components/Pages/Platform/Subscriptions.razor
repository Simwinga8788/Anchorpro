@page "/platform/subscriptions"
@using AnchorPro.Components.Layout
@layout MainLayout
@using AnchorPro.Data
@using AnchorPro.Data.Entities
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Context
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<div class="p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">Subscription Lifecycle</h3>
            <p class="text-muted small mb-0">Monitor recurring revenue, trial expirations, and renewals.</p>
        </div>
        <div>
             <span class="badge bg-success p-2 fs-6 me-2">MRR: @mrr.ToString("C0")</span>
             <span class="badge bg-warning text-dark p-2 fs-6">Trials: @trialCount</span>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Subscriber</th>
                            <th>Plan</th>
                            <th>Value</th>
                            <th>Billing Cycle</th>
                            <th>Status Detail</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sub in subscriptions) {
                            <tr>
                                <td class="ps-4 fw-bold">@sub.Tenant?.Name</td>
                                <td><span class="badge bg-light text-dark border">@sub.SubscriptionPlan?.Name</span></td>
                                <td class="font-monospace">@(sub.SubscriptionPlan?.MonthlyPrice.ToString("C0") ?? "-")</td>
                                <td>
                                    <div class="small">
                                        Last: @(sub.LastPaymentDate?.ToShortDateString() ?? "-")
                                        <br>
                                        <span class="text-muted">Next: @(sub.NextBillingDate?.ToShortDateString() ?? "-")</span>
                                    </div>
                                </td>
                                <td>
                                    @if(sub.IsTrial) {
                                        <span class="text-warning fw-bold"><i class="bi bi-clock-history me-1"></i>Trial ends @sub.TrialEndDate?.ToShortDateString()</span>
                                    } else {
                                        <span class="text-success"><i class="bi bi-check-circle me-1"></i>Active</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-secondary" disabled title="Manage Subscription (Coming Soon)">
                                        Manage
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    List<TenantSubscription> subscriptions = new();
    decimal mrr = 0;
    int trialCount = 0;

    protected override async Task OnInitializedAsync() {
        subscriptions = await Context.TenantSubscriptions
            .Include(s => s.Tenant)
            .Include(s => s.SubscriptionPlan)
            .OrderByDescending(s => s.NextBillingDate)
            .ToListAsync();
        
        mrr = subscriptions.Where(s => !s.IsTrial && s.Status == "Active").Sum(s => s.SubscriptionPlan?.MonthlyPrice ?? 0);
        trialCount = subscriptions.Count(s => s.IsTrial);
    }
}
