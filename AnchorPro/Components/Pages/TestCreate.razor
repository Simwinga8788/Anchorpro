@page "/test-create"
@rendermode InteractiveServer
@using AnchorPro.Data.Entities
@using AnchorPro.Data.Enums
@using AnchorPro.Services.Interfaces
@inject IJobCardService JobCardService
@inject NavigationManager NavigationManager

<h1>Test Job Card Creation</h1>

<div class="card p-4">
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-info">@message</div>
    }

    <button class="btn btn-primary" @onclick="CreateTestJob" disabled="@isCreating">
        @if (isCreating)
        {
            <span class="spinner-border spinner-border-sm me-2"></span>
        }
        Create Test Job
    </button>
</div>

@code {
    private bool isCreating = false;
    private string message = "";

    private async Task CreateTestJob()
    {
        isCreating = true;
        message = "Starting...";
        StateHasChanged();

        try
        {
            message = "Creating job card object...";
            StateHasChanged();

            var jobCard = new JobCard
            {
                JobNumber = $"TEST-{DateTime.UtcNow:yyyyMMddHHmmss}",
                EquipmentId = 1, // Assuming first equipment exists
                JobTypeId = 1, // Assuming first job type exists
                Description = "Test job card created at " + DateTime.Now,
                Priority = JobPriority.Normal,
                Status = JobStatus.Unscheduled,
                CreatedAt = DateTime.UtcNow,
                CreatedBy = "TestUser"
            };

            message = "Calling CreateJobCardAsync...";
            StateHasChanged();
            await Task.Delay(100);

            await JobCardService.CreateJobCardAsync(jobCard, "TestUser");

            message = "SUCCESS! Job card created. Redirecting...";
            StateHasChanged();
            await Task.Delay(2000);

            NavigationManager.NavigateTo("/job-cards");
        }
        catch (Exception ex)
        {
            message = $"ERROR: {ex.Message}\n\nStack: {ex.StackTrace}";
        }
        finally
        {
            isCreating = false;
            StateHasChanged();
        }
    }
}
