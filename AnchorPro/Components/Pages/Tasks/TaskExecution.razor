@page "/my-tasks/{JobId:int}"
@using Microsoft.AspNetCore.Authorization
@using AnchorPro.Data.Entities
@using AnchorPro.Data.Enums
@using AnchorPro.Services.Interfaces
@using System.Security.Claims
@inject IJobCardService JobCardService
@inject IJobTaskService JobTaskService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject IInventoryService InventoryService
@inject IFileService FileService
@inject IDowntimeService DowntimeService
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-black mb-0">Technician Execution Console</h2>
    <div class="d-flex gap-2 align-items-center">
         <span class="small fw-bold text-uppercase me-2 text-muted">@currentUserName</span>
         <button class="btn btn-premium-ghost btn-sm" @onclick="@(() => NavigationManager.NavigateTo("/job-cards/" + JobId))">
            <i class="bi bi-arrow-left me-1"></i> VIEW SUMMARY
         </button>
    </div>
</div>

@if (job == null)
{
    <div class="d-flex justify-content-center p-5">
        <div class="spinner-border text-success" role="status"></div>
    </div>
}
else
{
    <div class="row g-4 h-100">
        <!-- LEFT: Task List -->
        <div class="col-lg-7">
            <div class="card h-100 border-0 shadow-sm p-4">
                <div class="mb-4 bg-light p-3 rounded-3 border-left-active">
                     <div class="fw-bold text-black fs-5">#@job.JobNumber</div>
                     <div class="text-muted small">@job.JobType?.Name</div>
                     <div class="text-secondary small mt-1">@job.Description</div>
                </div>

                <div class="d-flex align-items-center mb-3">
                    <div class="p-2 rounded bg-success text-white me-2 d-flex justify-content-center align-items-center" style="width:24px;height:24px;">
                        <i class="bi bi-check-lg small"></i>
                    </div> 
                    <span class="fw-bold text-black">Traceable Checklist</span>
                </div>

                <div class="d-grid gap-3">
                    @if(!job.JobTasks.Any()) { <div class="text-muted small ps-4">No tasks defined.</div> }
                    
                    @foreach(var task in job.JobTasks) 
                    {
                        <div class="d-flex align-items-center p-3 rounded-3 @(task.IsCompleted ? "bg-light opacity-75" : "bg-white border")" 
                             style="transition: all 0.2s;">
                             
                            <div class="me-3">
                                 <input type="checkbox" class="form-check-input p-2" 
                                        style="cursor:pointer; width: 24px; height: 24px; border-radius: 6px; @(task.IsCompleted ? "background-color: var(--color-accent-primary); border-color: var(--color-accent-primary);" : "")"
                                        checked="@task.IsCompleted" 
                                        @onchange="@(e => ToggleTask(task, (bool)e.Value))"
                                        disabled="@(job.Status != JobStatus.InProgress)" />
                            </div>
                            
                            <div class="flex-grow-1">
                                <span class="fw-bold text-black @(task.IsCompleted ? "text-decoration-line-through text-muted" : "")">
                                    @task.Name
                                </span>
                            </div>
                            
                            @if(task.IsCompleted) {
                                <i class="bi bi-check-circle-fill text-success fs-5"></i>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- RIGHT: Job Actions -->
        <div class="col-lg-5">
            <div class="card h-100 border-0 shadow-sm p-4 d-flex flex-column">
                 <div class="d-flex justify-content-between align-items-start mb-4">
                     <div>
                         <div class="text-muted small text-uppercase fw-bold mb-1">Current Job</div>
                         <h4 class="fw-bold text-black mb-0">#@job.JobNumber</h4>
                         <div class="fs-5 text-secondary">Maintenance</div>
                     </div>
                     <span class="status-badge @GetStatusClass(job.Status)">@job.Status</span>
                 </div>
                 
                     <div class="p-3 bg-light rounded-3 mb-3">
                         <div class="text-muted x-small text-uppercase fw-bold mb-1">Equipment</div>
                         <div class="fw-bold text-black">@job.Equipment?.Name</div>
                     </div>

                 <!-- Parts Usage Section -->
                 <div class="border-top pt-3 mb-3">
                     <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-800 text-slate-900 small uppercase mb-0">Spare Parts & Consumables</h6>
                        @if(job.Status == JobStatus.InProgress) {
                            <button class="btn btn-premium-ghost btn-sm px-3 fw-800" @onclick="OpenPartsModal">
                                <i class="bi bi-plus-lg me-1"></i> ADD PART
                            </button>
                        }
                     </div>
                     
                     @if(job.JobCardParts != null && job.JobCardParts.Any())
                     {
                         <div class="bg-light rounded-3 p-2">
                             <ul class="list-group list-group-flush small bg-transparent">
                                 @foreach(var part in job.JobCardParts)
                                 {
                                     <li class="list-group-item px-2 py-2 d-flex justify-content-between align-items-center bg-transparent border-0 border-bottom-dashed">
                                         <div>
                                             <div class="fw-800 text-slate-900">@part.InventoryItem?.Name</div>
                                             <div class="text-slate-500 x-small fw-700">Quantity: @part.QuantityUsed</div>
                                         </div>
                                         @if(job.Status == JobStatus.InProgress) {
                                             <button class="btn btn-link link-danger p-0" @onclick="() => RemovePart(part.Id)">
                                                 <i class="bi bi-trash small"></i>
                                             </button>
                                         }
                                     </li>
                                 }
                             </ul>
                         </div>
                     }
                     else
                     {
                         <div class="text-center py-3 text-slate-400 italic x-small bg-slate-50 rounded-3 border-dashed">
                             No parts attributed to this console yet.
                         </div>
                     }
                 </div>

                 <!-- Attachments Section -->
                 <div class="border-top pt-3 mb-3">
                     <h6 class="fw-bold mb-3">Photos & Attachments</h6>
                     
                     @if(job.JobAttachments != null && job.JobAttachments.Any())
                     {
                         <div class="d-flex flex-wrap gap-2 mb-3">
                             @foreach(var att in job.JobAttachments)
                             {
                                 <div class="position-relative border rounded p-1" style="width: 60px; height: 60px;">
                                     <a href="@att.FilePath" target="_blank" class="d-block w-100 h-100 d-flex justify-content-center align-items-center text-decoration-none bg-light text-secondary">
                                         @if(att.ContentType.StartsWith("image/")) {
                                             <img src="@att.FilePath" class="w-100 h-100 object-fit-cover rounded" />
                                         }
                                         else {
                                             <i class="bi bi-file-earmark fs-3"></i>
                                         }
                                     </a>
                                     <button class="btn btn-danger btn-sm position-absolute top-0 start-100 translate-middle p-0 rounded-circle" 
                                             style="width: 20px; height: 20px; font-size: 10px;"
                                             @onclick="() => DeleteAttachment(att)">
                                         <i class="bi bi-x"></i>
                                     </button>
                                 </div>
                             }
                         </div>
                     }
                     
                     @if(job.Status == JobStatus.InProgress) {
                         <div class="d-grid">
                            <label class="btn btn-outline-secondary btn-sm d-flex align-items-center justify-content-center gap-2 cursor-pointer">
                                <i class="bi bi-camera"></i> Upload Photo/File
                                <InputFile OnChange="HandleFileUpload" class="d-none" />
                            </label>
                         </div>
                     }
                 </div>

                 <div class="d-grid gap-3 mt-4">
                     @if (!string.IsNullOrEmpty(errorMessage)) {
                        <div class="alert alert-danger px-3 py-2 small mb-0 fw-bold">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>@errorMessage
                        </div>
                     }
                     @if (job.Status == JobStatus.Scheduled || job.Status == JobStatus.Unscheduled) {
                        <button class="btn btn-primary py-3 fs-6" @onclick="InitiateStartJob">
                            START WORK ORDER
                        </button>
                     }
                     else if (job.Status == JobStatus.InProgress) {
                          <button class="btn btn-primary py-3 fs-6" @onclick="CompleteJob">
                              <i class="bi bi-check-circle me-2"></i>COMPLETE JOB
                          </button>
                          <button class="btn btn-warning py-3 fs-6 fw-bold" @onclick="PauseJob" style="border-radius: 8px;">
                              <i class="bi bi-exclamation-triangle-fill me-2"></i>REPORT DELAY / BREAKDOWN
                          </button>
                     }
                     else if (job.Status == JobStatus.OnHold) {
                          <div class="alert alert-warning text-center fw-800 mb-2">
                              <i class="bi bi-pause-fill me-2"></i>JOB PAUSED
                          </div>
                          <button class="btn btn-success py-3 fs-6 fw-bold" @onclick="ResumeJob" style="border-radius: 8px;">
                              <i class="bi bi-play-circle me-2"></i>RESUME WORK
                          </button>
                     }
                     else {
                          <div class="alert alert-secondary text-center">Job Completed</div>
                     }
                 </div>
            </div>
        </div>
    </div>
}

<style>
    .border-left-active { border-left: 4px solid var(--color-accent-primary); }
</style>

@code {
    [Parameter]
    public int JobId { get; set; }
    private JobCard? job;
    private string? currentUserId;
    private string currentUserName = "Technician";

    private string? errorMessage;
    private List<InventoryItem> allParts = new();
    private int selectedPartId;
    private int selectedPartQty = 1;
    private bool showPartsModal = false;

    // Load available parts on init
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "MVP-User";
        currentUserName = authState.User.Identity?.Name ?? "Technician";
        await LoadJob();
        allParts = await InventoryService.GetAllItemsAsync();
    }

    private async Task LoadJob()
    {
        job = await JobCardService.GetJobCardByIdAsync(JobId);
    }

    private async Task ToggleTask(JobTask task, bool completed) {
        if (job.Status != JobStatus.InProgress) return;
        task.IsCompleted = completed;
        if (completed) await JobTaskService.CompleteTaskAsync(task.Id, currentUserId);
        else await JobTaskService.UpdateTaskAsync(task, currentUserId);
    }

    private async Task StartJob() {
         // Assign current user as technician if not already assigned
         if (string.IsNullOrEmpty(job.AssignedTechnicianId))
         {
             await JobCardService.AssignTechnicianAsync(job.Id, currentUserId);
         }
         
         await JobCardService.UpdateJobStatusAsync(job.Id, JobStatus.InProgress, currentUserId);
         await LoadJob();
    }
    
    private async Task CompleteJob() {
        try {
             errorMessage = null;
             await JobCardService.UpdateJobStatusAsync(job.Id, JobStatus.Completed, currentUserId);
             NavigationManager.NavigateTo("/my-tasks");
        } catch (InvalidOperationException ex) {
             errorMessage = ex.Message;
        } catch (Exception ex) {
             errorMessage = $"An unexpected error occurred: {ex.Message}";
             Console.WriteLine(ex); // Log to server console too
        }
    }

    private bool showDowntimeModal = false;
    private DowntimeEntry newDowntime = new() { DowntimeCategoryId = 1 }; // Default
    private string downtimeType = "Equipment Breakdown"; // Default selection

    private async Task PauseJob() {
        // Open Modal instead of immediate pause
        newDowntime = new DowntimeEntry { StartTime = DateTime.UtcNow };
        showDowntimeModal = true;
    }

    private void CancelPause() {
        showDowntimeModal = false;
    }

    private async Task ConfirmPause() {
        // Automatic Timer Start with Details
        var taskToLink = job.JobTasks.FirstOrDefault()?.Id ?? 0;
        
        if (taskToLink > 0)
        {
            var entry = new DowntimeEntry
            {
                JobTaskId = taskToLink,
                DowntimeCategoryId = 1, 
                StartTime = DateTime.UtcNow,
                Notes = $"{newDowntime.Notes} (Type: {downtimeType})"
            };
            await DowntimeService.CreateDowntimeEntryAsync(entry, currentUserId);
        }

        await JobCardService.UpdateJobStatusAsync(job.Id, JobStatus.OnHold, currentUserId);
        showDowntimeModal = false;
        await LoadJob();
    }

    private async Task ResumeJob() {
        // Automatic Timer Stop
        var taskToLink = job.JobTasks.FirstOrDefault()?.Id ?? 0;
        if (taskToLink > 0)
        {
            var downtimes = await DowntimeService.GetDowntimeForTaskAsync(taskToLink);
            var active = downtimes.FirstOrDefault(d => d.EndTime == null);
            
            if (active != null)
            {
                active.EndTime = DateTime.UtcNow;
                active.DurationMinutes = (int)(active.EndTime.Value - active.StartTime).TotalMinutes;
                await DowntimeService.UpdateDowntimeEntryAsync(active, currentUserId);
            }
        }

        await JobCardService.UpdateJobStatusAsync(job.Id, JobStatus.InProgress, currentUserId);
        await LoadJob();
    }

    private void ReportDelay() {
        _ = PauseJob();
    }
    
    // ... existing helpers ...
    private string GetStatusClass(JobStatus s) => s.ToString() switch {
        "InProgress" => "in-progress",
        "Completed" => "completed",
        "Scheduled" => "scheduled",
        "OnHold" => "on-hold",
        _ => "raw"
    };

    private void OpenPartsModal()
    {
        if (allParts.Any()) selectedPartId = allParts.First().Id;
        selectedPartQty = 1;
        showPartsModal = true;
    }

    private async Task AddPart()
    {
        if(selectedPartId > 0 && selectedPartQty > 0)
        {
            await JobCardService.AddPartToJobAsync(job.Id, selectedPartId, selectedPartQty, currentUserId);
            showPartsModal = false;
            await LoadJob();
        }
    }

    private async Task RemovePart(int jobCardPartId)
    {
        await JobCardService.RemovePartFromJobAsync(jobCardPartId);
        await LoadJob();
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        try
        {
            if (e.FileCount > 0)
            {
                var file = e.File;
                var fileUrl = await FileService.SaveFileAsync(file, "jobs");
                
                var attachment = new JobAttachment
                {
                    JobCardId = job.Id,
                    FileName = file.Name,
                    FilePath = fileUrl,
                    ContentType = file.ContentType,
                    FileSizeBytes = file.Size,
                    CreatedAt = DateTime.UtcNow,
                    CreatedBy = currentUserId
                };

                await JobCardService.AddAttachmentAsync(attachment);
                await LoadJob();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Upload failed: {ex.Message}";
        }
    }

    private async Task DeleteAttachment(JobAttachment att)
    {
        try
        {
            await JobCardService.RemoveAttachmentAsync(att.Id);
            FileService.DeleteFile(att.FilePath);
            await LoadJob();
        }
        catch (Exception ex)
        {
            errorMessage = $"Delete failed: {ex.Message}";
        }
    }

    private bool showPermitModal = false;
    private PermitToWork newPermit = new();
    
    private void InitiateStartJob()
    {
        if (job.PermitToWork != null)
        {
            StartJob();
        }
        else
        {
            newPermit = new PermitToWork 
            { 
                JobCardId = job.Id,
                AuthorizedBy = currentUserName
            };
            showPermitModal = true;
        }
    }

    private bool IsPermitValid => 
        !string.IsNullOrWhiteSpace(newPermit.AuthorizedBy) &&
        newPermit.IsIsolated && 
        newPermit.IsLotoApplied && 
        newPermit.IsAreaSecure && 
        newPermit.IsPpeChecked;

    private async Task SubmitPermit()
    {
        try
        {
            newPermit.AuthorizedAt = DateTime.UtcNow;
            await JobCardService.CreatePermitAsync(newPermit);
            showPermitModal = false;
            await StartJob();
        }
        catch (Exception ex)
        {
            errorMessage = $"Permit Error: {ex.Message}";
        }
    }
}

@if (showPartsModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Add Part to Job</h5>
                    <button type="button" class="btn-close" @onclick="() => showPartsModal = false"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Select Part</label>
                        <select class="form-select" @bind="selectedPartId">
                            @foreach(var part in allParts)
                            {
                                <option value="@part.Id">@part.Name (Stock: @part.QuantityOnHand)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Quantity Used</label>
                        <input type="number" class="form-control" @bind="selectedPartQty" min="1" max="100" />
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button class="btn btn-secondary" @onclick="() => showPartsModal = false">Cancel</button>
                        <button class="btn btn-primary" @onclick="AddPart">Add Spare Part</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (showDowntimeModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-warning text-dark border-0">
                    <h5 class="modal-title fw-800">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>REPORT OPERATIONAL DELAY
                    </h5>
                    <button type="button" class="btn-close" @onclick="CancelPause"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-4">
                        <label class="form-label fw-800 small text-slate-500 uppercase">Delay Category</label>
                        <select class="form-select border-2" @bind="downtimeType" style="border-radius: 10px;">
                            <option value="Equipment Breakdown">Equipment Breakdown</option>
                            <option value="Material Shortage">Spare Parts Shortage</option>
                            <option value="Process Delay">Wait for Work Area / Permit</option>
                            <option value="Staffing Issue">Personnel / Safety Wait</option>
                            <option value="Other">Other Operational Delay</option>
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-800 small text-slate-500 uppercase">Observations / Notes</label>
                        <textarea class="form-control border-2" rows="3" @bind="newDowntime.Notes" 
                                placeholder="Describe the symptom or reason for the delay..." style="border-radius: 10px;"></textarea>
                    </div>
                    <div class="p-3 rounded-3 bg-warning bg-opacity-10 border border-warning border-opacity-25 d-flex align-items-center mb-0">
                        <div class="me-3 fs-4 text-warning">
                            <i class="bi bi-info-circle-fill"></i>
                        </div>
                        <div class="text-slate-700 small fw-600">
                            Confirming will <span class="fw-800 text-warning">Pause the Job Timer</span> and start tracking this downtime event for MTBF/MTTR metrics.
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4">
                    <button class="btn btn-premium-ghost px-4" @onclick="CancelPause">CANCEL</button>
                    <button class="btn btn-warning px-5 fw-800" @onclick="ConfirmPause">CONFIRM & START DELAY</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showPermitModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-shield-check me-2"></i>Permit to Work (Safety Check)
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showPermitModal = false"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="alert alert-warning mb-4 d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill fs-3 me-3"></i>
                        <span class="small fw-bold">Safety is our #1 priority. You must confirm the following before starting work.</span>
                    </div>

                    <div class="d-grid gap-3 mb-4">
                         <div class="form-check form-switch p-3 bg-light rounded d-flex justify-content-between align-items-center ps-5">
                             <label class="form-check-label fw-bold" for="check1">Is the equipment isolated?</label>
                             <input class="form-check-input" type="checkbox" id="check1" @bind="newPermit.IsIsolated" />
                         </div>
                         <div class="form-check form-switch p-3 bg-light rounded d-flex justify-content-between align-items-center ps-5">
                             <label class="form-check-label fw-bold" for="check2">Is Lock-Out / Tag-Out applied?</label>
                             <input class="form-check-input" type="checkbox" id="check2" @bind="newPermit.IsLotoApplied" />
                         </div>
                         <div class="form-check form-switch p-3 bg-light rounded d-flex justify-content-between align-items-center ps-5">
                             <label class="form-check-label fw-bold" for="check3">Is the work area secure?</label>
                             <input class="form-check-input" type="checkbox" id="check3" @bind="newPermit.IsAreaSecure" />
                         </div>
                         <div class="form-check form-switch p-3 bg-light rounded d-flex justify-content-between align-items-center ps-5">
                             <label class="form-check-label fw-bold" for="check4">Is all PPE worn and checked?</label>
                             <input class="form-check-input" type="checkbox" id="check4" @bind="newPermit.IsPpeChecked" />
                         </div>
                    </div>
                    
                    <div class="mb-3">
                         <label class="form-label fw-bold small text-secondary">Hazards Identified (Optional)</label>
                         <input type="text" class="form-control" @bind="newPermit.HazardsIdentified" placeholder="e.g. Slippery floor, High voltage nearby" />
                    </div>

                    <div class="mb-3">
                         <label class="form-label fw-bold small text-secondary">Authorized By (Digital Signature)</label>
                         <input type="text" class="form-control" @bind="newPermit.AuthorizedBy" placeholder="Enter your full name" />
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light">
                    <button class="btn btn-secondary" @onclick="() => showPermitModal = false">Cancel</button>
                    <button class="btn btn-success px-4" @onclick="SubmitPermit" disabled="@(!IsPermitValid)">
                        <i class="bi bi-check-lg me-2"></i>Confirm & Start Job
                    </button>
                </div>
            </div>
        </div>
    </div>
}
