@page "/my-tasks"
@using Microsoft.AspNetCore.Authorization
@using AnchorPro.Data.Entities
@using AnchorPro.Data.Enums
@using AnchorPro.Services.Interfaces
@using System.Security.Claims
@inject IJobCardService JobCardService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>My Tasks</PageTitle>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-5 gap-3">
    <div>
        <h1 class="text-slate-900 mb-0 fw-800">My Assigned Tasks</h1>
        <div class="text-slate-500 x-small fw-800 text-uppercase" style="letter-spacing: 0.05em;">TRACKING YOUR DAILY OPERATIONS</div>
    </div>
    <button class="btn btn-outline-secondary fw-800 w-100 w-md-auto" @onclick="LoadTasks">
        <i class="bi bi-arrow-clockwise me-1"></i>REFRESH
    </button>
</div>

@if (isLoading)
{
    <div class="d-flex justify-content-center p-5">
        <div class="spinner-border text-success" role="status"></div>
    </div>
}
else if (!myJobs.Any())
{
    <div class="card p-5 text-center bg-light border-0">
        <div class="h4 text-muted fw-bold">No Tasks Assigned</div>
        <p class="text-secondary">You currently have no jobs assigned to you. Enjoy your break!</p>
    </div>
}
else
{
    <div class="row g-3 g-md-4">
        @foreach (var job in myJobs)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm p-4 d-flex flex-column hover-shadow-md transition-all">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <span class="badge @GetStatusBadgeClass(job.Status) x-small fw-800">@job.Status.ToString().ToUpper()</span>
                        <span class="text-slate-400 x-small fw-800">#@job.JobNumber</span>
                    </div>
                    
                    <h5 class="fw-800 text-slate-900 mb-2">@job.JobType?.Name</h5>
                    <div class="text-slate-500 x-small mb-4 flex-grow-1">
                        <div class="d-flex align-items-center mb-2">
                             <i class="bi bi-gear-fill me-2 text-primary"></i>
                             <span class="fw-800">@job.Equipment?.Name</span>
                        </div>
                        <span class="d-block text-truncate-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; white-space: normal;">
                            @job.Description
                        </span>
                    </div>
                    
                    <div class="mt-auto">
                        <button class="btn btn-primary w-100 py-3 py-md-2 fw-800" @onclick="() => OpenJob(job.Id)">
                            @(job.Status == JobStatus.InProgress ? "CONTINUE OPERATION" : "VIEW DETAILS")
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<JobCard> myJobs = new();
    private bool isLoading = true;
    private string? currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        isLoading = true;
        
        if(currentUserId != null) {
            myJobs = await JobCardService.GetJobCardsByTechnicianAsync(currentUserId);
        }
        else {
            // MVP Mode: Load all active jobs if not logged in
            var all = await JobCardService.GetAllJobCardsAsync();
            myJobs = all.Where(j => j.Status != JobStatus.Completed && j.Status != JobStatus.Cancelled).ToList();
        }
        
        isLoading = false;
    }

    private void OpenJob(int id)
    {
        NavigationManager.NavigateTo($"/my-tasks/{id}");
    }

    private string GetStatusBadgeClass(JobStatus s) => s.ToString() switch {
        "InProgress" => "bg-warning text-dark",
        "Completed" => "bg-success",
        "Scheduled" => "bg-info",
        _ => "bg-slate-200 text-slate-700"
    };
}
