@using AnchorPro.Components.Shared
<div class="d-flex flex-column align-items-center justify-content-center py-5 text-center">
    <div class="blueprint-ring mb-4">
        <i class="bi @Icon fs-1"></i>
    </div>
    <h2 class="fw-800 text-slate-900 mb-2">@ModuleName Module</h2>
    <p class="text-slate-500 max-w-400 mx-auto">This module is currently being configured for your Mini-ERP environment. Enterprise-grade @ModuleName tracking will be available soon.</p>
    
    <div class="mt-4 d-flex gap-3">
        <div class="badge-premium info">PLANNED</div>
        <div class="badge-premium slate">V1.2 RELEASE</div>
    </div>
</div>

<style>
    .blueprint-ring {
        width: 100px;
        height: 100px;
        border: 2px dashed #E2E8F0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--ap-primary);
        background: #F8FAFC;
    }
    .max-w-400 { max-width: 400px; }
</style>

@code {
    [Parameter] public string ModuleName { get; set; } = "";
    [Parameter] public string Icon { get; set; } = "bi-boxes";
}
