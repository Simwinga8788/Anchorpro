@using AnchorPro.Services.Interfaces
@inject ISubscriptionService SubscriptionService
@inject NavigationManager NavigationManager

@if (showAlert)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <div class="d-flex align-items-center">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <div class="flex-grow-1">
                <strong>@Title</strong>
                <p class="mb-0 small">@Message</p>
            </div>
            <button type="button" class="btn btn-sm btn-dark me-2" @onclick="NavigateToBilling">
                Upgrade Plan
            </button>
            <button type="button" class="btn-close" @onclick="() => showAlert = false"></button>
        </div>
    </div>
}

@code {
    [Parameter] public string Title { get; set; } = "Plan Limit Reached";
    [Parameter] public string Message { get; set; } = "You've reached your subscription limit.";
    [Parameter] public bool Show { get; set; } = true;

    private bool showAlert = true;

    protected override void OnParametersSet()
    {
        showAlert = Show;
    }

    private void NavigateToBilling()
    {
        NavigationManager.NavigateTo("/billing");
    }
}
