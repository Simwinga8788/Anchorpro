@inherits LayoutComponentBase

<main class="auth-layout">
    <div class="auth-grid">
        <div class="auth-brand-section d-none d-lg-flex">
            <div class="brand-content">
                <div class="brand-badge mb-4">⚓ Production Planning v2.0</div>
                <h1 class="brand-title">The Standard in Production Planning</h1>
                <p class="brand-subtitle">Precision tracking, automated reporting, and comprehensive asset management for high-output industrial operations.</p>
                <div class="brand-stats mt-5">
                    <div class="stat-item">
                        <span class="stat-val">99.9%</span>
                        <span class="stat-lbl">Uptime</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-val">3k+</span>
                        <span class="stat-lbl">Assets Managed</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="auth-form-section">
            @Body
        </div>
    </div>
</main>

<style>
    .auth-layout {
        width: 100%;
        min-height: 100vh;
        background: #F8FAFC;
    }
    .auth-grid {
        display: grid;
        grid-template-columns: 1fr;
        min-height: 100vh;
    }
    @@media (min-width: 992px) {
        .auth-grid { grid-template-columns: 1.2fr 1fr; }
    }
    
    .auth-brand-section {
        background: linear-gradient(135deg, #0F172A 0%, #1E40AF 100%);
        color: white;
        padding: 5rem;
        display: flex;
        align-items: center;
        position: relative;
        overflow: hidden;
    }
    .auth-brand-section::after {
        content: "";
        position: absolute;
        top: -10%; right: -10%;
        width: 60%; height: 60%;
        background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 70%);
        border-radius: 50%;
    }
    
    .brand-content { position: relative; z-index: 10; max-width: 600px; }
    .brand-badge { display: inline-block; padding: 6px 12px; background: rgba(255,255,255,0.1); border-radius: 4px; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.05em; border: 1px solid rgba(255,255,255,0.1); }
    .brand-title { font-size: 3.5rem; font-weight: 800; line-height: 1.1; margin-bottom: 2rem; color: white; }
    .brand-subtitle { font-size: 1.1rem; color: rgba(255,255,255,0.7); line-height: 1.6; }
    
    .brand-stats { display: flex; gap: 3rem; }
    .stat-val { display: block; font-size: 1.5rem; font-weight: 800; color: #60A5FA; }
    .stat-lbl { font-size: 0.85rem; color: rgba(255,255,255,0.5); font-weight: 600; text-transform: uppercase; }
    
    .auth-form-section {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        background: white;
    }
</style>
