@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar" style="background-image: linear-gradient(180deg, #1a0505 0%, #340c0c 100%);">
        <PlatformNavMenu />
    </div>

    <main>
        <div class="top-row px-4" style="background-color: #fff5f5; border-bottom: 1px solid #ffcccc;">
            <span class="badge bg-danger shadow-sm">PLATFORM OWNER CONSOLE</span>
            
            <div class="ms-auto d-flex gap-3 align-items-center">
                <span class="text-danger small fw-bold"><i class="bi bi-eye-fill me-1"></i>GOD MODE ACTIVE</span>
            </div>
        </div>

        <article class="content px-4 py-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

<style>
    /* Override Sidebar Width if needed, but standard CSS might handle it */
    .sidebar {
        width: 250px;
    }
</style>
