        margin-right: 16px;
        box-shadow: 0 4px 15px rgba(15, 23, 42, 0.3);
        border: 1px solid rgba(255,255,255,0.1);
    }

    .brand-text-container {
        display: flex;
        flex-direction: column;
        line-height: 1.1;
    }

    .brand-name {
        font-size: 20px;
