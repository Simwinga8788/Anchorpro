@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AnchorPro.Services.Interfaces.ICurrentTenantService TenantService
@inject NavigationManager NavigationManager
@inject AnchorPro.Services.Interfaces.ISettingsService SettingsService

<div class="nav-brand d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center">
        <div class="brand-icon" style="@brandColorStyle">
            <i class="bi bi-anchor"></i>
        </div>
        <div class="brand-text-container">
            <span class="brand-name">Anchor Pro</span>
            <span class="brand-tagline">MINI ERP PLATFORM</span>
        </div>
    </div>
    <button class="btn btn-link text-white d-lg-none p-0" @onclick="OnCloseSidebar">
        <i class="bi bi-x-lg fs-4"></i>
    </button>
</div>

<nav class="sidebar-nav">
    @if (!IsPlatformUser)
    {
            <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
                <i class="bi bi-grid-1x2-fill"></i>
                <span>Dashboard</span>
            </NavLink>

            <div class="nav-section-label">OPERATIONS</div>
            <NavLink class="nav-item" href="job-cards">
                <i class="bi bi-card-checklist"></i>
                <span>Job Cards</span>
            </NavLink>

            <AuthorizeView Roles="Admin,Planner,Supervisor">
                <NavLink class="nav-item" href="planning">
                    <i class="bi bi-calendar3"></i>
                    <span>Planning Board</span>
                </NavLink>
            </AuthorizeView>

            <NavLink class="nav-item" href="equipment">
                <i class="bi bi-gear-fill"></i>
                <span>Asset Registry</span>
            </NavLink>

            <NavLink class="nav-item" href="safety">
                <i class="bi bi-shield-check"></i>
                <span>Safety & Compliance</span>
            </NavLink>

            <div class="nav-section-label">RESOURCES</div>
            @if (Features.Inventory)
            {
                <NavLink class="nav-item" href="inventory">
                    <i class="bi bi-box-seam-fill"></i>
                    <span>Inventory & Parts</span>
                </NavLink>
            }

            <AuthorizeView Roles="Admin">
                <NavLink class="nav-item" href="admin/departments">
                    <i class="bi bi-diagram-3"></i>
                    <span>Org Structure</span>
                </NavLink>
                <NavLink class="nav-item" href="admin/users">
                    <i class="bi bi-people-fill"></i>
                    <span>Team Members</span>
                </NavLink>
            </AuthorizeView>

            <div class="nav-section-label">PROCUREMENT</div>
            <AuthorizeView Roles="Admin,Purchasing">
                <NavLink class="nav-item" href="procurement/suppliers">
                    <i class="bi bi-truck"></i>
                    <span>Suppliers</span>
                </NavLink>
                <NavLink class="nav-item" href="procurement/purchase-orders">
                    <i class="bi bi-file-earmark-text"></i>
                    <span>Purchase Orders</span>
                </NavLink>
            </AuthorizeView>

            <div class="nav-section-label">FINANCIAL</div>
            <AuthorizeView Roles="Admin,Finance">
                <NavLink class="nav-item" href="billing/invoices">
                    <i class="bi bi-currency-dollar"></i>
                    <span>Financial Ledger</span>
                </NavLink>
            </AuthorizeView>

            <div class="nav-section-label">COMMERCIAL</div>
            <NavLink class="nav-item" href="crm">
                <i class="bi bi-person-rolodex"></i>
                <span>Customers & CRM</span>
            </NavLink>

            <AuthorizeView Roles="Admin,Commercial">
                <NavLink class="nav-item" href="commercial/contracts">
                    <i class="bi bi-file-earmark-lock"></i>
                    <span>Service Contracts</span>
                </NavLink>
            </AuthorizeView>

            @if (Features.Reports)
            {
                <NavLink class="nav-item" href="intelligence">
                    <i class="bi bi-pie-chart-fill"></i>
                    <span>Decision Intelligence</span>
                </NavLink>
            }

            <AuthorizeView Roles="Admin">
                <div class="nav-divider" style="opacity: 0.1;"></div>
                <div class="nav-section-label">MANAGEMENT</div>
                
                <NavLink class="nav-item" href="billing">
                    <i class="bi bi-credit-card-fill"></i>
                    <span>Subscription</span>
                </NavLink>

                <NavLink class="nav-item" href="admin/settings?tab=Organization">
                    <i class="bi bi-sliders"></i>
                    <span>Global Settings</span>
                </NavLink>
            </AuthorizeView>
    }
    
    <AuthorizeView>
        @if (IsPlatformUser)
        {
            <div class="nav-divider" style="opacity: 0.1;"></div>
            <div class="nav-section-label" style="color:var(--ap-danger); opacity:0.6;">PLATFORM</div>
            <NavLink class="nav-item" href="platform">
                    <i class="bi bi-shield-lock-fill" style="color:var(--ap-danger);"></i>
                    <span style="color:var(--ap-danger); font-weight:700;">Console</span>
            </NavLink>
        }
    </AuthorizeView>
</nav>

@code {
    [Parameter] public EventCallback OnCloseSidebar { get; set; }
    private bool IsPlatformUser = false;
    private FeatureFlags Features = new();
    
    // Branding
    private string companyName = "Anchor Pro";
    private string? brandColor = null;
    private string brandColorStyle => !string.IsNullOrEmpty(brandColor) 
        ? $"background: {brandColor};" 
        : "background: linear-gradient(135deg, var(--ap-primary) 0%, var(--ap-primary-hover) 100%);";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var email = user.Identity?.Name?.ToLower();
        var tenantClaim = user.FindFirst("TenantId");
        
        IsPlatformUser = (email == "simwinga8788@gmail.com") && tenantClaim == null;
        
        if (!IsPlatformUser)
        {
            await LoadTenantSettings();
        }
    }

    private async Task LoadTenantSettings()
    {
        var name = await SettingsService.GetSettingAsync("Org.CompanyName");
        if (!string.IsNullOrEmpty(name)) 
        {
            companyName = name.Replace("CMMS", "").Replace("v2.0", "").Trim();
        }

        var color = await SettingsService.GetSettingAsync("Org.PrimaryColor"); 
        if (!string.IsNullOrEmpty(color)) brandColor = color;

        var inv = await SettingsService.GetSettingAsync("Feature.Inventory");
        Features.Inventory = inv?.ToLower() != "false";
        
        var rep = await SettingsService.GetSettingAsync("Feature.Reports");
        Features.Reports = rep?.ToLower() != "false";
    }

    private class FeatureFlags
    {
        public bool Inventory { get; set; } = true;
        public bool Reports { get; set; } = true;
    }
}

