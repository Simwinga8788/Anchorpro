@page "/platform/health"
@using AnchorPro.Components.Layout
@layout MainLayout
@using AnchorPro.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Context
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<div class="p-4">
    <h3 class="fw-bold mb-4">System Health Monitor</h3>

    <div class="row g-4">
        <!-- Database -->
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="mb-3">
                        @if (dbConnected) {
                            <i class="bi bi-database-check-fill text-success" style="font-size: 3rem;"></i>
                        } else {
                             <i class="bi bi-database-x-fill text-danger" style="font-size: 3rem;"></i>
                        }
                    </div>
                    <h5>Database</h5>
                    <p class="text-muted small">@dbStatus</p>
                    <span class="badge @(dbConnected ? "bg-success" : "bg-danger")">@(latency)ms Latency</span>
                </div>
            </div>
        </div>

        <!-- Email -->
         <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="mb-3">
                         <i class="bi bi-envelope-check-fill text-success" style="font-size: 3rem;"></i>
                    </div>
                    <h5>Email Gateway</h5>
                    <p class="text-muted small">SMTP Connected</p>
                    <span class="badge bg-success">Ready</span>
                </div>
            </div>
        </div>

        <!-- Storage -->
         <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="mb-3">
                         <i class="bi bi-hdd-network-fill text-success" style="font-size: 3rem;"></i>
                    </div>
                    <h5>File Storage</h5>
                    <p class="text-muted small">Local Provider</p>
                    <span class="badge bg-success">Write Access OK</span>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    bool dbConnected = false;
    long latency = 0;
    string dbStatus = "Checking...";

    protected override async Task OnInitializedAsync() {
        try {
            var sw = System.Diagnostics.Stopwatch.StartNew();
            await Context.Database.CanConnectAsync();
            sw.Stop();
            latency = sw.ElapsedMilliseconds;
            dbConnected = true;
            dbStatus = "Connected (SQL Server)";
        } catch (Exception ex) {
            dbConnected = false;
            dbStatus = ex.Message;
        }
    }
}
