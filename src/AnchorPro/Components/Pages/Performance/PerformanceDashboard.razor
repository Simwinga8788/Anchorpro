@page "/performance"
@using AnchorPro.Data.Models
@using AnchorPro.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@inject IDashboardService DashboardService
@attribute [Authorize(Roles = "Admin,Planner,Supervisor")]
@rendermode InteractiveServer

<PageTitle>Performance Dashboard</PageTitle>

<ApplePageHeader Title="Performance Metrics" Subtitle="Analyze asset reliability and technician efficiency">
    <ActionButtons>
        <button class="btn btn-primary" @onclick="LoadMetrics">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </ActionButtons>
</ApplePageHeader>

@if (metrics == null)
{
    <div class="d-flex justify-content-center p-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else
{
    <div class="row g-3 g-md-4 mb-4">
        <!-- KPI Cards -->
        <div class="col-6 col-md-3">
            <div class="card-premium h-100 d-flex flex-column justify-content-center text-center p-3 p-md-4">
                <div class="h2 fw-800 text-primary mb-1">@metrics.OnTimeCompletionPercentage%</div>
                <div class="text-slate-500 x-small fw-800 text-uppercase" style="letter-spacing: 0.05em;">On-Time Completion</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card-premium h-100 d-flex flex-column justify-content-center text-center p-3 p-md-4">
                <div class="h2 fw-800 text-success mb-1">@metrics.AvgLeadTimeHours h</div>
                <div class="text-slate-500 x-small fw-800 text-uppercase" style="letter-spacing: 0.05em;">Avg. Lead Time</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card-premium h-100 d-flex flex-column justify-content-center text-center p-3 p-md-4">
                <div class="h2 fw-800 text-warning mb-1">@metrics.OverdueJobsCount</div>
                <div class="text-slate-500 x-small fw-800 text-uppercase" style="letter-spacing: 0.05em;">Overdue Jobs</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card-premium h-100 d-flex flex-column justify-content-center text-center p-3 p-md-4">
                <div class="h2 fw-800 text-dark mb-1">@metrics.CompletedJobsInPeriod</div>
                <div class="text-slate-500 x-small fw-800 text-uppercase" style="letter-spacing: 0.05em;">Jobs (30d)</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Technician Performance -->
        <div class="col-lg-6">
            <div class="card-premium h-100">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                    <h5 class="fw-bold mb-0">Technician Performance</h5>
                    <small class="text-muted">Utilization and efficiency</small>
                </div>
                <div class="card-body p-0">
                    <div class="d-none d-md-block table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 border-0 text-secondary x-small text-uppercase">Technician</th>
                                    <th class="border-0 text-secondary x-small text-uppercase text-center">Jobs</th>
                                    <th class="border-0 text-secondary x-small text-uppercase text-center">Hours</th>
                                    <th class="border-0 text-secondary x-small text-uppercase text-end pe-4">Util %</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tech in metrics.TechnicianStats.OrderByDescending(t => t.JobsCompleted).Take(5))
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold">@tech.TechnicianName</td>
                                        <td class="text-center">@tech.JobsCompleted</td>
                                        <td class="text-center">@tech.TotalHoursWorked</td>
                                        <td class="text-end pe-4">
                                            @if(tech.UtilizationPercentage > 80) {
                                                <span class="badge bg-success">@tech.UtilizationPercentage%</span>
                                            } else if (tech.UtilizationPercentage > 50) {
                                                <span class="badge bg-info text-dark">@tech.UtilizationPercentage%</span>
                                            } else {
                                                <span class="badge bg-secondary">@tech.UtilizationPercentage%</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Mobile Technician View -->
                    <div class="d-md-none p-3">
                         @foreach (var tech in metrics.TechnicianStats.OrderByDescending(t => t.JobsCompleted).Take(5))
                         {
                             <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
                                 <div>
                                     <div class="fw-800 text-slate-900">@tech.TechnicianName</div>
                                     <div class="text-slate-500 x-small">@tech.JobsCompleted JOBS &bull; @tech.TotalHoursWorked HR</div>
                                 </div>
                                 <span class="badge @(tech.UtilizationPercentage > 80 ? "bg-success" : (tech.UtilizationPercentage > 50 ? "bg-info text-dark" : "bg-secondary")) fw-800">
                                     @tech.UtilizationPercentage%
                                 </span>
                             </div>
                         }
                    </div>
                </div>
            </div>
        </div>

        <!-- Asset Reliability (Top 5 Worst) -->
        <div class="col-lg-6">
            <div class="card-premium h-100">
                 <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                    <h5 class="fw-bold mb-0">Asset Reliability (Top Issues)</h5>
                    <small class="text-muted">Equipment with most breakdowns</small>
                </div>
                <div class="card-body p-0">
                    <div class="d-none d-md-block table-responsive">
                       <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 border-0 text-secondary x-small text-uppercase">Asset</th>
                                    <th class="border-0 text-secondary x-small text-uppercase text-center">Breakdowns</th>
                                    <th class="border-0 text-secondary x-small text-uppercase text-center">MTTR (Hr)</th>
                                    <th class="border-0 text-secondary x-small text-uppercase text-end pe-4">Total Maint. Hrs</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var eq in metrics.EquipmentStats.OrderByDescending(e => e.BreakdownCount).ThenByDescending(e => e.TotalMaintenanceHours).Take(5))
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold text-truncate" style="max-width: 150px;">@eq.EquipmentName</td>
                                        <td class="text-center">
                                            @if(eq.BreakdownCount > 2) {
                                                 <span class="text-danger fw-bold">@eq.BreakdownCount</span>
                                            } else {
                                                <span>@eq.BreakdownCount</span>
                                            }
                                        </td>
                                        <td class="text-center">@eq.MTTR_Hours</td>
                                        <td class="text-end pe-4">@eq.TotalMaintenanceHours</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Mobile Asset View -->
                    <div class="d-md-none p-3">
                        @foreach (var eq in metrics.EquipmentStats.OrderByDescending(e => e.BreakdownCount).ThenByDescending(e => e.TotalMaintenanceHours).Take(5))
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
                                <div>
                                    <div class="fw-800 text-slate-900 text-truncate" style="max-width: 200px;">@eq.EquipmentName</div>
                                    <div class="text-slate-500 x-small">MTTR: @eq.MTTR_Hours h &bull; TOTAL: @eq.TotalMaintenanceHours h</div>
                                </div>
                                <span class="badge @(eq.BreakdownCount > 2 ? "bg-danger" : "bg-slate-200 text-slate-700") fw-800">
                                    @eq.BreakdownCount FAULTS
                                </span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PerformanceMetrics? metrics;

    protected override async Task OnInitializedAsync()
    {
        await LoadMetrics();
    }

    private async Task LoadMetrics()
    {
        metrics = null;
        // Simulate slight delay for effect if needed, typically fast
        metrics = await DashboardService.GetPerformanceMetricsAsync(30);
    }
}
