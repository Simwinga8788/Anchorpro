@page "/equipment/create"
@page "/equipment/edit/{Id:int}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using AnchorPro.Data.Entities
@using AnchorPro.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Supervisor,Planner")]
@inject IEquipmentService EquipmentService
@inject IOrgService OrgService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@(Id == 0 ? "Add Equipment" : "Edit Equipment")</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-black fw-bold mb-1">@(Id == 0 ? "Add New Asset" : "Edit Asset")</h2>
        <div class="text-secondary small">Register and manage facility machinery</div>
    </div>
    <button class="btn btn-outline-secondary" @onclick="Cancel">
        <i class="bi bi-x-lg me-2"></i>Cancel
    </button>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm p-4">
            <EditForm Model="equipment" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger mb-4">@errorMessage</div>
                }

                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Equipment Name *</label>
                        <InputText @bind-Value="equipment.Name" class="form-control" placeholder="e.g. CNC Lathe #5" />
                        <ValidationMessage For="() => equipment.Name" class="text-danger" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Serial Number *</label>
                        <InputText @bind-Value="equipment.SerialNumber" class="form-control" placeholder="Unique ID" />
                        <ValidationMessage For="() => equipment.SerialNumber" class="text-danger" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Model Number</label>
                        <InputText @bind-Value="equipment.ModelNumber" class="form-control" placeholder="Manufacturer Model" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Manufacturer</label>
                        <InputText @bind-Value="equipment.Manufacturer" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Location / Bay</label>
                        <InputText @bind-Value="equipment.Location" class="form-control" placeholder="Workshop A - Bay 1" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Department (Cost Center)</label>
                        <InputSelect @bind-Value="equipment.DepartmentId" class="form-select">
                            <option value="">-- No Department --</option>
                            @foreach (var dept in departments)
                            {
                                <option value="@dept.Id">@dept.Name (@dept.CostCode)</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top">
                    <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
                    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <span>@(Id == 0 ? "Save Equipment" : "Update Equipment")</span>
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    private Equipment equipment = new();
    private List<Department> departments = new();
    private bool isSubmitting = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        departments = await OrgService.GetAllDepartmentsAsync();
        
        if (Id > 0)
        {
            var existing = await EquipmentService.GetEquipmentByIdAsync(Id);
            if (existing != null)
            {
                equipment = existing;
            }
            else
            {
                NavigationManager.NavigateTo("/equipment");
            }
        }
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.Identity?.Name ?? "System";

            if (Id == 0)
            {
                await EquipmentService.CreateEquipmentAsync(equipment, userId);
            }
            else
            {
                await EquipmentService.UpdateEquipmentAsync(equipment, userId);
            }

            NavigationManager.NavigateTo("/equipment");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel() => NavigationManager.NavigateTo("/equipment");
}
