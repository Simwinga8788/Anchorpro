@page "/equipment"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using AnchorPro.Data.Entities
@using AnchorPro.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IEquipmentService EquipmentService
@inject NavigationManager NavigationManager

<PageTitle>Equipment</PageTitle>

<ApplePageHeader Title="Equipment Registry" Subtitle="Manage assets and machinery">
    <ActionButtons>
        <AuthorizeView Roles="Admin,Supervisor,Planner">
            <button class="btn btn-premium" @onclick="CreateNew">
                <i class="bi bi-plus-lg me-2"></i>ADD NEW ASSET
            </button>
        </AuthorizeView>
    </ActionButtons>
</ApplePageHeader>

<div class="card-premium p-0 overflow-hidden">
    @if (isLoading)
    {
        <div class="d-flex justify-content-center p-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (!equipmentList.Any())
    {
        <div class="text-center p-5 text-slate-400">
            <i class="bi bi-gear-wide display-4 mb-3 opacity-25"></i>
            <p class="fw-800 x-small uppercase">No equipment records identified</p>
            <AuthorizeView Roles="Admin,Supervisor,Planner">
                <button class="btn btn-premium btn-sm px-4" @onclick="CreateNew">INITIALIZE ASSET</button>
            </AuthorizeView>
        </div>
    }
    else
    {
        <div class="d-none d-lg-block">
            <table class="table-premium mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Asset Designation</th>
                        <th>Configuration / Serial</th>
                        <th>Manufacturer</th>
                        <th>Deployment Site</th>
                        <th class="pe-4 text-end">Operations</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in equipmentList)
                    {
                        <tr class="asset-row" @onclick="() => ViewDetails(item.Id)" style="cursor: pointer;">
                            <td class="ps-4 py-4">
                                <div class="fw-800 text-slate-900">@item.Name</div>
                                <div class="x-small text-slate-400 fw-700">ID: @item.Id.ToString().PadLeft(5, '0')</div>
                            </td>
                            <td>
                                <div class="fw-800 text-slate-700 small">@item.ModelNumber</div>
                                <div class="text-slate-400 x-small fw-700 text-uppercase">S/N: @item.SerialNumber</div>
                            </td>
                            <td class="small fw-800 text-slate-600">@item.Manufacturer</td>
                            <td>
                                @if (item.Department == null && string.IsNullOrEmpty(item.Location))
                                {
                                    <span class="text-slate-300 x-small fw-800 uppercase italic">Ondock / Not Assigned</span>
                                }
                                else
                                {
                                    <div class="fw-800 text-slate-900 small">@(item.Department?.Name ?? "General Operations")</div>
                                    <div class="x-small text-slate-400 fw-700">@item.Location</div>
                                }
                            </td>
                            <td class="pe-4 text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <AuthorizeView Roles="Admin,Supervisor,Planner">
                                         <button class="btn-action" title="Edit Asset" @onclick='() => Edit(item.Id)' @onclick:stopPropagation>
                                             EDIT
                                         </button>
                                         <button class="btn-action btn-action-danger" title="Decommission" @onclick='() => Delete(item.Id)' @onclick:stopPropagation>
                                             REMOVE
                                         </button>
                                    </AuthorizeView>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Mobile View (Asset Cards) -->
        <div class="d-lg-none p-3">
            @foreach (var item in equipmentList)
            {
                <div class="card p-3 mb-3 border-0 shadow-sm position-relative overflow-hidden" @onclick="() => ViewDetails(item.Id)" style="cursor: pointer; background: white; border-radius: 12px;">
                    <div class="position-absolute top-0 bottom-0 start-0" style="width: 4px; background-color: var(--ap-primary);"></div>
                    <div class="ps-2">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="fw-800 text-slate-900">@item.Name</span>
                            @if (item.Department != null || !string.IsNullOrEmpty(item.Location))
                            {
                                <div class="text-end">
                                    <span class="badge-premium slate">@(item.Department?.Name ?? item.Location)</span>
                                </div>
                            }
                            else
                            {
                                <span class="text-slate-300 x-small fw-800 uppercase italic">Ondock</span>
                            }
                        </div>
                        <div class="text-slate-500 x-small fw-700 mb-1">MOD: @item.ModelNumber</div>
                        <div class="text-slate-500 x-small fw-700 mb-3">S/N: @item.SerialNumber</div>
                        
                        <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                            <span class="x-small text-slate-400 fw-800 uppercase">@item.Manufacturer</span>
                            <div class="d-flex gap-2">
                                 <button class="btn btn-outline-secondary btn-sm px-3 fw-800" style="border-radius: 6px; font-size: 0.7rem;" @onclick:stopPropagation="true" @onclick="() => Edit(item.Id)">EDIT</button>
                                 <button class="btn btn-outline-danger btn-sm px-3 fw-800" style="border-radius: 6px; font-size: 0.7rem;" @onclick:stopPropagation="true" @onclick="() => Delete(item.Id)">REMOVE</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .x-small { font-size: 0.75rem; }
    /* Ensure table rows have hover effect consistent with Job Cards */
    tbody tr:hover { background-color: #F9FAFB; transition: background-color 0.2s; }
</style>

@code {
    private List<Equipment> equipmentList = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        equipmentList = await EquipmentService.GetAllEquipmentAsync();
        isLoading = false;
    }

    private void CreateNew()
    {
        NavigationManager.NavigateTo("/equipment/create");
    }

    private void ViewDetails(int id)
    {
        NavigationManager.NavigateTo($"/equipment/details/{id}");
    }

    private void Edit(int id)
    {
        NavigationManager.NavigateTo($"/equipment/edit/{id}");
    }

    private async Task Delete(int id)
    {
        // specific generic confirmation dialog usually needed here
        await EquipmentService.DeleteEquipmentAsync(id);
        await LoadData();
    }
}
