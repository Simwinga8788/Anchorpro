@using AnchorPro.Data
@using Microsoft.AspNetCore.Identity
@using AnchorPro.Services.Interfaces
@inject UserManager<ApplicationUser> UserManager
@inject ICurrentTenantService TenantService

@if (IsVisible)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
                <div class="modal-header border-bottom-0 pt-4 px-4">
                    <h5 class="modal-title fw-800 text-slate-900">Add New Team Member</h5>
                    <button type="button" class="btn-close" @onclick="Close"></button>
                </div>
                <div class="modal-body px-4 pb-4">
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger py-2 small fw-600">@ErrorMessage</div>
                    }

                    <div class="mb-3">
                        <label class="form-label x-small fw-800 text-slate-500 text-uppercase">First Name</label>
                        <input class="form-control border-0 bg-light fw-600" style="height: 48px; border-radius: 10px;" @bind="Model.FirstName" placeholder="Enter first name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Last Name</label>
                        <input class="form-control border-0 bg-light fw-600" style="height: 48px; border-radius: 10px;" @bind="Model.LastName" placeholder="Enter last name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Email Address</label>
                        <input type="email" class="form-control border-0 bg-light fw-600" style="height: 48px; border-radius: 10px;" @bind="Model.Email" placeholder="e.g. name@company.com" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Employee / Man Number</label>
                        <input class="form-control border-0 bg-light fw-600" style="height: 48px; border-radius: 10px;" @bind="Model.EmployeeNumber" placeholder="e.g. EMP-001" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Temporary Password</label>
                        <input type="password" class="form-control border-0 bg-light fw-600" style="height: 48px; border-radius: 10px;" @bind="Model.Password" placeholder="Min 6 chars, 1 upper" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label x-small fw-800 text-slate-500 text-uppercase">Security Role</label>
                        <select class="form-select border-0 bg-light fw-600" style="height: 48px; border-radius: 10px;" @bind="Model.Role">
                            <option value="Technician">Technician</option>
                            <option value="Planner">Planner</option>
                            <option value="Supervisor">Supervisor</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-top-0 px-4 pb-4">
                    <button type="button" class="btn btn-light fw-800 px-4" style="border-radius: 10px;" @onclick="Close">CANCEL</button>
                    <button type="button" class="btn btn-primary fw-800 px-4" style="border-radius: 10px;" @onclick="SaveUser">CREATE USER</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public EventCallback OnUserAdded { get; set; }

    private CreateUserModel Model { get; set; } = new();
    private string? ErrorMessage;

    private async Task Close()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(false);
        Model = new();
        ErrorMessage = null;
    }

    private async Task SaveUser()
    {
        ErrorMessage = null;
        if (string.IsNullOrWhiteSpace(Model.Email) || string.IsNullOrWhiteSpace(Model.Password))
        {
            ErrorMessage = "Email and Password are required.";
            return;
        }

        if (TenantService.TenantId == null)
        {
             ErrorMessage = "Error: No Tenant Context found. Please refresh.";
             return;
        }

        var newUser = new ApplicationUser
        {
            UserName = Model.Email,
            Email = Model.Email,
            FirstName = Model.FirstName,
            LastName = Model.LastName,
            EmployeeNumber = Model.EmployeeNumber,
            EmailConfirmed = true,
            CreatedAt = DateTime.UtcNow,
            TenantId = TenantService.TenantId
        };

        var result = await UserManager.CreateAsync(newUser, Model.Password);
        if (result.Succeeded)
        {
            var roleResult = await UserManager.AddToRoleAsync(newUser, Model.Role);
             if (!roleResult.Succeeded)
             {
                 ErrorMessage = "User created but role assignment failed: " + string.Join(", ", roleResult.Errors.Select(e => e.Description));
                 return;
             }

            await OnUserAdded.InvokeAsync();
            await Close();
        }
        else
        {
            ErrorMessage = string.Join(", ", result.Errors.Select(e => e.Description));
        }
    }

    public class CreateUserModel
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string EmployeeNumber { get; set; } = "";
        public string Password { get; set; } = "";
        public string Role { get; set; } = "Technician";
    }
}
