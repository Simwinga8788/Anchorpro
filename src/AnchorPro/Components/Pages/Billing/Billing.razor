@code {
    private TenantSubscription? currentSubscription;
    private SubscriptionPlan? currentPlan;
    private List<SubscriptionPlan> availablePlans = new();
    private bool isLoading = true;
    private int daysRemaining = 0;
    private bool showUpgradeModal = false;
    private SubscriptionPlan? selectedPlan;


    // Payment Submission Fields
    private decimal paymentAmount = 0;
    private string paymentMethod = "";
    private string paymentReference = "";
    private string paymentNotes = "";
    private string uploadedFilePath = "";
    private bool isSubmittingPayment = false;
    private string paymentSubmissionMessage = "";
    private bool paymentSubmissionSuccess = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadSubscriptionData();
    }

    private async Task LoadSubscriptionData()
    {
        isLoading = true;
        currentSubscription = await SubscriptionService.GetCurrentSubscriptionAsync();
        currentPlan = await SubscriptionService.GetCurrentPlanAsync();
        availablePlans = await SubscriptionService.GetAllPlansAsync();
        daysRemaining = await SubscriptionService.GetDaysRemainingAsync();
        isLoading = false;
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            try 
            {
                // Upload via FileService (Saves to wwwroot/uploads/payments)
                // Limit size to 5MB to match UI text
                uploadedFilePath = await FileService.SaveFileAsync(file, "payments");
            }
            catch (Exception ex)
            {
                paymentSubmissionMessage = $"File upload failed: {ex.Message}";
                paymentSubmissionSuccess = false;
            }
        }
    }

    private async Task SubmitPaymentProof()
    {
        paymentSubmissionMessage = "";
        paymentSubmissionSuccess = false;

        // Validation
        if (paymentAmount <= 0)
        {
            paymentSubmissionMessage = "Please enter a valid payment amount.";
            return;
        }
        if (string.IsNullOrWhiteSpace(paymentMethod))
        {
            paymentSubmissionMessage = "Please select a payment method.";
            return;
        }
        if (string.IsNullOrWhiteSpace(paymentReference))
        {
            paymentSubmissionMessage = "Please enter a transaction reference.";
            return;
        }

        isSubmittingPayment = true;

        try
        {
            var payment = new PaymentTransaction
            {
                TenantId = Context.CurrentTenantId,
                TenantSubscriptionId = currentSubscription?.Id,
                Amount = paymentAmount,
                Currency = currentPlan?.Currency ?? "ZMW",
                PaymentMethod = paymentMethod,
                TransactionReference = paymentReference,
                Status = "Pending",
                ProofDocumentUrl = uploadedFilePath,
                Notes = paymentNotes
            };

            Context.PaymentTransactions.Add(payment);
            await Context.SaveChangesAsync();

            paymentSubmissionSuccess = true;
            paymentSubmissionMessage = "Payment proof submitted successfully! Our team will review and approve it within 24 hours.";

            // Clear form
            paymentAmount = 0;
            paymentMethod = "";
            paymentReference = "";
            paymentNotes = "";
            uploadedFilePath = "";
        }
        catch (Exception ex)
        {
            paymentSubmissionMessage = $"Error submitting payment: {ex.Message}";
        }
        finally
        {
            isSubmittingPayment = false;
        }
    }

    private void UpgradePlan(int planId)
    {
        selectedPlan = availablePlans.FirstOrDefault(p => p.Id == planId);
        showUpgradeModal = true;
    }

    private void CloseUpgradeModal()
    {
        showUpgradeModal = false;
        selectedPlan = null;
    }

    private async Task SubmitUpgradePayment()
    {
        if (selectedPlan == null)
        {
            paymentSubmissionMessage = "No plan selected.";
            paymentSubmissionSuccess = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(paymentMethod) || string.IsNullOrWhiteSpace(paymentReference) || string.IsNullOrEmpty(uploadedFilePath))
        {
            paymentSubmissionMessage = "Please fill all required fields and upload proof document.";
            paymentSubmissionSuccess = false;
            return;
        }

        isSubmittingPayment = true;
        paymentSubmissionMessage = "";

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.Identity?.Name ?? "System";

            var payment = new PaymentTransaction
            {
                TenantSubscriptionId = currentSubscription?.Id,
                Amount = paymentAmount > 0 ? paymentAmount : selectedPlan.MonthlyPrice,
                Currency = selectedPlan.Currency,
                PaymentMethod = paymentMethod,
                TransactionReference = paymentReference,
                ProofDocumentUrl = uploadedFilePath,
                Notes = $"Upgrade to {selectedPlan.Name}. {paymentNotes}",
                Status = "Pending",
                CreatedAt = DateTime.UtcNow,
                CreatedBy = userId
            };

            Context.PaymentTransactions.Add(payment);
            await Context.SaveChangesAsync();

            paymentSubmissionSuccess = true;
            paymentSubmissionMessage = "Payment proof submitted successfully! Awaiting platform owner approval.";
            
            // Reset form
            paymentAmount = 0;
            paymentMethod = "";
            paymentReference = "";
            paymentNotes = "";
            uploadedFilePath = null;

            // Close modal after 2 seconds
            await Task.Delay(2000);
            CloseUpgradeModal();
        }
        catch (Exception ex)
        {
            paymentSubmissionSuccess = false;
            paymentSubmissionMessage = $"Error submitting payment: {ex.Message}";
        }
        finally
        {
            isSubmittingPayment = false;
        }
    }

    private string GetStatusBadgeClass()
    {
        return currentSubscription?.Status?.ToLower() switch
        {
            "active" => "bg-success",
            "trial" => "bg-warning text-dark",
            "suspended" => "bg-danger",
            "cancelled" => "bg-secondary",
            _ => "bg-secondary"
        };
    }
}
