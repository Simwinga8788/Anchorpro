@page "/billing"
@using AnchorPro.Data.Entities
@using AnchorPro.Services.Interfaces
@using AnchorPro.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Roles = "Admin")]
@inject ISubscriptionService SubscriptionService
@inject ApplicationDbContext Context
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AnchorPro.Services.Interfaces.IFileService FileService
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Subscription & Billing</PageTitle>

<div class="container-fluid py-4 px-lg-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-5 gap-3 text-start">
        <div>
            <div class="text-primary x-small fw-800 text-uppercase mb-1" style="letter-spacing: 0.1em;">FINANCIAL OPERATIONS</div>
            <h1 class="fw-800 text-slate-900 mb-0">Subscription & Billing</h1>
        </div>
        @if (currentSubscription != null && currentSubscription.IsTrial)
        {
            <div class="badge bg-warning text-dark px-3 py-2 fw-800 x-small shadow-sm">
                <i class="bi bi-clock-history me-1"></i>
                TRIAL: @daysRemaining DAYS REMAINING
            </div>
        }
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-slate-500 fw-600">Retrieving ledger details...</p>
        </div>
    }
    else
    {
        <!-- Current Plan Overview -->
        <div class="card card-premium mb-5 p-0 overflow-hidden">
             <div class="card-header bg-white border-bottom py-4 px-4 d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-0 fw-800 text-slate-900">Current Deployment Plan</h5>
                    <div class="text-slate-500 x-small fw-800 uppercase">ACTIVE CONFIGURATION: @currentPlan?.Name?.ToUpper()</div>
                </div>
                <div class="text-end">
                    <div class="h3 fw-800 text-primary mb-0">@currentPlan?.Currency @currentPlan?.MonthlyPrice.ToString("N0")</div>
                    <div class="x-small text-slate-400 fw-800 uppercase">PER MONTHLY CYCLE</div>
                </div>
            </div>

            <div class="row g-0">
                <div class="col-lg-7 p-4 border-end">
                    <h6 class="fw-800 text-slate-500 x-small text-uppercase mb-4">PROTOCOL SPECIFICATIONS</h6>
                    <div class="row g-4 mb-4">
                        <div class="col-6 col-md-3">
                            <div class="text-slate-400 x-small fw-800 uppercase mb-1">TECHNICIANS</div>
                            <div class="h4 fw-800 text-slate-900 mb-0">@currentPlan?.MaxTechnicians</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-slate-400 x-small fw-800 uppercase mb-1">EQUIPMENT</div>
                            <div class="h4 fw-800 text-slate-900 mb-0">@currentPlan?.MaxEquipment</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-slate-400 x-small fw-800 uppercase mb-1">ACTIVE JOBS</div>
                            <div class="h4 fw-800 text-slate-900 mb-0">@currentPlan?.MaxActiveJobs</div>
                        </div>
                         <div class="col-6 col-md-3">
                            <div class="text-slate-400 x-small fw-800 uppercase mb-1">STORAGE</div>
                            <div class="h4 fw-800 text-slate-900 mb-0">@(currentPlan?.StorageLimitMB / 1024)GB</div>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-3">
                        <div class="d-flex align-items-center gap-2 x-small fw-800 @(currentPlan?.AllowExports == true ? "text-success" : "text-slate-300")">
                            <i class="bi bi-check-circle-fill"></i> EXPORT MODULE
                        </div>
                        <div class="d-flex align-items-center gap-2 x-small fw-800 @(currentPlan?.AllowPredictiveEngine == true ? "text-success" : "text-slate-300")">
                            <i class="bi bi-cpu-fill"></i> PREDICTIVE ENGINE
                        </div>
                         <div class="d-flex align-items-center gap-2 x-small fw-800 @(currentPlan?.AllowMobileAccess == true ? "text-success" : "text-slate-300")">
                            <i class="bi bi-phone-fill"></i> MOBILE PROTOCOL
                        </div>
                    </div>
                </div>
                <div class="col-lg-5 p-4 bg-slate-50">
                    <h6 class="fw-800 text-slate-500 x-small text-uppercase mb-4">STATUS & RENEWAL</h6>
                    <div class="d-flex justify-content-between mb-3">
                         <span class="x-small fw-800 text-slate-500 uppercase">SYSTEM STATUS</span>
                         <span class="badge @GetStatusBadgeClass() fw-800 x-small px-3">@currentSubscription?.Status?.ToUpper()</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                         <span class="x-small fw-800 text-slate-500 uppercase">BILLING CYCLE</span>
                         <span class="x-small fw-800 text-slate-900">MONTHLY</span>
                    </div>
                    @if (currentSubscription?.NextBillingDate != null)
                    {
                        <div class="d-flex justify-content-between mb-4">
                             <span class="x-small fw-800 text-slate-500 uppercase">RENEWAL DATE</span>
                             <span class="x-small fw-800 text-primary">@currentSubscription.NextBillingDate.Value.ToString("MMM dd, yyyy")</span>
                        </div>
                    }
                    <button class="btn btn-outline-dark fw-800 w-100 x-small mt-2">DOWNLOAD LAST INVOICE</button>
                </div>
            </div>
        </div>

        <!-- Available Plans -->
        <h5 class="fw-800 text-slate-900 mb-4">Upgrade Protocols</h5>
        <div class="row g-4 mb-5">
            @foreach (var plan in availablePlans)
            {
                <div class="col-lg-4">
                    <div class="card h-100 border-0 shadow-sm p-4 @(plan.Id == currentPlan?.Id ? "border-2 border-primary" : "")" style="transition: transform 0.2s;">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h6 class="fw-800 text-slate-900 mb-0 uppercase">@plan.Name</h6>
                            @if (plan.Id == currentPlan?.Id)
                            {
                                <span class="badge bg-primary-subtle text-primary fw-800 x-small">CURRENT</span>
                            }
                        </div>
                        <div class="mb-4">
                            <span class="h3 fw-800 text-slate-900">@plan.Currency @plan.MonthlyPrice.ToString("N0")</span>
                            <span class="x-small text-slate-400 fw-600">/MO</span>
                        </div>
                        <p class="x-small text-slate-500 fw-600 mb-4" style="min-height: 40px;">@plan.Description</p>
                        
                        <div class="vstack gap-2 mb-4">
                             <div class="d-flex align-items-center gap-2 x-small fw-700 text-slate-600">
                                 <i class="bi bi-people text-slate-400"></i> @plan.MaxTechnicians Technicians
                             </div>
                             <div class="d-flex align-items-center gap-2 x-small fw-700 text-slate-600">
                                 <i class="bi bi-gear-wide text-slate-400"></i> @plan.MaxEquipment Assets
                             </div>
                             <div class="d-flex align-items-center gap-2 x-small fw-700 text-slate-600">
                                 <i class="bi bi-clipboard-check text-slate-400"></i> @plan.MaxActiveJobs Work Orders
                             </div>
                        </div>

                        @if (plan.Id != currentPlan?.Id)
                        {
                            <button class="btn @(plan.MonthlyPrice > (currentPlan?.MonthlyPrice ?? 0) ? "btn-primary" : "btn-outline-dark") w-100 fw-800" @onclick="() => UpgradePlan(plan.Id)">
                                @(plan.MonthlyPrice > (currentPlan?.MonthlyPrice ?? 0) ? "UPGRADE SYSTEM" : "DOWNGRADE")
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-light w-100 fw-800 disabled" disabled>ACTIVE PLAN</button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showUpgradeModal)
{
    <div class="modal-backdrop" @onclick="CloseUpgradeModal"></div>
    <div class="upgrade-modal">
        <div class="modal-header">
            <h5><i class="bi bi-receipt me-2"></i>Submit Payment for Plan Upgrade</h5>
            <button class="btn-close" @onclick="CloseUpgradeModal"></button>
        </div>
        <div class="modal-body">
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                <strong>Manual Approval Required:</strong> Upload your payment proof below. The platform owner will review and approve your upgrade.
            </div>

            <div class="plan-change-summary mb-4">
                <div class="change-row">
                    <span>Current Plan:</span>
                    <strong>@currentPlan?.Name</strong>
                </div>
                <div class="change-row">
                    <span>Upgrading to:</span>
                    <strong>@selectedPlan?.Name</strong>
                </div>
                <div class="change-row">
                    <span>Amount to Pay:</span>
                    <strong class="text-primary">@selectedPlan?.Currency @selectedPlan?.MonthlyPrice.ToString("N0")</strong>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Payment Amount</label>
                    <div class="input-group">
                        <span class="input-group-text">@(selectedPlan?.Currency ?? "ZMW")</span>
                        <input type="number" class="form-control" @bind="paymentAmount" 
                               placeholder="@selectedPlan?.MonthlyPrice.ToString("N0")" />
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Payment Method</label>
                    <select class="form-select" @bind="paymentMethod">
                        <option value="">Select method...</option>
                        <option value="Bank Transfer">Bank Transfer</option>
                        <option value="Mobile Money">Mobile Money (MTN/Airtel)</option>
                        <option value="Cash Deposit">Cash Deposit</option>
                    </select>
                </div>
                <div class="col-md-12">
                    <label class="form-label fw-bold">Transaction Reference</label>
                    <input type="text" class="form-control" @bind="paymentReference" 
                           placeholder="e.g., TXN123456789 or Receipt Number" />
                </div>
                <div class="col-md-12">
                    <label class="form-label fw-bold">Upload Proof Document <span class="text-danger">*</span></label>
                    <InputFile class="form-control mb-2" accept=".pdf,.jpg,.jpeg,.png" 
                           OnChange="HandleFileUpload" />
                    
                    @if (!string.IsNullOrEmpty(uploadedFilePath))
                    {
                        <div class="alert alert-success py-1 px-2 small mb-1">
                            <i class="bi bi-check-circle me-1"></i> File Selected
                        </div>
                    }
                    <small class="text-muted d-block">Accepted: PDF, JPG, PNG (Max 5MB)</small>
                </div>
                <div class="col-md-12">
                    <label class="form-label fw-bold">Additional Notes (Optional)</label>
                    <textarea class="form-control" rows="2" @bind="paymentNotes" 
                              placeholder="Any additional information..."></textarea>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(paymentSubmissionMessage))
            {
                <div class="alert @(paymentSubmissionSuccess ? "alert-success" : "alert-danger") mt-3">
                    <i class="bi @(paymentSubmissionSuccess ? "bi-check-circle" : "bi-x-circle") me-2"></i>
                    @paymentSubmissionMessage
                </div>
            }
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" @onclick="CloseUpgradeModal">Cancel</button>
            <button class="btn btn-primary" @onclick="SubmitUpgradePayment" disabled="@isSubmittingPayment">
                @if (isSubmittingPayment)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                else
                {
                    <i class="bi bi-send me-2"></i>
                }
                Submit for Approval
            </button>
        </div>
    </div>
}

